package com.gymlogger.data

import com.gymlogger.model.Exercise
import com.gymlogger.model.MuscleGroup
import com.gymlogger.model.Exercise.Equipment
import com.gymlogger.model.Exercise.ExerciseCategory

object ExerciseRepository {

    val exerciseDatabase: List<Exercise> = listOf(
        // ABS
        Exercise(1001L, "Plank", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by kneeling on all fours and aligning both hands right below your shoulders, keeping your knees beneath your hips.\n2. Extend both of your feet out behind you and squeeze on your core muscles, making sure that your body is aligned straight.\n3. Hold this position for about 30 seconds to a minute.\n4. Release, return back to the starting position and repeat for as many times as you would like to perform this exercise."),
        Exercise(1002L, "Machine Ab Crunch", listOf(MuscleGroup.CORE), Equipment.MACHINE, "1. Set Up: Adjust the Seat and Back Pad. Ensure the seat height is adjusted so that your knees are at a 90-degree angle when seated.\n2. Your upper back should be against the pad.\n3. Engage Your Core: Tighten your abdominal muscles before starting the movement.\n4. Slowly contract your abs to curl your torso forward.\n5. Exhale as you crunch forward.\n6. Slowly release the contraction and return to the starting position."),
        Exercise(1003L, "Crunch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by placing your hands across your chest or on either side of your head as this will be your starting position.\n2. Then slowly raise your upper body (head, shoulders and chest) up off of the floor and towards your knees, squeezing and crunching your abs.\n3. Hold this position for a count, squeezing your abs, then return back to the starting position.\nTips: Make sure to keep your hips straight and your lower back against the floor during this exercise."),
        Exercise(1004L, "Cable Kneeling Crunch (Rope)", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Kneel below a high pulley that contains a rope attachment.\n2. Grasp cable rope attachment and lower the rope until your hands are near your cheeks.\n3. Crunch down with your abs so that your face gets very close to the ground.\n4. Kneel back up slowly and inhale.\n5. Repeat for the desired amount of reps.\nTips: For a more intense workout go at a slower pace."),
        Exercise(1005L, "Hanging Leg Raise", listOf(MuscleGroup.CORE), Equipment.OTHER, "1. Find a pull-up bar or a secure overhead bar that can support your weight.\n2. Tighten your core muscles before you start the movement.\n3. Keeping your legs straight, lift them up towards your torso.\n4. Aim to bring your feet as high as possible, ideally reaching the level of the bar or higher if your flexibility allows.\n5. Slowly lower your legs back to the starting position in a controlled manner."),
        Exercise(1006L, "Leg Raise", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie flat on your back on the floor, a bench or an exercise mat.\n2. Keep your legs straight and together.\n3. Raise Your Legs: Slowly lift your legs up towards the ceiling, keeping them straight and together.\n4. Lower Your Legs: Slowly lower your legs back to the starting position in a controlled manner."),
        Exercise(1007L, "Weight Plate Russian Twist", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Start off with your back on the floor and your feet under a bench or have a partner holding them.\n2. Bend your knees and lift your upper body off of the floor as if you were in a sit up position.\n3. Stick your arms out in front of your chest with your hands together.\n4. Twist your torso to the right while exhaling, holding on and squeezing your abs for a few seconds.\n5. Move back to the starting position, then repeat in the alternate direction."),
        Exercise(1008L, "Decline Crunch", listOf(MuscleGroup.CORE), Equipment.MACHINE, "1. Start by lying with your back flat on a decline bench and placing your feet securely under the foot rest pads.\n2. Place your hands either across your chest or on either side of your head.\n3. Lie back fully and slowly rise with your upper body, crunching your abdominals.\n4. Continue forward until you feel a tightening in your ab muscles and hold for a count.\n5. Return to the starting position and repeat for as many repetitions and sets as desired."),
        Exercise(1009L, "Dumbbell Side Bend", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start by standing with your feet shoulder-width apart with your knees slightly bent and abs drawn in.\n2. Grab a dumbbell in one hand.\n3. Bend at the waist to one side of your body as far as possible.\n4. Hold onto the position for a count, squeezing your abdominal muscles.\n5. Return back to the starting position.\nTips: Be careful to bend only at your waist and not at the hips or knees."),
        Exercise(1010L, "Parallel Bar Leg Raise", listOf(MuscleGroup.CORE), Equipment.MACHINE, "1. Start by positioning yourself on parallel bars by placing your back on the padding.\n2. Forearms rested upon the arm rests and grabbing the handles in front of you.\n3. Keep your legs extended and together.\n4. Slowly elevate your feet up towards the ceiling, still keeping them together and straight.\n5. Squeeze your lower abs as much possible on the way up and go up as far as possible.\n6. Hold for a count then return back to the starting position."),
        Exercise(1011L, "Air Bike", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie flat on your back on a mat.\n2. Crunch Up and Twist: Simultaneously lift your upper body and twist to bring your right elbow towards your left knee while straightening your right leg.\n3. Alternate Sides: Switch sides by bringing your left elbow towards your right knee while straightening your left leg."),
        Exercise(1012L, "Dead Bug", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by lying flat on your back.\n2. Keep your back in its natural position without flattening it.\n3. Extend your arms.\n4. Raise your feet, knees and hips.\n5. To execute the movement, lower opposite arm and leg simultaneously.\n6. Repeat with the other arm and leg."),
        Exercise(1013L, "Side Plank", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by lying on your right side with legs extended out, one foot on top of the other.\n2. Place your right elbow right underneath your right shoulder.\n3. Elevate your hips and draw inward towards your spine.\n4. Lift the body onto the forearm and hold for 30 seconds to a minute.\n5. Lower back to the floor."),
        Exercise(1014L, "Cable Wood Chop", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Stand with your feet shoulder width apart and your knees slightly bent.\n2. Hold a high pulley cable at about shoulder level to one side of your body.\n3. Slowly bring the cable downward in a diagonal direction.\n4. Press the pulley into your opposite thigh, squeezing your oblique muscles.\n5. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(1015L, "Hanging Knee Raise", listOf(MuscleGroup.CORE), Equipment.OTHER, "1. Start off by grabbing onto a hanging grip or pull up bar.\n2. Use a comfortable distance between your hands and a strong grip.\n3. Slowly lift your knees in towards your chest until you feel tension on your lower abs.\n4. Hold this position for a few seconds.\n5. Return back to the starting position and repeat for the desired reps and sets."),
        Exercise(1016L, "Weighted Crunch", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Start by laying flat on your back on the ground.\n2. Rest your feet at a 90 degree angle on a bench.\n3. Hold a weight to your chest or extended out in front of you.\n4. Slowly elevate your shoulders off of the floor while your lower back keeps you positioned on the floor.\n5. As soon as you feel tension in your abs, squeeze and hold for a few seconds.\n6. Release and return back to the starting position."),
        Exercise(1017L, "Cable Pallof Press with Rotation", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start off by connecting a cable to a high pulley cable machine at shoulder height level.\n2. Stand to the side of the machine, grasping the cable with both hands.\n3. Slowly pull the cable in towards your chest.\n4. Squeeze your pecs, hold this position for a count.\n5. Push the cable back out in front of your chest.\n6. While squeezing your abs, twist through your hips in the opposite direction of the machine.\n7. Get a full rotation and feel a stretch in your abdominals."),
        Exercise(1018L, "Barbell Ab Rollout (Kneeling)", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Start off placing a barbell on the floor in front of you.\n2. Kneel in front of the bar, gripping it with a shoulder-width overhand grip.\n3. With a slow controlled motion, roll the bar out so that your back is straight.\n4. Bend your knees and keep your feet off the floor.\n5. Roll back up bringing the bar under your shoulders.\n6. Return to the starting position.\n7. Repeat for as many reps and sets as desired."),
        Exercise(1019L, "Sit-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie flat on the floor.\n2. Bend knees and place hands behind the head.\n3. Lift the upper body toward the knees while contracting abdominals.\n4. Squeeze abs at the top.\n5. Slowly return to the starting position.\n6. Repeat for desired reps."),
        Exercise(1020L, "Reverse Crunch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start lying flat with knees bent and arms at sides.\n2. Lift hips and roll pelvis back while moving legs toward the chest.\n3. Squeeze abs and hold briefly.\n4. Return legs to the floor.\n5. Repeat."),
        Exercise(1021L, "Bench Weighted Decline Crunch", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lay on a decline bench with a weight plate crossed over the chest.\n2. Curl body up while squeezing abdominals.\n3. Hold the top position for a few seconds.\n4. Return to start and repeat."),
        Exercise(1022L, "Parallel Bar Hip Raise", listOf(MuscleGroup.CORE), Equipment.MACHINE, "1. Rest forearms on machine pads with hands on handles.\n2. Keep back pressed firm.\n3. Lift legs straight with knees bent.\n4. Hold when parallel to chest.\n5. Lower legs slowly to start.\n6. Repeat."),
        Exercise(1023L, "Mountain Climber", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start in a high plank with arms extended.\n2. Keep body straight and engage core.\n3. Drive one knee toward chest quickly.\n4. Alternate legs in a climbing motion.\n5. Maintain pace and avoid sagging hips."),
        Exercise(1024L, "Alternating Heel Touch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back with knees bent and feet hip-width apart.\n2. Extend arms down.\n3. Lift shoulders and reach right hand to right heel.\n4. Return to center.\n5. Reach left hand to left heel.\n6. Alternate smoothly."),
        Exercise(1025L, "Bird Dog", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Kneel on all fours with wrists under shoulders.\n2. Extend right arm forward and left leg back.\n3. Hold briefly.\n4. Return and extend left arm and right leg.\n5. Switch sides.\n6. Repeat."),
        Exercise(1026L, "Seated Leg Tuck", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Sit in middle of flat bench with legs stretched out.\n2. Lean upper body back slightly.\n3. Curl knees toward chest and bring chest close to shins.\n4. Squeeze abs.\n5. Return to start.\n6. Repeat."),
        Exercise(1027L, "Cable Crunch", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Attach rope to high pulley.\n2. Turn back to machine and pull rope over head.\n3. Crunch forward until head is near thighs.\n4. Hold for a count.\n5. Return to upright.\n6. Repeat sets."),
        Exercise(1028L, "Weighted Side Bend", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Stand straight holding a weight plate in one arm.\n2. Rest other arm behind head with palm on head.\n3. Bend torso to side feeling tension in obliques.\n4. Hold.\n5. Return and switch sides."),
        Exercise(1029L, "Oblique Crunch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back with knees bent.\n2. Hands behind head without pulling neck.\n3. Lift shoulders and twist torso to the side.\n4. Exhale during crunch.\n5. Hold at top.\n6. Lower slowly.\n7. Repeat."),
        Exercise(1030L, "Stability Ball Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Sit on ball and walk feet forward to roll back onto it.\n2. Lean back so thighs are parallel.\n3. Hands behind head.\n4. Crunch up using abs.\n5. Hold squeeze.\n6. Lower slowly.\n7. Continue motion."),
        Exercise(1031L, "V-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lay on mat with legs extended upward.\n2. Hands extended above chest.\n3. Squeeze abs to reach up with arms between legs.\n4. Hold briefly.\n5. Return legs and arms to start.\n6. Repeat."),
        Exercise(1032L, "Leg Pull-In", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Back flat on floor with legs extended.\n2. Pull knees toward chest while exhaling.\n3. Squeeze abs at chest level.\n4. Hold briefly.\n5. Inhale and release legs back to floor.\n6. Repeat."),
        Exercise(1033L, "Bench Leg Raise (Supine)", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lie on back on flat bench.\n2. Raise legs together in air.\n3. Extend legs straight up pointing to ceiling.\n4. Lower legs slowly.\n5. Control movement to avoid swinging.\n6. Repeat for reps."),
        Exercise(1034L, "Scissor Kick", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Back flat, hands at sides.\n2. Bend knees and lift legs.\n3. Lift left leg higher than right while lowering right leg.\n4. Alternate crossing legs up and down.\n5. Keep back on floor.\n6. Repeat."),
        Exercise(1035L, "Dumbbell Single-Leg Cobra", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Stand holding dumbbells at sides.\n2. Lift one foot a few inches.\n3. Lean forward keeping arms straight.\n4. Rotate hands in arc behind you.\n5. Return upright.\n6. Switch legs.\n7. Repeat."),
        Exercise(1036L, "Weighted Trunk Rotation", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Stand with feet shoulder width apart.\n2. Hold weight plate against chest.\n3. Rotate torso to right without twisting feet.\n4. Rotate to left and contract abs.\n5. Return to center.\n6. Repeat."),
        Exercise(1037L, "Dumbbell Wood Chop", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Stand off with your feet shoulder width apart and your knees slightly bent.\n2. Hold a dumbbell over your head to one side of your body.\n3. Slowly bring the dumbbell down in a diagonal direction.\n4. Press the weight into your opposite thigh.\n5. Squeeze your oblique muscles."),
        Exercise(1038L, "Cable Seated Crunch", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Sit on a flat bench with your back facing a high pulley with a rope attachment.\n2. Grasp cable rope attachment.\n3. While keeping hips still perform a crunch with your abs while holding the rope at the backside of your head."),
        Exercise(1039L, "Weight Plate Rotation", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Lie on a mat or on the floor.\n2. While sitting up extend your knees out with a slight bend.\n3. Your feet should be a few inches off the ground.\n4. Grab a plate and rotate from one side of your chest to the other side while maintaining your body position."),
        Exercise(1040L, "Plank with Shoulder Taps", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by getting into a plank position on the floor.\n2. Place your hands directly beneath your shoulders.\n3. Your body forming a straight line from your head to your heels.\n4. Engage your core muscles to stabilize your body.\n5. Lift one hand off the floor and touch the opposite shoulder."),
        Exercise(1041L, "Jackknife Sit-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie flat on your back on an exercise mat.\n2. Extend your arms straight back behind your head, keeping them close to your ears.\n3. Extend your legs straight out in front of you, keeping them close together.\n4. Lift your arms and legs simultaneously."),
        Exercise(1042L, "Dragon Flag", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Start by laying on a decline or flat bench.\n2. Grab the end of it behind your head with both hands.\n3. Squeeze and create tension throughout your body.\n4. Feel your muscles and abdominals tighten."),
        Exercise(1043L, "Weighted Hanging Knee Raise", listOf(MuscleGroup.CORE), Equipment.OTHER, "1. Stand in front of a pull up bar with a dumbbell in between your legs.\n2. Grab the pull up bar.\n3. Lift your body up off of the floor with the dumbbell pressed between your feet so that it is secure for your motion up."),
        Exercise(1044L, "Cross Body Crunch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by lying on your back.\n2. Bring your knees up in a 60-degree angle.\n3. Keep your feet flat on the floor.\n4. Place your hands on either side of your head.\n5. Slowly curl up raising your right elbow and your left knee so that they touch over your chest."),
        Exercise(1045L, "Cable Side Bend", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Stand up straight and sideways next to a low pulley single handle attachment.\n2. Grip the handle.\n3. Adjust your weight and position.\n4. Slowly bend to the opposite direction of the low pulley machine.\n5. Contract with your abs."),
        Exercise(1046L, "Toe Touches", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start off lying down with your back flat on an exercise mat or the floor.\n2. Your arms lying across your sides with palms facing down.\n3. Legs touching each other as this is your starting position.\n4. Slowly raise your legs till they are pointing in the air."),
        Exercise(1047L, "Decline Bench Weighted Twist", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lay with your back flat on a decline bench.\n2. Hold a weight plate or dumbbell to your chest.\n3. Place your feet underneath the padded foot rests.\n4. While keeping your back straight, slowly lean up so that your back creates a 90-degree angle with the bench."),
        Exercise(1048L, "Extended Arm Child Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start off with placing your hands and knees on the floor.\n2. Keep your feet extended and hands underneath your shoulders.\n3. Take your right hand and place it underneath your left.\n4. Slowly sit back onto your heels.\n5. Move your head forward in the direction of your stretch."),
        Exercise(1049L, "Side Bridge", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by lying on one side of your body with your legs bent.\n2. Your forearm perpendicular to your body.\n3. Once in position, draw your abs in.\n4. Slowly raise yourself up so that you are balanced on your forearm."),
        Exercise(1050L, "Barbell Ab Rollout", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Load a barbell with weight plates that can roll smoothly on the floor.\n2. Kneel on an exercise mat to protect your knees.\n3. Position the barbell in front of you.\n4. Grip it with an overhand grip, hands shoulder-width apart."),
        Exercise(1051L, "Bench Crunch", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lie on your back with your feet up on a bench.\n2. Keep your knees bent at a 90-degree angle.\n3. Place your hands across your chest or on either side of your head.\n4. Raise your head, shoulders and chest off the floor moving towards your knees."),
        Exercise(1052L, "Decline Bench Leg Raise", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lay with your back flat on a decline bench.\n2. Head rested upon the highest end and holding onto the pads above your head to stabilize your body.\n3. Keeping your feet and knees together.\n4. Point your legs straight out in front of you in a plank position."),
        Exercise(1053L, "Rotational Crunch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lay with your back flat on the ground.\n2. Knees bent and arms at your sides.\n3. Place one leg on top of the other with the lifted leg's ankle rested upon the bent knee.\n4. Place your hands, interlocking your fingers, behind your head for support.\n5. Lift shoulders and rotate torso."),
        Exercise(1054L, "Glute Bridge March", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on your back on a mat or comfortable surface with your knees bent.\n2. Your feet flat on the ground.\n3. Keep your arms by your sides with your palms facing down for stability.\n4. Lift your hips upward by pushing through your heels until your body forms a straight line.\n5. March alternating legs while keeping hips elevated."),
        Exercise(1055L, "Abdominal Pendulum", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by laying with your back flat on the floor.\n2. Your legs together extended out in front of you.\n3. Your hands placed out to your sides so that you are in a T position.\n4. Slowly lift your legs up and over your body.\n5. Create a right angle to the floor.\n6. Twist only at your hips.\n7. Lower your feet slowly to the floor to your right without losing any control.\n8. As soon as you feel a stretch in your obliques, return to the starting position and repeat on the opposite side."),
        Exercise(1056L, "Cable Oblique Crunch", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by standing with your side next to a high pulley cable machine with a grip attachment connected to the machine.\n2. Grasp the handle with one of your hands.\n3. Your feet shoulder width apart and the other arm rested at your side.\n4. Slowly pull down and rotate the body with the arm grasping the cable with your obliques until you feel a stretch in your core.\n5. Return back to the starting position and switch to the opposite side.\n6. Repeat for as many reps and sets as desired."),
        Exercise(1057L, "Kettlebell Figure Eight", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Take one kettlebell and place it between your legs.\n2. Bending over and pressing your glutes out.\n3. Keep your back flat.\n4. Take the kettlebell and pass it between the legs to your other hand that is behind the legs.\n5. Repeat this motion with a figure eight motion.\n6. Repeat this exercise for as many repetitions as needed.\n7. You can also alternate the direction of which the kettlebells are passed between the legs."),
        Exercise(1058L, "Kettlebell Leg Pass", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Take one kettlebell and place it between your legs.\n2. Bending over and pressing your glutes out.\n3. Keep your back flat.\n4. Take the kettlebell and pass it between your legs to your other hand behind the legs.\n5. Make sure that you are passing the kettlebell only behind your legs.\n6. Repeat this motion with a W returning the kettlebell to the front with each pass through.\n7. Repeat this exercise for as many repetitions as needed.\n8. You can also alternate the direction of which the kettlebells are passed between the legs."),
        Exercise(1059L, "Bird Dog Elbow to Knee", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin on your hands and knees on a mat or soft surface.\n2. Your hands should be directly under your shoulders.\n3. Your knees should be under your hips.\n4. Forming a tabletop position.\n5. Engage your core muscles to maintain a neutral spine position.\n6. Keep your back flat and avoid overarching or rounding.\n7. Extend your right arm straight out in front of you.\n8. Parallel to the ground.\n9. Simultaneously extend your left leg straight back behind you.\n10. Parallel to the ground.\n11. Your arm and leg should be fully extended.\n12. Forming a straight line with your body.\n13. From the extended position, simultaneously bend your right elbow and your left knee.\n14. Bring them towards each other under your body.\n15. Aim to touch your right elbow to your left knee underneath your torso.\n16. Or as close as possible without compromising form.\n17. Contract your abdominal muscles as you perform this movement.\n18. Feeling the crunch in your core.\n19. Fully extend your right arm and left leg back out to the starting position.\n20. Returning to the tabletop position.\n21. Repeat the movement on the opposite side."),
        Exercise(1060L, "Tuck Crunch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by lying down with your back on the floor or an exercise mat.\n2. Your arms lying across your sides and palms facing down.\n3. Once in position cross your legs at your ankles.\n4. Slowly elevate your legs up in the air until your thighs are perpendicular to the floor.\n5. Next cross your arms on your chest as if you were doing sit ups.\n6. Perform crunches while maintaining your leg position.\n7. Repeat for as many reps and sets as desired."),
        Exercise(1061L, "Forearm Plank with Hip Abduction", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start off on your hands and toes in a modified push-up position.\n2. Next, place both forearms on the ground.\n3. Extend both legs transitioning to a plank.\n4. Take one of your legs and bring them out to the side of your body (hip abduction).\n5. Keeping it parallel to the floor.\n6. Hold the position for a few seconds.\n7. After feeling tension in your core.\n8. Bring the leg back to the center.\n9. Then return to the starting position.\n10. Repeat this motion with the opposite leg and continue to alternate.\n11. Perform as many reps and sets as desired."),
        Exercise(1062L, "Parallel Bar Hip Flexion", listOf(MuscleGroup.CORE), Equipment.MACHINE, "1. Start by stepping in between parallel bars.\n2. Placing your arms on the rests allowing your legs to hang and extend down below you.\n3. As soon as you are in position.\n4. Bring your knees towards your chest in a diagonal direction.\n5. Holding near the top contracting your abs for a few seconds.\n6. Before returning back to the starting position.\n7. Repeat in the opposite direction for as many reps and sets desired."),
        Exercise(1063L, "Cable Reverse Wood Chop", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by standing with your feet shoulder width apart and your knees slightly bent.\n2. Hold a low pulley cable at about knee level to one side of your body.\n3. Slowly bring the cable up in a diagonal direction.\n4. Raise the cable over your head and shoulders.\n5. Squeeze your oblique muscles.\n6. Return back to the starting position.\n7. Repeat for as many reps and sets as desired."),
        Exercise(1064L, "Medicine Ball Overhead Slam", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder width apart.\n2. Your arms behind your head holding a medicine ball.\n3. Raise the ball above your head fully extending your body and arms.\n4. With your force, slam the ball into the ground in front of you as hard as you can.\n5. Follow through.\n6. With the follow through receive the ball from the bounce up.\n7. Repeat for as many reps and sets as desired."),
        Exercise(1065L, "Downward Facing Dog", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin this position on all fours.\n2. Your hands directly underneath your shoulders.\n3. Push up with your hips towards the ceiling whilst extending your legs back.\n4. Keep a straight line from your arms to through your spine.\n5. And your tailbone down through your legs.\n6. Hold this position for around 5 to 10 breaths.\n7. Return to the starting position and repeat."),
        Exercise(1066L, "Lateral Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by standing up straight with your feet shoulder width apart.\n2. Knees slightly bent.\n3. Placing your right hand on your hip and the other placed behind your head.\n4. Slowly raise the left arm in a vertical line.\n5. Incline your torso to the right.\n6. Feeling a stretch and tension in your abdominals.\n7. Return back to the starting position and repeat for as many reps and sets desired."),
        Exercise(1067L, "Hanging Knee Raise Rotation", listOf(MuscleGroup.CORE), Equipment.OTHER, "1. Start by grabbing onto a hanging grip or pull up bar.\n2. With a comfortable distance between your hands and a strong grip.\n3. Then slowly lift your knees in towards your chest in a diagonal direction.\n4. Rotating your legs from side to side until you feel tension on your lower abs.\n5. Hold this position for a few seconds.\n6. Return back to the starting position and repeat for the desired reps and sets."),
        Exercise(1068L, "Cross-Leg Side Stretch (Supine)", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start off by lying on your back with your arms extended out in the form of a T.\n2. Take both of your legs and bring them up into your chest.\n3. Keeping them at a 90-degree angle.\n4. Then crossing your right leg slowly over the left.\n5. While keeping your shoulder blades in contact with the floor and arms extended out.\n6. Rotate the lower half of your body to the left.\n7. Hold onto this position for 15 to 30 seconds.\n8. Repeating for 2-4 reps and then performing this stretch on your opposite side."),
        Exercise(1069L, "Straight Arm Plank", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in a kneeling position.\n2. Position the hands out in front of the body slightly wider than shoulder width.\n3. At the same time extend the legs out behind you.\n4. Separate the legs slightly.\n5. Hold the position for desired time."),
        Exercise(1070L, "Side Plank Hip Abduction", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by lying on your side on a mat or soft surface.\n2. Align your body so that your elbow is directly beneath your shoulder.\n3. Stack your feet on top of each other.\n4. Lift your hips off the ground.\n5. Creating a straight line from your head to your heels.\n6. Engage your core muscles to maintain stability throughout the exercise.\n7. Place your bottom hand (the one closest to the ground) flat on the mat.\n8. With your fingers spread wide for stability.\n9. Keep your elbow directly under your shoulder to support your upper body.\n10. Lift your top leg (the one not in contact with the ground) upward.\n11. While keeping it straight.\n12. Lift your leg as high as you can comfortably.\n13. Focusing on using the muscles on the side of your hip (abductors) to perform the movement.\n14. Keep your foot flexed and your toes pointing forward throughout the exercise.\n15. Once you reach the top position of the leg lift.\n16. Hold it for a brief moment.\n17. Squeezing your glutes and outer thigh muscles to maximize engagement.\n18. Focus on maintaining stability in your core and not allowing your hips to sag or rotate backward.\n19. Slowly lower your top leg back down to meet your bottom leg.\n20. Returning to the starting position of the side plank.\n21. Keep the movement controlled and avoid letting your leg drop too quickly or bounce off the ground.\n22. Perform the leg lift movement for the desired number of repetitions on one side before switching to the other side."),
        Exercise(1071L, "Seated Bench Leg Pull-In", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Start off with your body sitting at the end of a flat bench.\n2. Your legs stretched out in front of you.\n3. Keep the upper half of your body leaning back.\n4. Take your knees and curl up.\n5. Pulling your thighs toward your chest as you exhale.\n6. Once your knees have hit the chest level.\n7. Squeeze your abs and hold for a few seconds.\n8. Release your contraction and return back to the starting position inhaling down.\n9. Repeat this exercise for as many repetitions as needed."),
        Exercise(1072L, "Cable Crunch Kneeling Rotation", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by connecting a rope attachment to a high pulley cable machine.\n2. Grab the rope with both hands and move into a kneeling position on the floor.\n3. Position the rope behind your head with your hands by your ears.\n4. Contract your abs as you pull downward on the rope in a crunch movement.\n5. Until your elbows touch your knees.\n6. Hold this position for a count and then return back up to the starting position.\n7. Repeat for as many reps and sets as desired."),
        Exercise(1073L, "Plank with Alternating Knee Drive", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in a traditional plank position.\n2. With your forearms on the ground and elbows directly under your shoulders."),
        Exercise(1074L, "Wide Leg Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Take your hands.\n2. Bring them to your hips and let your back lower and bend down towards the ground."),
        Exercise(1075L, "Bench Leg Pull-In", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Begin by lying flat on a bench.\n2. Bring your knees up to your chest while keeping your legs together."),
        Exercise(1076L, "Decline Bench Ab Reach", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Start by sitting on a decline bench.\n2. With your head at the lowest end.\n3. Then place both of your hands together.\n4. And point straight up towards the ceiling."),
        Exercise(1077L, "Decline Bench Rotational Sit-Up", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Start off laying with your back flat on a decline bench.\n2. With your hands above your chest.\n3. And placing your feet underneath the resting pads."),
        Exercise(1078L, "Decline Reverse Crunch", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lie down on the bench with your head positioned at the higher end.\n2. And your feet at the lower end."),
        Exercise(1079L, "Leg Raise with Hip Thrust", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Start by laying with your back flat on a bench.\n2. Head rested upon the one end.\n3. And holding onto the bench below your head to stabilize your body."),
        Exercise(1080L, "Stability Ball Weighted Sit-Up", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start by setting up a bench horizontally or something to rest your feet against in front of an exercise ball.\n2. Then sit down on the ball.\n3. With a weight plate against your chest."),
        Exercise(1081L, "Kettlebell Windmill", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Take the kettlebell and clean press it overhead.\n2. With the kettlebell in place overhead.\n3. Push your glutes into the direction that the kettlebell is located on."),
        Exercise(1082L, "Child's Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin this workout by sitting on your knees.\n2. Keeping them tightly together.\n3. Fold your body over your thighs."),
        Exercise(1083L, "Stability Ball Trunk Rotation", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Take a stability ball and hold it straight out in front of your chest.\n2. Then twist your upper body side to side.\n3. Tightening your abdominals when reaching each side."),
        Exercise(1084L, "Barbell Seated Twist", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Start off with your body sitting at the end of a flat bench.\n2. With a barbell placed on the back of your shoulders behind your neck.\n3. Keep your feet and your head still.\n4. Twist your torso from side to side.\n5. Squeezing your abs tightly."),
        Exercise(1085L, "Alternating Floor Leg Raise", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying with your back flat on the floor.\n2. Arms at your side and feet extended out straight in front of you.\n3. Slowly lift one of your legs up off of the floor.\n4. Keeping the other one still and on the floor.\n5. Until your elevated foot is at a 90-degree angle with the ground."),
        Exercise(1086L, "Cable Seated Rotation (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Begin by sitting down on a stability ball.\n2. Keep your feet about shoulder width apart and maintaining a straight spine.\n3. Next to a cable machine.\n4. Grab a cable with both of your hands.\n5. Then bring your arms out straight in front of you."),
        Exercise(1087L, "Stability Ball Pull-In", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin in a push-up position.\n2. With your hands shoulder-width apart on the floor.\n3. And your shins resting on top of a stability ball.\n4. Your body should form a straight line from head to heels."),
        Exercise(1088L, "Abdominal Hip Roll", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying down on your back flat on the floor.\n2. Keeping your arms straight out and wide to your sides.\n3. And feet extended out in front of you in a T position.\n4. Slowly raise your knees up until they are at thigh level.\n5. And create a 90-degree angle to the floor.\n6. Then begin by twist at your hips.\n7. And lowering your knees towards the floor in a pendulum motion."),
        Exercise(1089L, "Shell Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin on all fours with your knees underneath your hips.\n2. And your arms in line with your shoulders.\n3. Take your head and lower it between your arms.\n4. Then lower your glutes to your heels.\n5. Keeping your hands in front of you on the floor during the entire motion."),
        Exercise(1090L, "Frog Sit-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in a sit-up position on a floor or mat.\n2. Have your legs spread out but connected with the soles touching each other.\n3. Cross your hands on your chest.\n4. Perform a crunch while keeping your feet together."),
        Exercise(1091L, "Boat Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on mat.\n2. Lean back.\n3. Lift legs.\n4. Reach hands forward.\n5. Hold.\n6. Then return."),
        Exercise(1092L, "Bent Knee Hip Raise", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back.\n2. Bend knees.\n3. Raise hips.\n4. Squeeze abs.\n5. Lower to start."),
        Exercise(1093L, "Hanging Pike", listOf(MuscleGroup.CORE), Equipment.OTHER, "1. Hang from bar.\n2. Lift legs to form L-shape.\n3. Hold contraction.\n4. Lower smoothly."),
        Exercise(1094L, "Bent Knee Hundreds", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Raise feet bent.\n2. Curl head/shoulders.\n3. Move arms up/down rapidly.\n4. Return down."),
        Exercise(1095L, "Stability Ball Plank", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Place forearms on ball.\n2. Extend legs back.\n3. Hold body straight out."),
        Exercise(1096L, "Weighted Side Rotation", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Lay with feet supported.\n2. Hold weight.\n3. Twist torso side to side."),
        Exercise(1097L, "Cable One-Arm Side Bend", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Stand side of machine.\n2. Grip cable low.\n3. Pull down with obliques."),
        Exercise(1098L, "Decline Oblique Crunch", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lie on decline bench.\n2. Bring elbow to opposite knee slowly."),
        Exercise(1099L, "Alternating Leg Bridge", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back.\n2. Lift hips.\n3. Alternate legs while maintaining hip height."),
        Exercise(1100L, "Windshield Wipers", listOf(MuscleGroup.CORE), Equipment.OTHER, "1. Hang from bar.\n2. Swing knees left/right while balancing.\n3. Lower slowly."),
        Exercise(1101L, "Alternating Reach and Catch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie flat.\n2. Reach hand to opposite thigh.\n3. Return to starting floor position."),
        Exercise(1102L, "Bench Oblique Crunch", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Rest arm on bench.\n2. Lower pelvis toward floor.\n3. Squeeze.\n4. Return up."),
        Exercise(1103L, "Stability Ball Leg Lift", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie down with ball between feet.\n2. Lift legs and ball upward."),
        Exercise(1104L, "Side Jacknife", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on left side.\n2. Lift left leg.\n3. Bring chest toward leg.\n4. Return slowly."),
        Exercise(1105L, "Overhead Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand straight.\n2. Lace fingers.\n3. Raise arms up.\n4. Stretch torso fully."),
        Exercise(1106L, "Cable Rotational Crunch (Kneeling)", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Kneel.\n2. Grab high pulley rope.\n3. Twist crunching elbow to opposite knee."),
        Exercise(1107L, "Knee to Chest to Leg Raise", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie supine.\n2. Extend legs out.\n3. Touch chest.\n4. Return to extended start."),
        Exercise(1108L, "Crunch with Hands Overhead", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie flat.\n2. Curl body up.\n3. Keep arms straight overhead.\n4. Lower gently."),
        Exercise(1109L, "Ab Roll", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on floor with knees bent and feet planted.\n2. Rock backwards off pelvis.\n3. Keep hands under knees forming C shape.\n4. Keep feet planted throughout.\n5. Squeeze abdominals.\n6. Hold.\n7. Return to start.\n8. Repeat desired reps."),
        Exercise(1110L, "Hundreds", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Back on ground.\n2. Knees bent 45 degrees.\n3. Feet flat.\n4. Arms by sides with slight elbow bend.\n5. Flex upper body forward.\n6. Raise arms off floor at shoulder level.\n7. Move arms up/down controlled.\n8. Repeat desired reps."),
        Exercise(1111L, "Stability Ball Dumbbell Sit-Up", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie with small back on ball.\n2. Dumbbell on chest.\n3. Balance on ball.\n4. Bring abdominals toward spine.\n5. Squeeze abs.\n6. Sit up.\n7. Return to starting position.\n8. Repeat desired reps."),
        Exercise(1112L, "Cable Upward Chop", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Connect cable to low pulley.\n2. Grab with both hands.\n3. Stand shoulder width apart.\n4. Slowly pull handle up.\n5. Extend hips.\n6. Twist torso across body until arms extended overhead.\n7. Hold squeezing abs.\n8. Release.\n9. Repeat."),
        Exercise(1113L, "Bench Plank", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Turn bench sideways.\n2. Place feet in middle.\n3. Extend body forward.\n4. Rest torso on forearms interlaced.\n5. Body straight in plank position.\n6. Hold position.\n7. Release tension.\n8. Repeat desired reps/sets."),
        Exercise(1114L, "Dumbbell Rotational Decline Sit-Up", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Lay back on decline bench with weights above chest.\n2. Feet on pads.\n3. Pull body up with weights.\n4. Bring right arm forward across left knee feeling ab stretch.\n5. Hold.\n6. Return to start.\n7. Repeat desired reps."),
        Exercise(1115L, "Stability Ball Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on back.\n2. Feet on ball.\n3. Hands across chest or head.\n4. Keep small of back on floor.\n5. Raise head.\n6. Shoulders.\n7. Chest off floor.\n8. Pause contracting abs.\n9. Return to starting position.\n10. Repeat desired reps."),
        Exercise(1116L, "Barbell Press Sit-Up", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Lie on decline bench.\n2. Hold barbell at chest.\n3. Do sit-up pushing bar overhead as you rise.\n4. Repeat desired reps."),
        Exercise(1117L, "Decline Bench Leg Raise with Hip Thrust", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lay back on decline bench.\n2. Head on highest end.\n3. Stabilize with pads above head.\n4. Keep feet/knees together.\n5. Point legs straight in plank position.\n6. Pull legs up to ceiling.\n7. Lift hips until feeling ab stretch.\n8. Return to starting position."),
        Exercise(1118L, "Inchworm", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Full-body movement targeting core.\n2. Shoulders.\n3. Hamstrings.\n4. Bend forward.\n5. Place palms forward.\n6. Keep legs straight without locking knees.\n7. Walk hands forward to high plank position.\n8. Hold engaging core.\n9. Walk hands back toward feet.\n10. Stand up to starting position."),
        Exercise(1119L, "Cross Leg Erector Spinae", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie flat on back with one leg straight.\n2. Other bent and crossed over.\n3. Take arm on extended leg side.\n4. Push against crossed leg 15-30 seconds.\n5. Repeat opposite side."),
        Exercise(1120L, "Hip Raise", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Pushup position/bridge position.\n2. Push buttock toward ceiling squeezing abs tightly.\n3. Reach final high bridge position.\n4. Exhale releasing ab tension.\n5. Return slowly inhaling.\n6. Repeat desired reps."),
        Exercise(1121L, "Lying Alternating Knee Raise", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lay back flat.\n2. Arms at sides.\n3. Legs extended straight.\n4. Extend one knee to chest feeling ab stretch.\n5. Return knee to starting position.\n6. Repeat opposite leg.\n7. Repeat desired reps."),
        Exercise(1122L, "Cable Reverse Crunch", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Attach ankle strap to low pulley cable.\n2. Sit in front.\n3. Lie down elevating legs to 90 degrees.\n4. Keep hands behind head.\n5. Bring knees inward toward core feeling ab tension.\n6. Hold.\n7. Slowly return to 90 degree angle.\n8. Repeat desired reps."),
        Exercise(1123L, "Cable Russian Twist (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Connect cable to low pulley.\n2. Lie on stability ball to machine side.\n3. Grab handle.\n4. Extend in front.\n5. Squeeze abs twisting opposite machine direction.\n6. Hold.\n7. Return to start.\n8. Repeat desired reps."),
        Exercise(1124L, "Weighted Decline Rotation", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Lay on decline bench with weight plate across arms.\n2. Feet secured.\n3. Curl up with abs.\n4. Pause at top.\n5. Rotate one direction.\n6. Return center.\n7. Go down.\n8. Repeat opposite direction.\n9. Perform desired reps/sets."),
        Exercise(1125L, "Seated Twist", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit cross-legged.\n2. Ankle under knees.\n3. Place right fingertips forward.\n4. Left fingertips behind.\n5. Press into ground.\n6. Twisting left/right using spine.\n7. Hold up to 10 breaths keeping spine straight and head aligned.\n8. Return to start.\n9. Repeat opposite direction."),
        Exercise(1126L, "Ab Draw Leg Slide", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lay on back.\n2. Knees bent 90 degrees.\n3. Arms at sides palms up.\n4. Maintain slight hand pressure.\n5. Extend legs slowly forward feeling stretch and contraction.\n6. Return to starting position.\n7. Repeat desired reps/sets."),
        Exercise(1127L, "Stability Ball Bridge", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by laying supine (on your back).\n2. With your heels placed upon an exercise ball.\n3. Keeping your arms flat at your sides."),
        Exercise(1128L, "Cable Single-Leg Knee Raise", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by placing a flat bench right in front of a low pulley cable machine.\n2. Attaching ankle straps to the pulley."),
        Exercise(1129L, "Side Plank Crunch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by lying on your side on a mat or soft surface.\n2. Stack your feet on top of each other.\n3. Prop yourself up on your bottom elbow."),
        Exercise(1130L, "Kettlebell Double Windmill", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Take one kettlebell and place it next to your starting foot.\n2. Followed by clean pressing the opposite kettlebell overhead."),
        Exercise(1131L, "Hanging Knee Raise (Rotational)", listOf(MuscleGroup.CORE), Equipment.OTHER, "1. Start by standing underneath a pull up bar.\n2. Pull yourself up off of the ground.\n3. So that you are hanging above the floor."),
        Exercise(1132L, "Leg Slide", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying flat on your back with your arms at your sides.\n2. Lift your legs and bend at the knees.\n3. So that they are in a 90-degree angle."),
        Exercise(1133L, "Medicine Ball Rotation", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. For this exercise you will need a medicine ball as well as a partner.\n2. If you don't have a partner.\n3. Use a brick wall."),
        Exercise(1134L, "Kettlebell Advanced Windmill", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Take the kettlebell and clean press it overhead.\n2. With the kettlebell in place overhead.\n3. Push your glutes into the direction that the kettlebell is located on."),
        Exercise(1135L, "Decline Bench Knee Raise", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Start by laying with your back flat on a decline bench.\n2. Head rested upon the highest end.\n3. Holding onto the pads above your head to stabilize your body."),
        Exercise(1136L, "Cable Rotation (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by placing a stability ball next to a cable machine.\n2. Sitting up straight.\n3. With your feet planted firmly on the floor in front of you."),
        Exercise(1137L, "Single-Leg Stance", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand up straight with both arms at your side.\n2. Then raising up one leg.\n3. With knee slightly bent."),
        Exercise(1138L, "Inchworm Push-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by standing tall with your feet hip-width apart.\n2. Your arms by your sides.\n3. Engage your core muscles to stabilize your torso.\n4. Maintain good posture throughout the exercise."),
        Exercise(1139L, "Dumbbell Seated Side Bend", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start by sitting up straight on a bench.\n2. With a dumbbell in each hand and arms at your sides.\n3. While keeping your back straight and facing forward.\n4. Slowly bend down to one side."),
        Exercise(1140L, "Stability Ball Hand and Foot Exchange", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start by laying on your back.\n2. With your arms and feet extended out.\n3. With an exercise held in between your feet."),
        Exercise(1141L, "Roll Down", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand upright with your feet hip-width apart.\n2. Your hands relaxed at your sides.\n3. Drop your head forward.\n4. Keep your knees slightly bent.\n5. Let your arms hang down vertically."),
        Exercise(1142L, "Cable Judo Flip", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by connecting a rope attachment to a low pulley cable machine.\n2. Standing to the side of the cable.\n3. With a wide stance and rope in both hands."),
        Exercise(1143L, "Barbell Side Bend", listOf(MuscleGroup.CORE), Equipment.BARBELL, "1. Hold the barbell on the back of your shoulders.\n2. As you stand up straight.\n3. While keeping your feet shoulder width apart.\n4. Leave your head up and your back straight."),
        Exercise(1144L, "Janda Sit-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. To begin the exercise.\n2. Start your body off in the basic sit-up position.\n3. Feet flat on the floor.\n4. Arms crossed over your chest."),
        Exercise(1145L, "Sun Salutation", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand tall with feet apart.\n2. Palms together.\n3. Fold forward to floor.\n4. Step back to plank.\n5. Lower chest.\n6. Then curve up into Cobra.\n7. Lift hips into Downward Dog."),
        Exercise(1146L, "Bench Rotational Crunch", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Place bench horizontally.\n2. Back on floor.\n3. Extend arms in T-position.\n4. Lift upper body.\n5. Twisting elbow to knee.\n6. Repeat on opposite side."),
        Exercise(1147L, "Reach and Catch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie back.\n2. Knees bent.\n3. Feet joined.\n4. Interlace fingers forward.\n5. Place hands on thigh.\n6. Then pull hands toward knee.\n7. Lower and switch sides."),
        Exercise(1148L, "Table Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on floor.\n2. Palms grounded behind.\n3. Walk hands away while lifting hips.\n4. Push chest up.\n5. Knees and head horizontal like a table."),
        Exercise(1149L, "Stability Ball Medicine Ball Sit-Up", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Small back on ball.\n2. Feet on floor.\n3. Hold medicine ball up.\n4. Contract abdominals.\n5. Bring torso toward ceiling.\n6. Elevating ball.\n7. Return to start."),
        Exercise(1150L, "Stability Ball Incline Ab Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on ball with lower back.\n2. Legs bent on floor.\n3. Arms crossed.\n4. Pull ribs down toward hips.\n5. Squeezing abs.\n6. Return to start."),
        Exercise(1151L, "Locust Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie face down.\n2. Forehead on floor.\n3. Lift legs with ankles together.\n4. Lift arms.\n5. Head.\n6. Chest.\n7. Reach fingertips toward toes."),
        Exercise(1152L, "Cable Knee Raise (Supine)", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Place bench front of low pulley.\n2. Attach ankle straps.\n3. Lie back.\n4. Feet pointed toward machine.\n5. Pull knees up toward chest."),
        Exercise(1153L, "Stability Ball Hip Rotation", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Sit on ball.\n2. Feet on floor.\n3. Rotate hips counter-clockwise while keeping upper body still.\n4. Repeat in opposite direction."),
        Exercise(1154L, "Stability Ball Oblique Curl", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on ball.\n2. Lower back supported.\n3. Extend arms behind head.\n4. Anchor body with one hand.\n5. Curl up.\n6. Squeezing abdominals."),
        Exercise(1155L, "Cable Rotational Crunch (Supine)", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Attach rope to low pulley.\n2. Lie back.\n3. Head in rope direction.\n4. Legs bent.\n5. Feet shoulder width.\n6. Pull rope above head.\n7. Lift shoulders.\n8. Bringing elbow opposite."),
        Exercise(1156L, "Straight Leg Sit-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lay on floor.\n2. Legs straight.\n3. One on other.\n4. Lift shoulders off floor until abs contract.\n5. Return to start.\n6. Switch feet/arms."),
        Exercise(1157L, "Bench Jackknife Sit-Up", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lie on bench back flat.\n2. Legs hang off one end.\n3. Arms behind.\n4. Raise legs and arms to center.\n5. Touching feet to hands.\n6. Lower controlled."),
        Exercise(1158L, "Stability Ball V-Up", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on mat.\n2. Legs extended toward ceiling.\n3. Arms above head holding ball.\n4. Squeeze abs.\n5. Reach up with arms between legs.\n6. Return to start."),
        Exercise(1159L, "Leg Slide", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie back.\n2. Legs bent.\n3. Squeeze abs.\n4. Straighten one leg until above floor with heel.\n5. Hold.\n6. Feeling lower abs squeeze.\n7. Return to start."),
        Exercise(1160L, "Side Angle Pose With Rotation", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lunge position.\n2. Feet three-feet apart.\n3. Lift arms.\n4. Lunge into lead leg.\n5. Bend to side.\n6. Allowing hand to touch floor.\n7. Hold.\n8. Repeat."),
        Exercise(1161L, "Bow Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie face down.\n2. Arch back.\n3. Keeping shoulder blades back.\n4. Bend legs.\n5. Grab ankles.\n6. Hold for five counts.\n7. Return to start."),
        Exercise(1162L, "Cable Lying Crunch", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Place rope to low pulley.\n2. Lay down near pulley.\n3. Knees bent.\n4. Grab rope.\n5. Pull to head.\n6. Contract abs.\n7. Reach toward knees.\n8. Return to start."),
        Exercise(1163L, "Warrior 2 Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by laterally stepping with your left leg until both legs are about 3 feet apart.\n2. Lunge into the right leg to about 90-degree angle.\n3. Extend both arms horizontal along shoulder line.\n4. Hold 5-15 seconds.\n5. Return to start.\n6. Alternate sides and repeat."),
        Exercise(1164L, "Stability Ball Roman Twist", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lay on ball with middle-upper back on ball.\n2. Slowly rotate upper body while keeping arms extended.\n3. Hold tension.\n4. Return to start."),
        Exercise(1165L, "Leg Slide (Supine)", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back.\n2. Feet elevated 90 degrees.\n3. Slide legs forward to feel tension in lower abdominals.\n4. Return to start and repeat."),
        Exercise(1166L, "Crow Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin squat with feet close together.\n2. Place hands shoulder-width apart on floor.\n3. Lean forward transferring weight to palms.\n4. Lift with ab muscles and arch hips."),
        Exercise(1167L, "Double Leg Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back with knees bent at 45 degrees.\n2. Raise both knees to 90 degrees over glutes.\n3. Flex upper body forward.\n4. Return to center with deep breath."),
        Exercise(1168L, "Medicine Ball Two-Arm Overhead Throw", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Lay on ground.\n2. Knees bent.\n3. Hold ball behind head.\n4. Sit up forcefully.\n5. Throw ball forward.\n6. Catch or bounce ball off wall."),
        Exercise(1169L, "Rolling", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit with spine flexed in C shape.\n2. Roll back while keeping knees locked.\n3. Roll back up staying balanced."),
        Exercise(1170L, "Double Leg Hundreds", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back.\n2. Legs up toward ceiling.\n3. Curl chest to pelvis.\n4. Move arms up and down rapidly in controlled motion."),
        Exercise(1171L, "Single-Leg Reverse Hyper (Flat Bench)", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lay face down on bench.\n2. Toes touching floor.\n3. Pull one leg up toward upper body.\n4. Hold.\n5. Return to start."),
        Exercise(1172L, "Warrior Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Step laterally with left leg.\n2. Lunge into right leg.\n3. Keep left leg straight.\n4. Raise arms overhead.\n5. Hold 5-10 breaths.\n6. Switch sides."),
        Exercise(1173L, "Camel Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on knees without glutes on heels.\n2. Place hands on upper hamstrings.\n3. Arch back.\n4. Press hips forward.\n5. Hold up to 5 breaths."),
        Exercise(1174L, "Alternating Reverse Hyper (Flat Bench)", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lay face down.\n2. One foot on floor.\n3. Other raised.\n4. Lift raised leg until tension felt.\n5. Alternate legs."),
        Exercise(1175L, "Band Sit-Up", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Wrap bands around bench base.\n2. Lay back flat holding bands.\n3. Curl up keeping chest close to abdominals.\n4. Squeeze abs.\n5. Return to start."),
        Exercise(1176L, "Decline Bench Cable Crunch", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Place decline bench facing low pulley.\n2. Hold rope by side of head.\n3. Use abs to pull body up and crunch.\n4. Return slowly."),
        Exercise(1177L, "Hero Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Kneel with knees close.\n2. Feet wide.\n3. Place hands on soles of feet.\n4. Lift from pubic bone toward ceiling.\n5. Hold.\n6. Return to start."),
        Exercise(1178L, "Medicine Ball Decline Two-Arm Overhead Throw", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Lay on decline bench.\n2. Feet in rests.\n3. Hold ball behind head.\n4. Sit up forcefully.\n5. Throw ball forward.\n6. Catch or have partner return ball."),
        Exercise(1179L, "Cross-Legged Forward Fold", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Position cross-legged with shins horizontal.\n2. Place fingertips in front of legs.\n3. Extend hands.\n4. Chest down to ground.\n5. Hold up to 10 seconds."),
        Exercise(1180L, "Downward Facing Puppy Dog", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Kneel with legs shoulder-width apart.\n2. Lower head toward floor.\n3. Keep knees under hips.\n4. Raise buttocks high.\n5. Relax and extend back.\n6. Hold 5-10 breaths."),
        Exercise(1181L, "Stability Ball Jack Knife Push-Up", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start prone on ball.\n2. Bring knees to chest.\n3. Hold.\n4. Then push up."),
        Exercise(1182L, "Kneeling Side Bend", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Balance on knees.\n2. Side bend to hand.\n3. Lift opposite arm overhead."),
        Exercise(1183L, "Walking Inchworm Push-Up", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Walk hands forward into plank.\n2. Perform push-up.\n3. Reverse to stand."),
        Exercise(1184L, "Standing Opposition Reach", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand straight.\n2. Extend leg back while reaching opposite arm forward."),
        Exercise(1185L, "Alternating Arm Cobra", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Prone position.\n2. Lift chest.\n3. Alternate arms touching floor."),
        Exercise(1186L, "Decline Bench Alternating Leg Raise", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lie on decline bench.\n2. Extend legs.\n3. Lift one leg at a time."),
        Exercise(1187L, "Crescent Moon Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Kneel forward.\n2. Step opposite leg forward.\n3. Arch back and lift."),
        Exercise(1188L, "Z Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Kneel on mat.\n2. Stretch arms forward.\n3. Lean back forming Z shape."),
        Exercise(1189L, "Stability Ball Side Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie sideways on ball.\n2. Curl torso toward side.\n3. Repeat on opposite side."),
        Exercise(1190L, "Kettlebell Bent Press", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Clean to shoulder.\n2. Lean body opposite.\n3. Press bell overhead."),
        Exercise(1191L, "One-Knee to Chest (Supine)", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back.\n2. Lift hips.\n3. Bring one knee to chest.\n4. Alternate."),
        Exercise(1192L, "Stability Ball Plank with Hip Abduction", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Plank on forearms.\n2. Move leg out to side.\n3. Hold.\n4. Switch legs."),
        Exercise(1193L, "Medicine Ball Throw (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Sit on ball.\n2. Walk feet forward.\n3. Lift abs and throw ball forward."),
        Exercise(1194L, "Bent Knee Side Angle Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Lie on back.\n2. Lift pelvis.\n3. Move chest toward chin.\n4. Hug knees."),
        Exercise(1195L, "Fish Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit with legs straight.\n2. Lean back on forearms.\n3. Arch chest."),
        Exercise(1196L, "Eagle Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand.\n2. Wrap one leg around opposite.\n3. Cross arms.\n4. Lift elbows."),
        Exercise(1197L, "Stability Ball Hip Roll", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on back.\n2. Legs on ball.\n3. Roll side to side using abs."),
        Exercise(1198L, "Decline Bench Alternating Knee Raise", listOf(MuscleGroup.CORE), Equipment.BENCH, "1. Lie on decline bench.\n2. Point legs.\n3. Pull one knee to chest."),
        Exercise(1199L, "Stability Ball Extended Arm Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lying with the center of your back on the top of an exercise ball.\n2. And arms extended."),
        Exercise(1200L, "Downward Facing Dog Single-Leg", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start off on all fours with your hands placed shoulder width apart."),
        Exercise(1201L, "Triangle Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand up straight and keep your spine erect."),
        Exercise(1202L, "Stability Ball Head Tilt", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Sitting on either an exercise ball or bench.\n2. Keeping your spine straight."),
        Exercise(1203L, "Mighty Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Stand with your feet shoulder width apart.\n2. Big toes and inner thighs together."),
        Exercise(1204L, "Stability Ball Single-Leg Hip Rotation", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Rolling onto an exercise ball so that you are in a pushup position."),
        Exercise(1205L, "Stability Ball Wood Chop", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Hold an exercise ball in your hands above your head to one side of your body."),
        Exercise(1206L, "Stability Ball Roll Down", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Sitting on the floor with your knees bent.\n2. And feet planted firmly on the floor."),
        Exercise(1207L, "Staff Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sitting on the floor with your legs straight out in front of you.\n2. With your back erect."),
        Exercise(1208L, "Stability Ball Side Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lay on an exercise ball with the small of your back rested upon the top of the ball."),
        Exercise(1209L, "Stability Ball Weight Plate Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lying one side of your torso.\n2. Waist and hip against an exercise ball."),
        Exercise(1210L, "Stability Ball Ab Curl", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Place an exercise ball right above your abdominals with your hands on the ball."),
        Exercise(1211L, "Warrior 3 Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in the Warrior 1 pose with your right leg in front of your left."),
        Exercise(1212L, "Standing Half Moon", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start in a straight standing position.\n2. With both of your feet together and spine aligned."),
        Exercise(1213L, "Stability Ball Walking Lunge", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Stand straight up.\n2. Feet shoulder width apart.\n3. And holding an exercise ball in front of you."),
        Exercise(1214L, "Hare Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on your knees keeping them close together."),
        Exercise(1215L, "Stability Ball Stork Stance", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Standing up straight with both arms at your side.\n2. Then raising up one leg.\n3. With knee slightly bent."),
        Exercise(1216L, "Seated Overhead Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by sitting up straight on a mat.\n2. In a butterfly position."),
        Exercise(1217L, "Sage Twist 1", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by sitting on the floor.\n2. And bringing your legs around to the left.\n3. Tucking your right foot underneath your left ankle.\n4. Take your right hand and bring it behind you to the floor.\n5. Keeping your knees facing forward.\n6. And holding onto them with your right arm.\n7. Then if possible.\n8. Take your left hand and slide it underneath your knee.\n9. And catch hold of the left arm with your right hand.\n10. Looking back over your shoulder.\n11. Hold this position for 5 to 10 breaths.\n12. Return to the starting position.\n13. Repeat with the opposite side."),
        Exercise(1218L, "Revolved Abdomen Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by laying on your back.\n2. With your arms out to the sides keeping your hands at shoulder level.\n3. Take your legs and bring them up in the air whilst lifting your hips and buttocks up and to the left.\n4. Extending your heels outward.\n5. Take your right leg and aim it out towards your fingertips at the side.\n6. Follow this movement slowly by lowering your left leg down to join the right.\n7. Try and hold onto both of your feet with your right hand.\n8. Anchor your body to the floor with your left arm and shoulder.\n9. Turn your head in the direction of your left hand.\n10. And repeat this pose for a few reps.\n11. Lifting your left leg and up down towards the right.\n12. And holding at full position."),
        Exercise(1219L, "Stability Ball Straight-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start off by laying on your back flat on the floor.\n2. Placing your feet on top of an exercise ball with your legs straightened out.\n3. Place your arms straight at your sides.\n4. And contracting on your abdominals.\n5. While squeezing lift your shoulder blades off of the floor.\n6. And reach your arms out towards your feet.\n7. Pausing at the top and hold this position for a few seconds.\n8. Return back to the starting position.\n9. Repeat for as many reps and sets as desired."),
        Exercise(1220L, "Passive Opening Twist", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying on your chest.\n2. With your arms and legs apart in a star form.\n3. Keeping your right hand and arm attached to the floor.\n4. Move your left arm up and over your left hip.\n5. Allow both of your knees to bend slightly.\n6. And roll over onto the sides of your feet.\n7. Turn your head to look behind you.\n8. As you lay your left arm right next to the side of your head.\n9. Hold this position for 1 to 2 minutes.\n10. And then return back to the starting position.\n11. Repeat with the opposite side."),
        Exercise(1221L, "Child's Pose (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by kneeling on the floor in front of a stability ball.\n2. Placing your hands on the ball with your arms extended straight.\n3. Roll down forward slowly.\n4. So that your head is even with your arms.\n5. And hold this stretch for 15 to 30 seconds.\n6. Return back to the starting position.\n7. Repeat this pose."),
        Exercise(1222L, "Decline Bench Cable Knee Raise", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by placing a decline bench in front of a low pulley cable machine.\n2. Positioning the lowest end closest to the cable.\n3. Connect an ankle strap to the low pulley cable.\n4. And wrap it around your ankles.\n5. Lay down with your back flat on the bench.\n6. With your head up towards the highest end.\n7. And grab onto the pads with your hands for support.\n8. Slowly pull up with your knees.\n9. So that they go as high as possible.\n10. And you feel a stretch in your abs.\n11. Hold for a count then return back to the starting position.\n12. Repeat for as many reps and sets as desired."),
        Exercise(1223L, "Stability Ball Single-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by lying on an exercise ball.\n2. With the small of your back.\n3. Crossing your arms across your chest.\n4. And slowly lifting one leg off of the floor.\n5. As soon as you find your balance.\n6. Curl your torso up.\n7. And draw in your belly button towards your spine.\n8. Squeeze with your abdominals.\n9. And then slowly return back to the starting position.\n10. Repeating for as many reps and sets as possible."),
        Exercise(1224L, "Dumbbell Alternating Cobra (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start off by lying in a prone position.\n2. With a stability ball underneath your sternum.\n3. Keeping your legs straight behind you.\n4. And your arms at your sides.\n5. Squeeze with your glutes.\n6. Keep your feet straight.\n7. And lift your torso off of the ball in an elevated position.\n8. Extend your right arm backwards.\n9. While keeping the left arm in place.\n10. Return the right arm to the starting position.\n11. While the left arm extends backwards.\n12. Alternate arms for as many reps and sets as desired."),
        Exercise(1225L, "Stability Ball Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on an exercise ball with the small of your back rested upon the top of the ball."),
        Exercise(1226L, "Stability Ball Weight Plate Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lying one side of your torso.\n2. Waist and hip against an exercise ball."),
        Exercise(1227L, "Stability Ball Ab Curl", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Place an exercise ball right above your abdominals with your hands on the ball."),
        Exercise(1228L, "Warrior 3 Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in the Warrior 1 pose with your right leg in front of your left."),
        Exercise(1229L, "Standing Half Moon", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start in a straight standing position.\n2. With both of your feet together and spine aligned."),
        Exercise(1230L, "Stability Ball Walking Lunge", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Stand straight up.\n2. Feet shoulder width apart.\n3. And holding an exercise ball in front of you."),
        Exercise(1231L, "Hare Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on your knees keeping them close together."),
        Exercise(1232L, "Stability Ball Stork Stance", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Standing up straight with both arms at your side.\n2. Then raising up one leg.\n3. With knee slightly bent."),
        Exercise(1233L, "Seated Overhead Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by sitting up straight on a mat.\n2. In a butterfly position."),
        Exercise(1234L, "Sage Twist 1", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by sitting on the floor.\n2. And bringing your legs around to the left.\n3. Tucking your right foot underneath your left ankle.\n4. Take your right hand and bring it behind you to the floor.\n5. Keeping your knees facing forward.\n6. And holding onto them with your right arm.\n7. Then if possible.\n8. Take your left hand and slide it underneath your knee.\n9. And catch hold of the left arm with your right hand.\n10. Looking back over your shoulder.\n11. Hold this position for 5 to 10 breaths.\n12. Return to the starting position.\n13. Repeat with the opposite side."),
        Exercise(1235L, "Revolved Abdomen Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by laying on your back.\n2. With your arms out to the sides keeping your hands at shoulder level.\n3. Take your legs and bring them up in the air whilst lifting your hips and buttocks up and to the left.\n4. Extending your heels outward.\n5. Take your right leg and aim it out towards your fingertips at the side.\n6. Follow this movement slowly by lowering your left leg down to join the right.\n7. Try and hold onto both of your feet with your right hand.\n8. Anchor your body to the floor with your left arm and shoulder.\n9. Turn your head in the direction of your left hand.\n10. And repeat this pose for a few reps.\n11. Lifting your left leg and up down towards the right.\n12. And holding at full position."),
        Exercise(1236L, "Stability Ball Straight-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start off by laying on your back flat on the floor.\n2. Placing your feet on top of an exercise ball with your legs straightened out.\n3. Place your arms straight at your sides.\n4. And contracting on your abdominals.\n5. While squeezing lift your shoulder blades off of the floor.\n6. And reach your arms out towards your feet.\n7. Pausing at the top and hold this position for a few seconds.\n8. Return back to the starting position.\n9. Repeat for as many reps and sets as desired."),
        Exercise(1237L, "Passive Opening Twist", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying on your chest.\n2. With your arms and legs apart in a star form.\n3. Keeping your right hand and arm attached to the floor.\n4. Move your left arm up and over your left hip.\n5. Allow both of your knees to bend slightly.\n6. And roll over onto the sides of your feet.\n7. Turn your head to look behind you.\n8. As you lay your left arm right next to the side of your head.\n9. Hold this position for 1 to 2 minutes.\n10. And then return back to the starting position.\n11. Repeat with the opposite side."),
        Exercise(1238L, "Child's Pose (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by kneeling on the floor in front of a stability ball.\n2. Placing your hands on the ball with your arms extended straight.\n3. Roll down forward slowly.\n4. So that your head is even with your arms.\n5. And hold this stretch for 15 to 30 seconds.\n6. Return back to the starting position.\n7. Repeat this pose."),
        Exercise(1239L, "Decline Bench Cable Knee Raise", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by placing a decline bench in front of a low pulley cable machine.\n2. Positioning the lowest end closest to the cable.\n3. Connect an ankle strap to the low pulley cable.\n4. And wrap it around your ankles.\n5. Lay down with your back flat on the bench.\n6. With your head up towards the highest end.\n7. And grab onto the pads with your hands for support.\n8. Slowly pull up with your knees.\n9. So that they go as high as possible.\n10. And you feel a stretch in your abs.\n11. Hold for a count then return back to the starting position.\n12. Repeat for as many reps and sets as desired."),
        Exercise(1240L, "Stability Ball Single-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by lying on an exercise ball.\n2. With the small of your back.\n3. Crossing your arms across your chest.\n4. And slowly lifting one leg off of the floor.\n5. As soon as you find your balance.\n6. Curl your torso up.\n7. And draw in your belly button towards your spine.\n8. Squeeze with your abdominals.\n9. And then slowly return back to the starting position.\n10. Repeating for as many reps and sets as possible."),
        Exercise(1241L, "Dumbbell Alternating Cobra (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start off by lying in a prone position.\n2. With a stability ball underneath your sternum.\n3. Keeping your legs straight behind you.\n4. And your arms at your sides.\n5. Squeeze with your glutes.\n6. Keep your feet straight.\n7. And lift your torso off of the ball in an elevated position.\n8. Extend your right arm backwards.\n9. While keeping the left arm in place.\n10. Return the right arm to the starting position.\n11. While the left arm extends backwards.\n12. Alternate arms for as many reps and sets as desired."),
        Exercise(1242L, "Stability Ball Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on an exercise ball with the small of your back rested upon the top of the ball."),
        Exercise(1243L, "Stability Ball Weight Plate Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lying one side of your torso.\n2. Waist and hip against an exercise ball."),
        Exercise(1244L, "Stability Ball Ab Curl", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Place an exercise ball right above your abdominals with your hands on the ball."),
        Exercise(1245L, "Warrior 3 Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in the Warrior 1 pose with your right leg in front of your left."),
        Exercise(1246L, "Standing Half Moon", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start in a straight standing position.\n2. With both of your feet together and spine aligned."),
        Exercise(1247L, "Stability Ball Walking Lunge", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Stand straight up.\n2. Feet shoulder width apart.\n3. And holding an exercise ball in front of you."),
        Exercise(1248L, "Hare Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on your knees keeping them close together."),
        Exercise(1249L, "Stability Ball Stork Stance", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Standing up straight with both arms at your side.\n2. Then raising up one leg.\n3. With knee slightly bent."),
        Exercise(1250L, "Seated Overhead Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by sitting up straight on a mat.\n2. In a butterfly position."),
        Exercise(1251L, "Sage Twist 1", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by sitting on the floor.\n2. Bring your legs around to the left.\n3. Tuck your right foot underneath your left ankle.\n4. Take your right hand and bring it behind you to the floor.\n5. Keep your knees facing forward.\n6. Hold onto them with your right arm.\n7. Take your left hand and slide it underneath your knee.\n8. Catch hold of the left arm with your right hand.\n9. Looking back over your shoulder.\n10. Hold this position for 5 to 10 breaths.\n11. Return to the starting position.\n12. Repeat with the opposite side."),
        Exercise(1252L, "Revolved Abdomen Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by laying on your back with your arms out to the sides keeping your hands at shoulder level.\n2. Take your legs and bring them up in the air whilst lifting your hips and buttocks up and to the left.\n3. Extending your heels outward.\n4. Take your right leg and aim it out towards your fingertips at the side.\n5. Follow this movement slowly by lowering your left leg down to join the right.\n6. Try and hold onto both of your feet with your right hand.\n7. Anchor your body to the floor with your left arm and shoulder.\n8. Turn your head in the direction of your left hand.\n9. Repeat this pose for a few reps.\n10. Lifting your left leg and up down towards the right.\n11. Holding at full position."),
        Exercise(1253L, "Stability Ball Straight-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start off by laying on your back flat on the floor.\n2. Placing your feet on top of an exercise ball with your legs straightened out.\n3. Place your arms straight at your sides.\n4. Contracting on your abdominals.\n5. While squeezing lift your shoulder blades off of the floor.\n6. Reach your arms out towards your feet.\n7. Pausing at the top and hold this position for a few seconds.\n8. Return back to the starting position.\n9. Repeat for as many reps and sets as desired."),
        Exercise(1254L, "Passive Opening Twist", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying on your chest with your arms and legs apart in a star form.\n2. Keeping your right hand and arm attached to the floor.\n3. Move your left arm up and over your left hip.\n4. Allow both of your knees to bend slightly.\n5. Roll over onto the sides of your feet.\n6. Turn your head to look behind you.\n7. Lay your left arm right next to the side of your head.\n8. Hold this position for 1 to 2 minutes.\n9. Return back to the starting position.\n10. Repeat with the opposite side."),
        Exercise(1255L, "Child's Pose (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by kneeling on the floor in front of a stability ball.\n2. Placing your hands on the ball with your arms extended straight.\n3. Roll down forward slowly so that your head is even with your arms.\n4. Hold this stretch for 15 to 30 seconds.\n5. Return back to the starting position.\n6. Repeat this pose."),
        Exercise(1256L, "Decline Bench Cable Knee Raise", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by placing a decline bench in front of a low pulley cable machine.\n2. Positioning the lowest end closest to the cable.\n3. Connect an ankle strap to the low pulley cable.\n4. Wrap it around your ankles.\n5. Lay down with your back flat on the bench.\n6. With your head up towards the highest end.\n7. Grab onto the pads with your hands for support.\n8. Slowly pull up with your knees so that they go as high as possible.\n9. Feel a stretch in your abs.\n10. Hold for a count then return back to the starting position.\n11. Repeat for as many reps and sets as desired."),
        Exercise(1257L, "Stability Ball Single-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by lying on an exercise ball with the small of your back.\n2. Crossing your arms across your chest.\n3. Slowly lifting one leg off of the floor.\n4. As soon as you find your balance.\n5. Curl your torso up and draw in your belly button towards your spine.\n6. Squeeze with your abdominals.\n7. Slowly return back to the starting position.\n8. Repeating for as many reps and sets as possible."),
        Exercise(1258L, "Dumbbell Alternating Cobra (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start off by lying in a prone position with a stability ball underneath your sternum.\n2. Keeping your legs straight behind you and your arms at your sides.\n3. Squeeze with your glutes and keep your feet straight.\n4. Lift your torso off of the ball in an elevated position.\n5. Extend your right arm backwards while keeping the left arm in place.\n6. Return the right arm to the starting position while the left arm extends backwards.\n7. Alternate arms for as many reps and sets as desired."),
        Exercise(1259L, "Stability Ball Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on an exercise ball with the small of your back rested upon the top of the ball."),
        Exercise(1260L, "Stability Ball Weight Plate Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lying one side of your torso.\n2. Waist and hip against an exercise ball."),
        Exercise(1261L, "Stability Ball Ab Curl", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Place an exercise ball right above your abdominals with your hands on the ball."),
        Exercise(1262L, "Warrior 3 Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in the Warrior 1 pose with your right leg in front of your left."),
        Exercise(1263L, "Standing Half Moon", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start in a straight standing position with both of your feet together and spine aligned."),
        Exercise(1264L, "Stability Ball Walking Lunge", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Stand straight up.\n2. Feet shoulder width apart.\n3. And holding an exercise ball in front of you."),
        Exercise(1265L, "Hare Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on your knees keeping them close together."),
        Exercise(1266L, "Stability Ball Stork Stance", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Standing up straight with both arms at your side then raising up one leg with knee slightly bent."),
        Exercise(1267L, "Seated Overhead Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by sitting up straight on a mat in a butterfly position."),
        Exercise(1268L, "Sage Twist 1", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by sitting on the floor and bringing your legs around to the left.\n2. Tucking your right foot underneath your left ankle.\n3. Take your right hand and bring it behind you to the floor.\n4. Keeping your knees facing forward and holding onto them with your right arm.\n5. Take your left hand and slide it underneath your knee.\n6. Catch hold of the left arm with your right hand.\n7. Looking back over your shoulder.\n8. Hold this position for 5 to 10 breaths and return to the starting position.\n9. Repeat with the opposite side."),
        Exercise(1269L, "Revolved Abdomen Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by laying on your back with your arms out to the sides keeping your hands at shoulder level.\n2. Take your legs and bring them up in the air whilst lifting your hips and buttocks up and to the left.\n3. Extending your heels outward.\n4. Take your right leg and aim it out towards your fingertips at the side.\n5. Follow this movement slowly by lowering your left leg down to join the right.\n6. Try and hold onto both of your feet with your right hand.\n7. Anchor your body to the floor with your left arm and shoulder.\n8. Turn your head in the direction of your left hand and repeat this pose for a few reps.\n9. Lifting your left leg and up down towards the right and holding at full position."),
        Exercise(1270L, "Stability Ball Straight-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start off by laying on your back flat on the floor.\n2. Placing your feet on top of an exercise ball with your legs straightened out.\n3. Place your arms straight at your sides and contracting on your abdominals.\n4. While squeezing lift your shoulder blades off of the floor and reach your arms out towards your feet.\n5. Pausing at the top and hold this position for a few seconds.\n6. Return back to the starting position.\n7. Repeat for as many reps and sets as desired."),
        Exercise(1271L, "Passive Opening Twist", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying on your chest with your arms and legs apart in a star form.\n2. Keeping your right hand and arm attached to the floor.\n3. Move your left arm up and over your left hip.\n4. Allow both of your knees to bend slightly and roll over onto the sides of your feet.\n5. Turn your head to look behind you as you lay your left arm right next to the side of your head.\n6. Hold this position for 1 to 2 minutes.\n7. Return back to the starting position.\n8. Repeat with the opposite side."),
        Exercise(1272L, "Child's Pose (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by kneeling on the floor in front of a stability ball.\n2. Placing your hands on the ball with your arms extended straight.\n3. Roll down forward slowly so that your head is even with your arms.\n4. Hold this stretch for 15 to 30 seconds.\n5. Return back to the starting position.\n6. Repeat this pose."),
        Exercise(1273L, "Decline Bench Cable Knee Raise", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by placing a decline bench in front of a low pulley cable machine.\n2. Positioning the lowest end closest to the cable.\n3. Connect an ankle strap to the low pulley cable and wrap it around your ankles.\n4. Lay down with your back flat on the bench with your head up towards the highest end.\n5. Grab onto the pads with your hands for support.\n6. Slowly pull up with your knees so that they go as high as possible.\n7. Feel a stretch in your abs.\n8. Hold for a count then return back to the starting position.\n9. Repeat for as many reps and sets as desired."),
        Exercise(1274L, "Stability Ball Single-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by lying on an exercise ball with the small of your back.\n2. Crossing your arms across your chest.\n3. Slowly lifting one leg off of the floor.\n4. As soon as you find your balance.\n5. Curl your torso up and draw in your belly button towards your spine.\n6. Squeeze with your abdominals.\n7. Slowly return back to the starting position.\n8. Repeating for as many reps and sets as possible."),
        Exercise(1275L, "Dumbbell Alternating Cobra (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start off by lying in a prone position with a stability ball underneath your sternum.\n2. Keeping your legs straight behind you and your arms at your sides.\n3. Squeeze with your glutes and keep your feet straight.\n4. Lift your torso off of the ball in an elevated position.\n5. Extend your right arm backwards while keeping the left arm in place.\n6. Return the right arm to the starting position while the left arm extends backwards.\n7. Alternate arms for as many reps and sets as desired."),
        Exercise(1276L, "Stability Ball Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on an exercise ball with the small of your back rested upon the top of the ball."),
        Exercise(1277L, "Stability Ball Weight Plate Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lying one side of your torso.\n2. Waist and hip against an exercise ball."),
        Exercise(1278L, "Stability Ball Ab Curl", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Place an exercise ball right above your abdominals with your hands on the ball."),
        Exercise(1279L, "Warrior 3 Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in the Warrior 1 pose with your right leg in front of your left."),
        Exercise(1280L, "Standing Half Moon", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start in a straight standing position with both of your feet together and spine aligned."),
        Exercise(1281L, "Stability Ball Walking Lunge", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Stand straight up.\n2. Feet shoulder width apart.\n3. And holding an exercise ball in front of you."),
        Exercise(1282L, "Hare Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on your knees keeping them close together."),
        Exercise(1283L, "Stability Ball Stork Stance", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Standing up straight with both arms at your side then raising up one leg with knee slightly bent."),
        Exercise(1284L, "Seated Overhead Stretch", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by sitting up straight on a mat in a butterfly position."),
        Exercise(1285L, "Sage Twist 1", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by sitting on the floor and bringing your legs around to the left.\n2. Tucking your right foot underneath your left ankle.\n3. Take your right hand and bring it behind you to the floor.\n4. Keeping your knees facing forward and holding onto them with your right arm.\n5. Take your left hand and slide it underneath your knee.\n6. Catch hold of the left arm with your right hand.\n7. Looking back over your shoulder.\n8. Hold this position for 5 to 10 breaths and return to the starting position.\n9. Repeat with the opposite side."),
        Exercise(1286L, "Revolved Abdomen Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin by laying on your back with your arms out to the sides keeping your hands at shoulder level.\n2. Take your legs and bring them up in the air whilst lifting your hips and buttocks up and to the left.\n3. Extending your heels outward.\n4. Take your right leg and aim it out towards your fingertips at the side.\n5. Follow this movement slowly by lowering your left leg down to join the right.\n6. Try and hold onto both of your feet with your right hand.\n7. Anchor your body to the floor with your left arm and shoulder.\n8. Turn your head in the direction of your left hand and repeat this pose for a few reps.\n9. Lifting your left leg and up down towards the right and holding at full position."),
        Exercise(1287L, "Stability Ball Straight-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Start off by laying on your back flat on the floor.\n2. Placing your feet on top of an exercise ball with your legs straightened out.\n3. Place your arms straight at your sides and contracting on your abdominals.\n4. While squeezing lift your shoulder blades off of the floor and reach your arms out towards your feet.\n5. Pausing at the top and hold this position for a few seconds.\n6. Return back to the starting position.\n7. Repeat for as many reps and sets as desired."),
        Exercise(1288L, "Passive Opening Twist", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start by laying on your chest with your arms and legs apart in a star form.\n2. Keeping your right hand and arm attached to the floor.\n3. Move your left arm up and over your left hip.\n4. Allow both of your knees to bend slightly and roll over onto the sides of your feet.\n5. Turn your head to look behind you as you lay your left arm right next to the side of your head.\n6. Hold this position for 1 to 2 minutes.\n7. Return back to the starting position.\n8. Repeat with the opposite side."),
        Exercise(1289L, "Child's Pose (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by kneeling on the floor in front of a stability ball.\n2. Placing your hands on the ball with your arms extended straight.\n3. Roll down forward slowly so that your head is even with your arms.\n4. Hold this stretch for 15 to 30 seconds.\n5. Return back to the starting position.\n6. Repeat this pose."),
        Exercise(1290L, "Decline Bench Cable Knee Raise", listOf(MuscleGroup.CORE), Equipment.CABLE, "1. Start by placing a decline bench in front of a low pulley cable machine.\n2. Positioning the lowest end closest to the cable.\n3. Connect an ankle strap to the low pulley cable and wrap it around your ankles.\n4. Lay down with your back flat on the bench with your head up towards the highest end.\n5. Grab onto the pads with your hands for support.\n6. Slowly pull up with your knees so that they go as high as possible.\n7. Feel a stretch in your abs.\n8. Hold for a count then return back to the starting position.\n9. Repeat for as many reps and sets as desired."),
        Exercise(1291L, "Stability Ball Single-Leg Crunch", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Begin by lying on an exercise ball with the small of your back.\n2. Crossing your arms across your chest.\n3. Slowly lifting one leg off of the floor.\n4. As soon as you find your balance.\n5. Curl your torso up and draw in your belly button towards your spine.\n6. Squeeze with your abdominals.\n7. Slowly return back to the starting position.\n8. Repeating for as many reps and sets as possible."),
        Exercise(1292L, "Dumbbell Alternating Cobra (Stability Ball)", listOf(MuscleGroup.CORE), Equipment.DUMBBELL, "1. Start off by lying in a prone position with a stability ball underneath your sternum.\n2. Keeping your legs straight behind you and your arms at your sides.\n3. Squeeze with your glutes and keep your feet straight.\n4. Lift your torso off of the ball in an elevated position.\n5. Extend your right arm backwards while keeping the left arm in place.\n6. Return the right arm to the starting position while the left arm extends backwards.\n7. Alternate arms for as many reps and sets as desired."),
        Exercise(1293L, "Stability Ball Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lie on an exercise ball with the small of your back rested upon the top of the ball."),
        Exercise(1294L, "Stability Ball Weight Plate Side Bend", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Lying one side of your torso.\n2. Waist and hip against an exercise ball."),
        Exercise(1295L, "Stability Ball Ab Curl", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Place an exercise ball right above your abdominals with your hands on the ball."),
        Exercise(1296L, "Warrior 3 Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Begin in the Warrior 1 pose with your right leg in front of your left."),
        Exercise(1297L, "Standing Half Moon", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Start in a straight standing position with both of your feet together and spine aligned."),
        Exercise(1298L, "Stability Ball Walking Lunge", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Stand straight up.\n2. Feet shoulder width apart.\n3. And holding an exercise ball in front of you."),
        Exercise(1299L, "Hare Pose", listOf(MuscleGroup.CORE), Equipment.BODYWEIGHT, "1. Sit on your knees keeping them close together."),
        Exercise(1300L, "Stability Ball Stork Stance", listOf(MuscleGroup.CORE), Equipment.EXERCISEBALL, "1. Standing up straight with both arms at your side then raising up one leg with knee slightly bent."),
        Exercise(2002L, "Cable Seated Row", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Set Up the Machine: Attach the desired handle to the cable row machine. Adjust the seat and chest pad if available so that you can reach the handle comfortably without overextending.\n2. Starting Position: Sit down on the machine with your feet securely placed on the footrests. Your knees should be slightly bent.\n3. Grasp the handle with both hands, using an overhand or neutral grip (palms facing each other).\n4. Sit with a straight back and slight lean forward from the hips, keeping your chest up and core engaged.\n5. Executing the Row: Pull the handle towards your torso, leading with your elbows. Your elbows should stay close to your body.\n6. As you pull, squeeze your shoulder blades together and keep your back straight.\n7. End Position: Pull the handle until it reaches your torso, typically around the lower chest or upper abdomen.\n8. Hold this position for a brief moment to maximize the contraction in your back muscles.\n9. Slowly extend your arms and return the handle to the starting position, maintaining control of the weight throughout the movement."),
        Exercise(2003L, "Dumbbell One-Arm Row", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Start by kneeling over the side of a bench placing the knee and hand of the supporting arm on the bench and then position the opposite foot on the floor.\n2. Grab a dumbbell from the floor opposite of the side supporting the body and pull the dumbbell up slowly to your chest, feeling a stretch in your back until it almost makes contact with your chest.\n3. Hold this position for a count, then return slowly back to the starting position.\n4. Repeat for as many reps and sets as desired and switch with the opposite arms."),
        Exercise(2004L, "Cable Rope Face Pull", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start by facing a high pulley cable machine with either a rope or dual handles connected to the machine.\n2. Grab onto the handles and pull the weight directly towards your face, using your shoulders, and separating your shoulders as you pull the weights back.\n3. Hold for a count then return back to the starting position."),
        Exercise(2005L, "Pull-Up", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Grab the bar with an overhand grip.\n2. Lift your self up till your chin is above the bar.\n3. Pause for a few seconds.\n4. Lower yourself down slowly.\n5. Repeat for the desired amount of reps."),
        Exercise(2006L, "Barbell Deadlift", listOf(MuscleGroup.BACK, MuscleGroup.LEGS), Equipment.BARBELL, "1. Start by standing in front of a barbell with your feet shoulder-width apart.\n2. Bend at your hips and knees to lower your body and grasp the bar with an overhand or mixed grip.\n3. Keep your back flat and chest up as you drive through your heels to stand up, lifting the bar with you.\n4. Keep the bar close to your body throughout the movement.\n5. At the top, stand tall with your shoulders back.\n6. Slowly lower the bar back to the ground by hinging at your hips and bending your knees."),

        // CARDIO
        Exercise(4001L, "Walking", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4002L, "Running", listOf(MuscleGroup.CARDIO), Equipment.BODYWEIGHT, "No detailed instructions available"),
        Exercise(4003L, "Treadmill Running", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4004L, "Elliptical Training", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4005L, "Road Cycling", listOf(MuscleGroup.CARDIO), Equipment.OTHER, "No detailed instructions available"),
        Exercise(4006L, "Step Machine", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4007L, "Stationary Bike", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4008L, "Rowing", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4009L, "Indoor Cycling", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4010L, "Recumbent Bike", listOf(MuscleGroup.CARDIO), Equipment.MACHINE, "No detailed instructions available"),
        Exercise(4011L, "Jump Rope", listOf(MuscleGroup.CARDIO), Equipment.OTHER, "No detailed instructions available"),
        Exercise(4012L, "Yoga", listOf(MuscleGroup.CARDIO), Equipment.BODYWEIGHT, "No detailed instructions available"),
        Exercise(4013L, "Swimming", listOf(MuscleGroup.CARDIO), Equipment.BODYWEIGHT, "No detailed instructions available"),
        Exercise(4014L, "Jumping Jacks", listOf(MuscleGroup.CARDIO), Equipment.BODYWEIGHT, "Begin in a standing position with your feet together and your arms at your sides. Jump up explosively while simultaneously spreading your legs out to the sides. At the same time, raise your arms above your head until your hands meet. Repeat: Continue this motion, jumping in and out while raising and lowering your arms."),
        Exercise(4015L, "Field Sports", listOf(MuscleGroup.CARDIO), Equipment.OTHER, "No detailed instructions available"),
        Exercise(4016L, "Burpee", listOf(MuscleGroup.CARDIO), Equipment.BODYWEIGHT, "Begin in a standing position. Stand in athletic posture with feet hip to shoulder width apart and toes pointing forward. Squat down driving the hips back as far as possible. Place hands on floor, kick feet out to push-up position. Perform push up. Jump feet back underneath, transition to squat jump. Jump explosively. Land with knees following toes and neutral spine."),
        Exercise(4017L, "Aerobics", listOf(MuscleGroup.CARDIO), Equipment.OTHER, "No detailed instructions available"),
        Exercise(4018L, "Boxing", listOf(MuscleGroup.CARDIO), Equipment.OTHER, "No detailed instructions available"),
        Exercise(4019L, "Mountain Biking", listOf(MuscleGroup.CARDIO), Equipment.OTHER, "Mountain biking is a sport that consists of riding outdoors, mostly off-road courses and over rough terrain. It requires stamina, core strength, endurance, balance, coordination and handling skills."),
        Exercise(4020L, "Pilates", listOf(MuscleGroup.CARDIO), Equipment.BODYWEIGHT, "Pilates are an exercise that focus upon developing strength through the core of the body as well as increasing flexibility and coordination."),
        Exercise(4021L, "Inline Skating", listOf(MuscleGroup.CARDIO), Equipment.OTHER, "Inline skating is a sport that helps tone your body, build a strong core and muscles, burn calories, increases endurance and stamina as well as improve coordination and balance."),

        // CHEST (continued from exercise_final_chest.md)
        Exercise(5006L, "Barbell Bench Press", listOf(MuscleGroup.CHEST), Equipment.BARBELL, "1. Load the barbell with an appropriate amount of weight.\n2. Lie down on the flat bench with your feet flat on the ground and your head, shoulders, and buttocks firmly pressed against the bench.\n3. Grip the barbell with both hands slightly wider than shoulder-width apart.\n4. Lower the barbell slowly to your mid-chest.\n5. Press the barbell back up to the starting position by fully extending your arms."),
        Exercise(5007L, "Dumbbell Incline Bench Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Adjust the bench to an incline position (30-45 degrees).\n2. Sit on the bench with a dumbbell in each hand resting on your thighs.\n3. Lie back on the bench with dumbbells at the sides of your chest.\n4. Push the dumbbells up toward the ceiling by extending your elbows.\n5. Slowly lower the dumbbells back to the starting position with controlled movement."),
        Exercise(5008L, "Machine Fly", listOf(MuscleGroup.CHEST), Equipment.MACHINE, "1. Adjust the seat height so that the handles are at chest level.\n2. Sit on the machine with your back flat against the backrest.\n3. Grasp the handles with an overhand grip.\n4. Bring the handles together in front of your chest in a wide arc, keeping your elbows slightly bent.\n5. Briefly pause at the peak contraction."),
        Exercise(5009L, "Dumbbell Bench Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Sit on the edge of the bench with a dumbbell in each hand.\n2. Lie back on the bench.\n3. Position the dumbbells to the sides of your chest with palms facing forward.\n4. Press the dumbbells upward by extending your arms.\n5. Lower the dumbbells slowly back to the starting position."),
        Exercise(5010L, "Barbell Incline Bench Press", listOf(MuscleGroup.CHEST), Equipment.BARBELL, "1. Set an adjustable bench to an incline angle of about 30 to 45 degrees.\n2. Lie back on the incline bench with your feet flat on the floor.\n3. Grip the barbell with your hands slightly wider than shoulder-width apart.\n4. Lower the barbell slowly to your upper chest.\n5. Press the barbell back up to the starting position."),
        Exercise(5011L, "Machine Bench Press", listOf(MuscleGroup.CHEST), Equipment.MACHINE, "1. Adjust a bench press machine so that when you sit at the machine, the bars are positioned at chest height.\n2. Place your hands upon the bars and place your feet flat on the foot rests.\n3. Press out by extending your arms out as far as possible.\n4. Return back to the start."),
        Exercise(5012L, "Dumbbell Fly", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Lie back on a flat bench with your feet flat on the floor.\n2. Hold a dumbbell in each hand with a neutral grip.\n3. Extend your arms above your chest with a slight bend in your elbows.\n4. Lower the dumbbells in a wide arc out to the sides.\n5. Reverse the motion and bring the dumbbells back up."),
        Exercise(5013L, "Push-Up", listOf(MuscleGroup.CHEST), Equipment.BODYWEIGHT, "1. Place your hands on the ground, slightly wider than shoulder-width apart.\n2. Extend your legs straight behind you.\n3. Tighten your core muscles.\n4. Inhale as you bend your elbows and lower your body toward the ground.\n5. Exhale as you push through your palms to straighten your arms."),
        Exercise(5014L, "Cable Cross-Over", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set the pulleys to the highest position on the cable crossover machine.\n2. Stand in the center with feet shoulder-width apart.\n3. Pull the handles down and across your body in a wide arc, bringing your hands together in front of you.\n4. Squeeze your chest muscles as your hands meet."),
        Exercise(5015L, "Machine Incline Chest Press", listOf(MuscleGroup.CHEST), Equipment.MACHINE, "1. Adjust the seat of the bench so that the handles are aligned with the upper portion of your chest.\n2. Slowly press the handles forward until your hands are fully extended.\n3. Hold this position for a count.\n4. Return back to the starting position."),
        Exercise(5016L, "Dumbbell Incline Fly", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Start by lying on an incline bench set to 45-degrees.\n2. Lift the dumbbells up and over your chest.\n3. While keeping a slight bend in your elbows, slowly bring the dumbbells towards each other in an arc motion.\n4. Return back to the starting position."),
        Exercise(5017L, "Cable Lower Chest Raise", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Start by setting up handles on a low pulley cable machine.\n2. Stand in between the machines.\n3. Slowly bring the handles together in front of your body at about waist level.\n4. Hold for a count.\n5. Return back to the starting position."),
        Exercise(5018L, "Smith Machine Incline Bench Press", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Start by placing an incline bench at a 45-degree angle.\n2. Lie down with your back flat on the bench.\n3. Grab onto the bar with a shoulder-width grip.\n4. Slowly lower it down towards your chest.\n5. Hold this position for a count then return back up to the start."),
        Exercise(5019L, "Cable Mid Chest Crossover", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set up two handles on two high cable pulley machine and stand in between.\n2. Slowly bring the handles down towards your sides.\n3. Bring the handles in together towards the front of your body, squeezing your chest.\n4. Return the handles back to the starting position."),
        Exercise(5020L, "Machine Inner Chest Press", listOf(MuscleGroup.CHEST), Equipment.MACHINE, "1. Sit on a chest press machine with your feet flat in front of you.\n2. Hold the handles with a neutral hammer grip.\n3. Once in position, slowly push out the handles using your arms but squeezing with your chest.\n4. Return back to the starting position."),
        Exercise(5021L, "Leverage Incline Chest Press", listOf(MuscleGroup.CHEST), Equipment.MACHINE, "1. Load the necessary amount of weight onto the leverage machine.\n2. Keep your head and chest up, press the handles forward extending through your elbows.\n3. Hold for a count.\n4. Return back to the starting position."),
        Exercise(5022L, "Smith Machine Bench Press", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Place a flat bench in the middle of a smith machine.\n2. Lie down with your back flat on the bench.\n3. Unlatch the bar, then slowly lower it down towards your chest.\n4. Hold this position for a count.\n5. Return back up to the start."),
        Exercise(5023L, "Barbell Decline Bench Press", listOf(MuscleGroup.CHEST), Equipment.BARBELL, "1. Load the barbell with an appropriate amount of weight.\n2. Adjust the decline bench to a suitable angle.\n3. Lie down on the decline bench with your feet securely hooked under the foot pads.\n4. Grip the barbell with your hands slightly wider than shoulder-width apart.\n5. Lower the barbell slowly to your lower chest.\n6. Press the barbell back up to the starting position."),
        Exercise(5024L, "Leverage Decline Chest Press", listOf(MuscleGroup.CHEST), Equipment.LEVERAGE, "1. Start by loading the necessary amount of weight onto the leverage machine.\n2. Adjust seat for handles beneath pecs.\n3. Press forward extending elbows.\n4. Return to start."),
        Exercise(5025L, "Leverage Chest Press", listOf(MuscleGroup.CHEST), Equipment.LEVERAGE, "1. Keep your head and chest up.\n2. Press the handles forward extending elbows until tension felt.\n3. Hold then return.\n4. Repeat for desired reps and sets."),
        Exercise(5026L, "Cable Incline Fly", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Adjust pulleys low.\n2. Place incline bench 30-45 degrees.\n3. Sit with feet flat.\n4. Grip handles overhand.\n5. Lower handles in arc feeling stretch.\n6. Squeeze chest returning."),
        Exercise(5027L, "Dumbbell Decline Bench Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Adjust bench decline 15-30 degrees.\n2. Sit feet under pads.\n3. Hold dumbbells neutral grip.\n4. Lie back.\n5. Press dumbbells up straightening arms.\n6. Pause and lower back."),
        Exercise(5028L, "Dumbbell Deep Push-Up", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Push-up position with dumbbells in hands.\n2. Arms shoulder width.\n3. Lower body towards floor feeling stretch.\n4. Return to start.\n5. Repeat reps."),
        Exercise(5029L, "Cable Straight Arm Crossover", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Start by setting up two handles on a two high cable pulley machine.\n2. Stand gripping handles above body.\n3. Bring handles down together squeezing chest.\n4. Return start."),
        Exercise(5030L, "Bench Push-Up", listOf(MuscleGroup.CHEST), Equipment.BENCH, "1. Get into push-up position with hands on a bench behind you.\n2. Lower your body towards the bench while keeping your arms straight.\n3. Push back up by extending your arms.\n4. Keep your core engaged throughout the movement."),
        Exercise(5031L, "Dumbbell Bench Press (Palms In)", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Sit on the edge of a flat bench with a dumbbell in each hand.\n2. Lie back with dumbbells at your sides.\n3. Position your palms facing each other (inward rotation).\n4. Press the dumbbells upward by extending your arms.\n5. Lower slowly back to starting position."),
        Exercise(5032L, "Cable Upper Chest Crossover", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set the cable machine pulleys to the highest position.\n2. Stand centered with hands holding the handles at upper chest level.\n3. Pull handles downward and inward in a wide arc.\n4. Focus on the upper chest portion.\n5. Squeeze chest at peak contraction."),
        Exercise(5033L, "Dumbbell Incline Bench Press (Hammer Grip)", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Adjust the bench to an incline position (30-45 degrees).\n2. Hold dumbbells with a neutral (hammer) grip.\n3. Lie back on the bench with dumbbells at the sides of your chest.\n4. Push the dumbbells up by extending your arms.\n5. Lower slowly and controlled."),
        Exercise(5034L, "Dumbbell Around the World", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Lie on a flat bench holding a dumbbell in one hand.\n2. Lift the dumbbell vertically.\n3. Rotate it in a circular motion, going under your body and up to the ceiling.\n4. Perform the rotation with controlled movement."),
        Exercise(5035L, "Dumbbell Decline Fly", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Set up on a decline bench.\n2. Lie back with dumbbells at your sides.\n3. Bring dumbbells together in a wide arc in front of your chest.\n4. Squeeze chest muscles.\n5. Return to starting position with control."),
        Exercise(5036L, "Barbell Bench Press (Wide Grip)", listOf(MuscleGroup.CHEST), Equipment.BARBELL, "1. Load the barbell with weight.\n2. Lie down on the flat bench with feet firmly on the ground.\n3. Grip the barbell with hands wider than shoulder-width.\n4. Lower the barbell to your mid-chest.\n5. Press the barbell back up to the starting position."),
        Exercise(5037L, "Cable Incline Press", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Adjust pulleys to low position.\n2. Set incline bench to 30-45 degrees.\n3. Sit on the bench with feet flat.\n4. Grip handles at upper chest level.\n5. Press handles forward in an arc.\n6. Return slowly to starting position."),
        Exercise(5038L, "Cable Flat Bench Fly", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set pulleys to middle position.\n2. Lie on a flat bench.\n3. Grip handles at chest level.\n4. Bring handles together in front of your body in a wide arc.\n5. Squeeze chest.\n6. Return to start with control."),
        Exercise(5039L, "Smith Machine Decline Bench Press", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Set up a decline bench with Smith Machine.\n2. Lie back with feet secured.\n3. Grip the bar with shoulder-width grip.\n4. Lower the bar towards your lower chest.\n5. Press back up along the bar path."),
        Exercise(5040L, "Dumbbell Incline Bench Press (Palms in)", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Set up on incline bench.\n2. Hold dumbbells with palms facing inward.\n3. Lie back with dumbbells at sides.\n4. Press dumbbells up by extending arms.\n5. Lower slowly with control."),
        Exercise(5041L, "Cable Decline Chest Fly", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set up cable machine for decline position.\n2. Lie on decline bench.\n3. Grip handles.\n4. Bring handles together in arc in front of chest.\n5. Squeeze chest.\n6. Return to start."),
        Exercise(5042L, "Dumbbell One-Arm Bench Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Lie on a flat bench.\n2. Hold one dumbbell against your chest at your side.\n3. Press the dumbbell up by extending your arm.\n4. Lower with control.\n5. Repeat on same or opposite side."),
        Exercise(5043L, "Dumbbell Bench Press (Reverse Grip)", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Sit on bench with dumbbells in hands.\n2. Lie back with dumbbells at sides.\n3. Rotate wrists so palms face you.\n4. Press dumbbells up by extending arms.\n5. Lower slowly back to starting position."),
        Exercise(5044L, "Cable Rope Pullover (Supine)", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Lie on a flat bench supine.\n2. Attach rope attachment to high pulley.\n3. Grasp rope with hands.\n4. Pull rope over your chest keeping elbows slightly bent.\n5. Squeeze chest.\n6. Return to starting position."),
        Exercise(5045L, "Dumbbell Decline Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Set up on decline bench.\n2. Lie back with dumbbells at sides.\n3. Press dumbbells up by extending arms.\n4. Pause at top.\n5. Lower back with control."),
        Exercise(5046L, "Dumbbell Incline Fly With A Twist", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Lie on incline bench holding dumbbells.\n2. Lift dumbbells up and slightly outward with a twisting motion.\n3. Bring dumbbells together in front of chest.\n4. Return to starting position with control."),
        Exercise(5047L, "Kettlebell Alternating Floor Press", listOf(MuscleGroup.CHEST), Equipment.KETTLEBELL, "1. Sit on the floor holding a kettlebell in one hand.\n2. Lie back keeping shoulders on the floor.\n3. Press the kettlebell up by extending your arm.\n4. Lower with control.\n5. Repeat on alternating sides."),
        Exercise(5048L, "Kettlebell Push-Up", listOf(MuscleGroup.CHEST), Equipment.KETTLEBELL, "1. Hold a kettlebell with both hands.\n2. Place it on the floor in push-up position.\n3. Perform push-ups normally.\n4. For variation, hold kettlebell with one hand in push-up position."),
        Exercise(5049L, "Dumbbell One-Arm Incline Chest Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Set up on incline bench.\n2. Hold one dumbbell against your chest.\n3. Press dumbbell up by extending arm while keeping elbow tucked.\n4. Lower with control.\n5. Repeat on same or opposite side."),
        Exercise(5050L, "Smith Machine Bench Press (Wide Grip)", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Set up Smith Machine with a flat bench.\n2. Lie back with back against the bench.\n3. Unlatch the bar.\n4. Grip the bar wider than shoulder-width.\n5. Lower to mid-chest.\n6. Press back up along the bar path."),
        Exercise(5051L, "Stability Ball Pike Push-Up", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Place stability ball at feet.\n2. Kneel behind it and grip it with hands.\n3. Extend hips up into pike position.\n4. Lower chest towards the ball.\n5. Push back up by extending arms.\n6. Focus on upper chest engagement."),
        Exercise(5052L, "Cable Decline Press", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set up cable machine for decline position.\n2. Lie on decline bench.\n3. Hold handles at chest level.\n4. Press handles forward.\n5. Squeeze chest.\n6. Return to starting position with control."),
        Exercise(5053L, "Barbell Reverse Bench Press (Wide Grip)", listOf(MuscleGroup.CHEST), Equipment.BARBELL, "1. Lie on flat bench with barbell across your chest (reverse grip).\n2. Press barbell up by extending arms.\n3. Lower slowly to chest.\n4. Focus on chest contraction.\n5. Keep core engaged."),
        Exercise(5054L, "Dumbbell Fly (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbells.\n2. Lean forward slightly with arms extended.\n3. Lower dumbbells in wide arc out to sides.\n4. Bring dumbbells back together in front.\n5. Keep slight bend in elbows throughout."),
        Exercise(5055L, "Kettlebell One-Arm Floor Press", listOf(MuscleGroup.CHEST), Equipment.KETTLEBELL, "1. Lie on floor holding kettlebell in one hand.\n2. Press kettlebell up by extending arm.\n3. Lower with control.\n4. Keep shoulder blades pressed into floor.\n5. Focus on chest activation."),
        Exercise(5056L, "Smith Machine Incline Bench Press (Reverse Grip)", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Set up Smith Machine with incline bench.\n2. Lie back with back against bench.\n3. Unlatch bar.\n4. Grip bar with reverse grip (palms down).\n5. Lower to upper chest.\n6. Press back up along bar path."),
        Exercise(5057L, "Cable Decline One-Arm Chest Fly", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set up cable machine for decline position.\n2. Lie on decline bench holding one handle.\n3. Pull handle across body in wide arc.\n4. Squeeze chest.\n5. Return to starting position."),
        Exercise(5058L, "Barbell One-Arm Floor Press", listOf(MuscleGroup.CHEST), Equipment.BARBELL, "1. Lie on floor holding barbell in one hand.\n2. Press barbell up by extending arm.\n3. Lower with control.\n4. Keep elbow close to body.\n5. Focus on chest and triceps."),
        Exercise(5059L, "Dumbbell One-Arm Pullover (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbell.\n2. Lean back with dumbbell extended overhead.\n3. Lower dumbbell back in arc over head.\n4. Pull dumbbell back over chest.\n5. Keep slight bend in elbow."),
        Exercise(5060L, "Smith Machine Bench Press (Reverse Grip)", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Set up Smith Machine with flat bench.\n2. Lie back with back against bench.\n3. Unlatch bar.\n4. Grip bar with reverse grip (palms down).\n5. Lower to lower chest.\n6. Press back up along bar path."),
        Exercise(5061L, "Smith Machine Decline Bench Press (Wide Grip)", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Set up decline bench with Smith Machine.\n2. Lie back with feet secured.\n3. Grip bar wider than shoulder-width.\n4. Lower to lower chest.\n5. Press back up along bar path."),
        Exercise(5062L, "Cable Decline One-Arm Chest Fly", listOf(MuscleGroup.CHEST), Equipment.CABLE, "1. Set up cable machine for decline position.\n2. Lie on decline bench.\n3. Grip one handle at chest level.\n4. Pull handle up and across body in wide arc.\n5. Squeeze chest.\n6. Return to start."),
        Exercise(5063L, "Dumbbell Incline One-Arm Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Set up on incline bench.\n2. Hold one dumbbell against chest.\n3. Press dumbbell up by extending arm while keeping elbow tucked.\n4. Lower with control.\n5. Repeat on same or opposite side."),
        Exercise(5064L, "Kettlebell One-Arm Floor Press", listOf(MuscleGroup.CHEST), Equipment.KETTLEBELL, "1. Lie on floor with kettlebell in one hand.\n2. Press kettlebell up by extending arm.\n3. Lower with control.\n4. Keep shoulder blades pressed into floor.\n5. Focus on chest activation."),
        Exercise(5065L, "Kettlebell Floor Press", listOf(MuscleGroup.CHEST), Equipment.KETTLEBELL, "1. Lie on floor holding kettlebell with both hands.\n2. Press kettlebell up by extending arms.\n3. Lower with control.\n4. Keep elbows close to body.\n5. Focus on chest engagement."),
        Exercise(5066L, "Dumbbell Incline Press on Stability Ball", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball on incline bench setup.\n2. Hold dumbbells at chest level.\n3. Press dumbbells up by extending arms.\n4. Lower with control.\n5. Keep slight bend in elbows."),
        Exercise(5067L, "Barbell Neck Press", listOf(MuscleGroup.CHEST), Equipment.BARBELL, "1. Lie on flat bench with barbell resting on forehead/neck area.\n2. Press barbell up by extending arms.\n3. Lower slowly back to starting position.\n4. Use caution with weight selection."),
        Exercise(5068L, "Dumbbell Incline One Arm Hammer Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Set up on incline bench.\n2. Hold dumbbell with neutral (hammer) grip.\n3. Press dumbbell up by extending arm.\n4. Lower with control.\n5. Repeat on same or opposite side."),
        Exercise(5069L, "Dumbbell Decline One-Arm Hammer Press", listOf(MuscleGroup.CHEST), Equipment.DUMBBELL, "1. Set up on decline bench.\n2. Hold dumbbell with neutral grip.\n3. Press dumbbell up by extending arm.\n4. Lower with control.\n5. Repeat on alternating sides."),
        Exercise(5070L, "Cable One-Arm Incline Fly (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball with incline setup.\n2. Hold cable handle at chest level.\n3. Pull handle down and across body in wide arc.\n4. Squeeze chest.\n5. Return to start."),
        Exercise(5071L, "Dumbbell Incline Fly (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball on incline setup.\n2. Hold dumbbells at chest level.\n3. Lower dumbbells in wide arc out to sides.\n4. Bring dumbbells back together.\n5. Keep slight bend in elbows."),
        Exercise(5072L, "Smith Machine Decline Bench Press (Reverse Grip)", listOf(MuscleGroup.CHEST), Equipment.SMITH, "1. Set up Smith Machine with decline bench.\n2. Lie back with feet secured.\n3. Grip bar with reverse grip.\n4. Lower to lower chest.\n5. Press back up along bar path."),
        Exercise(5073L, "Dumbbell One-Arm Hammer Press (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbell.\n2. Hold dumbbell with hammer grip.\n3. Press dumbbell up by extending arm.\n4. Lower with control.\n5. Repeat on alternating sides."),
        Exercise(5074L, "Stability Ball Narrow Push-Up", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Place hands on stability ball in push-up position.\n2. Feet on ground.\n3. Lower body towards ball.\n4. Push back up by extending arms.\n5. Keep core tight throughout movement."),
        Exercise(5075L, "Cable One-Arm Press (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding cable handle.\n2. Hold dumbbell with hammer grip.\n3. Press dumbbell up by extending arm.\n4. Lower with control.\n5. Repeat on alternating sides."),
        Exercise(5076L, "Dumbbell One-Arm Fly (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding one dumbbell.\n2. Extend arm overhead.\n3. Lower dumbbell in arc out to side.\n4. Bring dumbbell back over head.\n5. Keep slight bend in elbow."),
        Exercise(5077L, "Cable One-Arm Incline Press (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball with incline setup.\n2. Hold cable handle at chest level.\n3. Press handle forward in arc.\n4. Squeeze chest.\n5. Return to start."),
        Exercise(5078L, "Dumbbell Incline One-Arm Fly on Stability Ball", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbell with one hand.\n2. Lie back.\n3. Lower dumbbell in arc out to side.\n4. Bring dumbbell back together.\n5. Keep slight bend in elbow."),
        Exercise(5079L, "Cable Incline Press (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball with incline setup.\n2. Hold cable handles.\n3. Press handles forward in arc.\n4. Squeeze chest.\n5. Return to start."),
        Exercise(5080L, "Dumbbell One-Arm Press (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbell.\n2. Lie back.\n3. Press dumbbell up by extending arm.\n4. Lower with control.\n5. Repeat on alternating sides."),
        Exercise(5081L, "Medicine Ball Chest Push to Run", listOf(MuscleGroup.CHEST), Equipment.MEDICINE_BALL, "1. Hold medicine ball at chest level.\n2. Press ball forward.\n3. Immediately run forward to catch the ball.\n4. Repeat alternating pressing and running movements."),
        Exercise(5082L, "Dumbbell Incline One-Arm Hammer Press (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbell with hammer grip.\n2. Press dumbbell up by extending arm.\n3. Lower with control.\n4. Repeat on alternating sides."),
        Exercise(5083L, "Dumbbell Single-Leg Fly (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbells.\n2. Hold one leg up for balance.\n3. Perform dumbbell fly.\n4. Focus on chest and stability."),
        Exercise(5084L, "Dumbbell Incline One-Arm Press (Stability Ball)", listOf(MuscleGroup.CHEST), Equipment.STABILITY_BALL, "1. Sit on stability ball holding dumbbell.\n2. Lie back.\n3. Press dumbbell up by extending arm.\n4. Lower with control.\n5. Repeat on alternating sides."),
        Exercise(5085L, "Medicine Ball Chest Push from Stance", listOf(MuscleGroup.CHEST), Equipment.MEDICINE_BALL, "1. Stand with medicine ball at chest level.\n2. Press ball forward explosively.\n3. Use legs and core to stabilize.\n4. Catch ball and return to starting position.\n5. Repeat."),

        // SHOULDERS
        Exercise(8100L, "Dumbbell Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart.\n2. Keep a slight bend in your knees for balance.\n3. Hold a dumbbell in each hand: Your arms should hang down by your sides with your palms facing your body.\n4. Raise your arms out to the sides until they are at shoulder height.\n5. Lower the dumbbells slowly."),
        Exercise(8101L, "Dumbbell Seated Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Sit on the bench with your back firmly against the backrest.\n2. Position the Dumbbells: Lift the dumbbells to shoulder height.\n3. Press the Dumbbells Upward: Exhale as you press the dumbbells upward until your arms are fully extended.\n4. Lower the Dumbbells: Inhale as you slowly lower the dumbbells back to the starting position."),
        Exercise(8102L, "Machine Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Sit on the seat with your back firmly against the backrest.\n2. Press the Handles Upward: Exhale as you press the handles upward.\n3. Lower the Handles: Inhale as you slowly lower the handles back to the starting position."),
        Exercise(8103L, "Machine Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Start by adjusting the handles on a fly machine.\n2. Pull your arms out to your sides and as far back as possible, contracting your rear deltoids.\n3. Return back to the starting position."),
        Exercise(8104L, "Cable Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Attach a single handle to the low pulley of a cable machine.\n2. Stand with your side facing the cable machine.\n3. Raise your arm across your body and out to the side until it is level with the ground."),
        Exercise(8105L, "Barbell Military Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Take a weighted barbell and have it pressed up against your chest with your palms facing outward.\n2. Lift it above your head with locked arms.\n3. Return back to the starting position."),
        Exercise(8106L, "Dumbbell Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off standing up straight with your feet shoulder width apart and your arms rested at your sides, holding dumbbells in each hand.\n2. Raise the dumbbells to head level so that your arms are creating a 90 degree angle.\n3. Slowly push the dumbbells up, by extending through the elbows, over your head."),
        Exercise(8107L, "Barbell Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Stand with your feet shoulder-width apart.\n2. Unrack the barbell by pushing up with your legs and stepping back from the rack.\n3. Press the barbell upward in a straight line until your arms are fully extended above your head.\n4. Slowly lower the barbell back to the starting position at shoulder height."),
        Exercise(8108L, "Dumbbell Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off standing up straight holding dumbbells in each hand resting at your pelvis.\n2. Lift the dumbbells up and out so that they are extended in front of your shoulders, at your shoulder level."),
        Exercise(8109L, "Dumbbell Seated Arnold Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Begin with your arms bent, palms facing your body, and the dumbbells at shoulder level.\n2. Start the movement by pressing the dumbbells overhead.\n3. Fully extend your arms overhead, but don't lock your elbows.\n4. Slowly reverse the movement by lowering the dumbbells back to the starting position."),
        Exercise(8110L, "Barbell Upright Row", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Bend at your hips and knees to grip the barbell with an overhand grip.\n2. Lift the barbell to a standing position with your arms extended.\n3. Lift the barbell by driving your elbows up and to the sides, keeping the bar close to your body.\n4. Continue to lift until the barbell reaches your upper chest or just below your chin."),
        Exercise(8111L, "Dumbbell Seated Side Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. With a dumbbell in each hand sit on a workout bench and keep your feet on the ground.\n2. Have your arms at your side and hold the dumbbells with palms facing inward.\n3. Lift each dumbbell straight out as if you are going to fly."),
        Exercise(8112L, "Dumbbell Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off lying face down on an incline bench with a dumbbell in each hand rested on the floor in front of you.\n2. Then raise your arms so that they are parallel with your shoulders."),
        Exercise(8113L, "Machine Deltoid Raise", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Sit on a deltoid raise machine with your feet flat on the floor.\n2. Slowly elevate your arms up towards the ceiling, feeling a stretch in your shoulder blades."),
        Exercise(8114L, "Dumbbell Bent-Over Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder-width apart and holding a dumbbell in each hand at your side.\n2. Bend down so that your body is parallel with the floor.\n3. Slowly extend your arms up and out so that the weights are at level with your head and squeeze your shoulders."),
        Exercise(8115L, "Cable Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Start by setting up handles on two low pulley cable machines.\n2. Bend down so that your back is parallel with the ground.\n3. Slowly extend your arms out, squeezing your shoulders so that your arms at head level."),
        Exercise(8116L, "Smith Machine Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.SMITH, "1. Place an incline bench underneath a smith machine and align the barbell at a height that you are able to reach the bar.\n2. Grab onto the barbell and lift the bar off from the rack.\n3. Push the barbell back to the starting position by squeezing your shoulders."),
        Exercise(8117L, "Cable Upright Row", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Attach the straight bar or rope attachment to the low pulley of the cable machine.\n2. Stand facing the cable machine with your feet shoulder-width apart.\n3. Pull the bar straight up towards your chin, leading with your elbows.\n4. End Position: Lift the bar until your elbows are at or just above shoulder height."),
        Exercise(8118L, "Dumbbell One-Arm Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart, holding a dumbbell in one hand with arm hanging down and palm facing thigh.\n2. Maintain straight back and engage core.\n3. Lift arm straight in front until parallel to floor at shoulder height.\n4. Pause briefly, then lower in controlled manner."),
        Exercise(8119L, "Cable One-Arm Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Set up handle on low pulley, stand to side.\n2. Bring arm to waist level and slowly elevate up and out in semi-circle motion.\n3. Hold for count, return to starting position."),
        Exercise(8120L, "Cable External Rotation", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Place extension band around post at elbow level.\n2. Position to side of band and grab handle with opposite arm.\n3. Bring band to chest with elbow at 90 degrees.\n4. Rotate arm in backhand motion externally.\n5. Hold, return to start."),
        Exercise(8121L, "Dumbbell Upright Row", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand feet shoulder-width apart holding dumbbells with overhand grip, arms extended at thighs.\n2. Engage core and lift elbows up and out, keeping dumbbells close to body until chest level.\n3. Pause, then slowly lower."),
        Exercise(8122L, "Cable One-Arm Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Set up low cable pulley with attachment.\n2. Stand feet shoulder-width apart.\n3. Bend knees, keep back parallel to floor.\n4. Elevate arm up and out until head level.\n5. Hold and return."),
        Exercise(8123L, "Barbell Military Press (Seated)", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Sit upright gripping barbell overhand with elbows down and chest high.\n2. Push bar straight up until arms fully extended.\n3. Return behind neck. Repeat."),
        Exercise(8124L, "Dumbbell Seated Bent-Over Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Sit on bench with feet together.\n2. Rest chest on thighs with dumbbells underneath legs.\n3. Elevate dumbbells up and out to head level.\n4. Hold, return to starting position."),
        Exercise(8125L, "Cable Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Attach handle to low pulley, grab with one hand, arm extended down in front.\n2. Stand feet shoulder-width apart.\n3. Lift arm straight up until shoulder height.\n4. Lower with control."),
        Exercise(8126L, "Cable Deltoid Raise", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Stand to side of low pulley row with right hand on handle.\n2. Keep back straight, feet shoulder-width apart.\n3. Elevate arm to shoulder level.\n4. Hold for seconds. Return to start."),
        Exercise(8127L, "Machine Lateral Shoulder Raise", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Sit at shoulder raise machine with arms under each pad.\n2. Raise arms out to sides until about shoulder level.\n3. Hold for count.\n4. Return slowly to starting position."),
        Exercise(8128L, "Leverage Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.LEVERAGE, "1. Load weight and adjust seat so handles near top of shoulders.\n2. Keep head and chest straight.\n3. Press handles upward through elbows.\n4. Return but don't touch stops until set complete."),
        Exercise(8129L, "Dumbbell Arnold Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand straight with dumbbells in each hand.\n2. Raise dumbbells to shoulder height while rotating palms toward body.\n3. Raise both above head squeezing shoulders.\n4. Hold, return to starting position."),
        Exercise(8130L, "Cable Internal Rotation", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Adjust pulley to elbow height with single handle.\n2. Stand side to cable machine, grab handle with working arm hand.\n3. Position elbow against side at 90 degrees.\n4. Rotate arm inward across body.\n5. Return with control."),
        Exercise(8131L, "Arm Circles", listOf(MuscleGroup.SHOULDERS), Equipment.BODYWEIGHT, "1. Stand straight feet shoulder-width apart with arms extended creating 'T' shape.\n2. Make circles feeling shoulder stretch for 10-20 seconds.\n3. Return to starting position."),
        Exercise(8132L, "Weight Plate Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.WEIGHTPLATE, "1. Hold barbell weight plate at waist standing straight with palms facing inward.\n2. Slowly move plate up and out until shoulder level.\n3. Hold and squeeze shoulders.\n4. Return to starting position."),
        Exercise(8133L, "Dumbbell Alternating Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand straight with dumbbells in each hand, palms facing inward.\n2. Elevate one dumbbell up in front to shoulder level.\n3. Hold, return, and repeat with opposite arm."),
        Exercise(8134L, "Barbell Push Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Use power clean to get barbell from floor to shoulders.\n2. Bend knees slightly, explode upward using legs to press barbell overhead.\n3. Lower slowly to shoulders bending knees.\n4. Repeat."),
        Exercise(8135L, "Barbell Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Stand feet shoulder-width apart holding barbell with overhand grip, hands shoulder-width apart.\n2. Lift in controlled manner keeping arms straight with slight bend until shoulder height.\n3. Pause, then slowly lower."),
        Exercise(8136L, "Dumbbell Rear Deltoid Row", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Place your left knee and left hand on a bench for support.\n2. Hold a dumbbell in your right hand with a neutral grip.\n3. Keep your right foot on the ground.\n4. Tighten your abdominal muscles to stabilize your torso.\n5. Pull the dumbbell up and out to the side, leading with your elbow.\n6. Keep elbow slightly bent.\n7. Squeeze your shoulder blade toward your spine as you lift.\n8. Pause at the top focusing on squeezing rear deltoids.\n9. Slowly lower back to starting position."),
        Exercise(8137L, "Shoulder Stretch", listOf(MuscleGroup.SHOULDERS), Equipment.BODYWEIGHT, "1. Start standing with feet shoulder width apart.\n2. Slowly reach across your body with left arm.\n3. Using right hand, grab elbow of left arm and pull toward chest.\n4. Hold for 15-30 seconds.\n5. Return to starting position and repeat."),
        Exercise(8138L, "Dumbbell Alternating Deltoid Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with feet shoulder width apart holding dumbbell in each hand.\n2. Raise weights at sides till at shoulder height avoiding swinging.\n3. Hold for a count then return.\n4. Raise weights in front until shoulder level.\n5. Return to starting position and repeat."),
        Exercise(8139L, "Dumbbell 3 Way Shoulder Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with feet hip-width apart.\n2. Perform side lateral raise for desired repetitions.\n3. Then perform a front raise.\n4. Execute a hip hinge and hold.\n5. Perform a rear raise, also known as a reverse fly.\n6. Keep core engaged throughout.\n7. Do not lean back or use momentum."),
        Exercise(8140L, "Barbell Landmine Kneeling One-Arm Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Place one end of barbell into landmine attachment or secure in corner.\n2. Load weight plates.\n3. Kneel in front with knees on ground and torso upright.\n4. Grip loaded end at shoulder height.\n5. Brace core.\n6. Press barbell upward by extending arm fully overhead.\n7. Keep elbow close to body.\n8. Pause at top.\n9. Lower back under control."),
        Exercise(8141L, "Dumbbell One-Arm Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by holding dumbbell in one hand and standing next to incline bench.\n2. Have dumbbell resting on side next to pelvis.\n3. Raise dumbbell until at shoulder height and parallel to floor.\n4. Return to starting position.\n5. Repeat for desired repetitions."),
        Exercise(8142L, "Smith Machine Upright Row", listOf(MuscleGroup.SHOULDERS), Equipment.SMITH, "1. Position barbell just below thighs when standing upright.\n2. Stand with feet shoulder-width apart.\n3. Grasp barbell with overhand grip.\n4. Unlock bar and lower bar near thighs.\n5. Lift bar straight up towards chin, leading with elbows.\n6. Keep bar close to body.\n7. Continue until bar reaches just below chin.\n8. Slowly lower back in controlled manner."),
        Exercise(8143L, "Dumbbell Hammer Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Take dumbbells with palms facing inward.\n2. Slowly lift until extended overhead.\n3. Hold for few seconds.\n4. Lower into 90-degree push position.\n5. Repeat for desired repetitions."),
        Exercise(8144L, "Dumbbell One-Arm Incline Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Lie sideways on incline bench with dumbbell in one hand.\n2. Keep dumbbell rested next to pelvis.\n3. Perform lateral raise so dumbbell is overhead pressed.\n4. Hold for few seconds.\n5. Return down to starting position.\n6. Repeat."),
        Exercise(8145L, "Cable Rope Deltoid Row", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Start in same position as seated cable row.\n2. Taking overhead rope, grab with overhand grip keeping back straight.\n3. Pull cable towards chest bringing elbows pushed out.\n4. Hold squeezing tightly.\n5. Return to starting position.\n6. Repeat."),
        Exercise(8146L, "Barbell Seated Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start seated at bench holding barbell at shoulder level.\n2. Slowly elevate barbell up above head, squeezing shoulders.\n3. Hold for count.\n4. Return to starting position.\n5. Repeat for desired reps."),
        Exercise(8147L, "Cable Rear Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Position bench between two cable machines with handles on low pulleys.\n2. Stand between cables facing away.\n3. Reach back and grip handles with opposite hands, crossing arms behind back.\n4. Sit down with arms crossed under thighs.\n5. Lean forward until chest touches knees.\n6. Pull handles outward and upward until parallel to ground.\n7. Hold and squeeze.\n8. Slowly lower back."),
        Exercise(8148L, "Dumbbell Seated Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start sitting straight at bench feet shoulder width apart.\n2. Hold dumbbells with overhand grip at sides.\n3. Slowly elevate arms up towards ceiling.\n4. Hold for count.\n5. Return to starting position.\n6. Repeat for desired reps."),
        Exercise(8149L, "Dumbbell Upright Row", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart.\n2. Hold dumbbells with palms facing thighs.\n3. Keep back straight and engage core.\n4. Lift dumbbells by moving elbows up and out.\n5. Keep close to body.\n6. Continue until at chest level.\n7. Pause squeezing shoulders.\n8. Slowly lower back down."),
        Exercise(8150L, "Dumbbell Hammer Curl to Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with palms facing towards body.\n2. Perform standard dumbbell hammer curl.\n3. Contract biceps at top then lower.\n4. Press dumbbells overhead without fully locking elbows.\n5. Hold brief pause.\n6. Lower back down in controlled manner."),
        Exercise(8151L, "Dumbbell Shoulder Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart.\n2. Arms straight and in front of body with dumbbells on thighs.\n3. Slowly raise arms until parallel with floor.\n4. Feel stretch in front of shoulders.\n5. Maintain tight core.\n6. Hold for count then return.\n7. Repeat."),
        Exercise(8152L, "Dumbbell One-Arm Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart.\n2. Hold dumbbell at shoulder height with palm facing forward.\n3. Engage core to maintain stable torso.\n4. Press dumbbell overhead until fully extended.\n5. Lower back to shoulder height maintaining control."),
        Exercise(8153L, "Dumbbell Cuban Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand holding dumbbells down by sides.\n2. Raise by performing upright row.\n3. Rotate shoulders to bring dumbbells into goalpost position.\n4. Press dumbbells overhead.\n5. Hold briefly.\n6. Return to goalpost position by bending elbows.\n7. Lower to sides to complete repetition."),
        Exercise(8154L, "Weight Plate Neck Flexion (Supine)", listOf(MuscleGroup.SHOULDERS), Equipment.WEIGHTPLATE, "1. Start off by lying face up with your back on a flat bench holding a weight plate in front of your head.\n2. With the plate rested on the front your head, slowly lower your neck down squeezing your shoulders and keeping the plate pressed lightly to the head.\n3. Then return back up to the starting position."),
        Exercise(8155L, "Kettlebell Sumo High Pull", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking a kettlebell and keeping it in between your legs.\n2. Bend down as you would in a normal squat position but lower until you are in a sumo stance.\n3. Keeping your back and chest straight while bending your knees, pick up the kettlebell and extend your hips up while pulling the kettlebell upward.\n4. Raise your elbows in the process until they are at shoulder level.\n5. Hold for a few seconds and return back to the starting position."),
        Exercise(8156L, "Cable Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Start by standing in between a low pulley cable machines with two cables attached to the machine.\n2. Bend down, grab the cables and then bring them to your shoulders as this will be your starting position.\n3. Keeping your back straight, head up and chest up, extend through your elbows and push the handles up towards the ceiling over your head and feel the stretch in your shoulders."),
        Exercise(8157L, "Dumbbell Lateral Raise (Prone)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Set an incline bench to about 30-45 degrees.\n2. Lie face down on the bench with your chest supported and feet planted firmly on the floor for stability.\n3. Allow your arms to hang down straight from your shoulders, holding the dumbbells with a slight bend in your elbows.\n4. Lift the dumbbells out to the sides in a wide arc, leading with your elbows and squeezing your shoulder blades together."),
        Exercise(8158L, "Band Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.BANDS, "1. Secure the resistance band to a stable anchor point at about chest height.\n2. This could be a door, a sturdy pole, or any fixed object.\n3. If you don't have an anchor point, you can hold the band with your hands.\n4. Stand facing the anchor point with your feet shoulder-width apart.\n5. Hold one end of the band in each hand.\n6. Step back to create tension in the band when your arms are extended in front of you at shoulder height.\n7. With a slight bend in your elbows, pull the band apart by moving your arms out to the sides."),
        Exercise(8159L, "Dumbbell External Rotation", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by laying on your side on a flat bench with one arm holding a dumbbell against your chest and the other arm extended in front of you holding to the bottom of the bench.\n2. Bend your elbow that is holding the dumbbell so that it is in a 90 degree angle then while keeping this position.\n3. Slowly rotate your forearm externally so that the dumbbell is lifted up from the chest position and is perpendicular to the floor."),
        Exercise(8160L, "Kettlebell Thruster", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start with the kettlebell in a goblet position at your chest.\n2. Perform a thruster by extending your hips and knees to push the kettlebell overhead.\n3. Lower the kettlebell back to your chest and repeat."),
        Exercise(8161L, "Barbell Rear Military Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start by setting up a barbell with the weight that you would like to perform and stand up straight with your feet shoulder width apart.\n2. Extend the barbell above your head as this will be your starting position.\n3. Slowly lower the barbell behind your head and squeeze your shoulders.\n4. Hold for a count then return back to the starting position."),
        Exercise(8162L, "Dumbbell Push Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with your feet shoulder-width apart and hold a dumbbell in each hand at shoulder height.\n2. Your palms should be facing inward, and your elbows should be bent with your upper arms parallel to the floor.\n3. Bend your knees slightly and lower your body into a partial squat position.\n4. Explosively extend your knees and hips to drive the dumbbells upward.\n5. This generates momentum to help press the weights overhead."),
        Exercise(8163L, "Dumbbell Seated Alternating Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting on either a flat or elevated bench with your feet in front of you, holding a dumbbell in each hand keeping them rested at shoulder level next to your head.\n2. Slowly elevate one hand up towards the ceiling, keeping the other at the side of your head, and squeeze your shoulder.\n3. Return back to the starting position and repeat with the opposite arm."),
        Exercise(8164L, "Dumbbell Seated Press (Palms In)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting at the end of a flat bench with your feet on the floor in front of you, holding a dumbbell in each arm at shoulder level, palms facing in, next to your head.\n2. Slowly elevate your arms up and above your head, squeezing your shoulder and hold for a count.\n3. Return back to the starting position."),
        Exercise(8165L, "Barbell Clean and Jerk", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off with a weighted barbell in front of your feet and raise it slightly so that it is parallel with your shins.\n2. Lower your hips and bend your knees a bit while keeping your back straight so that the weight of the bar is rested upon your heels.\n3. Pull up on the bar so that it reaches the mid-thigh position then perform a jumping movement."),
        Exercise(8166L, "Barbell Overhead Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off with a weighted barbell rested in front of your thighs with your palms facing down.\n2. Lift the barbell up until it is overhead above your body and hold onto this position for a few seconds.\n3. Return back to the starting position."),
        Exercise(8167L, "Band Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.BANDS, "1. Stand on a band so that it is evenly distributed to be pulled by each arm.\n2. Grab the handles and keep you arms down and rested at your side.\n3. Then using your shoulders, raise the hands above your sides so that they are at shoulder level then lower the handles back down to the starting position."),
        Exercise(8168L, "Cable Seated Row to Neck", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Start by setting up either a V-Bar or Rope Extension on a low pulley cable machine and sit down flat on the floor or on a bench with your feet facing towards the machine.\n2. Grasping the rope and bringing it to knee level.\n3. Slowly, while keeping your body still, pull the rope in towards your chest and up to your neck.\n4. Squeezing your shoulders and hold for a count."),
        Exercise(8169L, "Cable Bent-Over Lateral Pulley", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Start by setting up handles on two low pulley cable machines and positioning yourself in between the machines with feet shoulder width apart.\n2. Bend down with your upper body, keeping your lower body still, so that your back is parallel with the floor.\n3. Grab each handle with the opposite hand and bring it in towards your chest, keeping arms crossed.\n4. Slowly let your arms extend outward, feeling a stretch in your shoulders and squeeze."),
        Exercise(8170L, "Barbell Rear Delt Row", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off by placing a weighted barbell in front of your legs bending over slightly with your glutes extended out.\n2. Let your arms hang down and grab the barbell, lifting slightly so that the bar is rested around your shins.\n3. Pull the barbell up towards your chest keeping your body still during the entire movement.\n4. As you reach your chest squeeze your back and your deltoids tightly holding on for a few seconds."),
        Exercise(8171L, "Dumbbell Front Incline Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting with your back flat on an incline bench holding a dumbbell in each hand.\n2. Push your arms out in front of you with your palms facing out above your thighs.\n3. Taking the dumbbells, raise them straight up until they are above your shoulders holding onto this position for a few seconds.\n4. Squeeze your shoulders tightly, then return back to the starting position."),
        Exercise(8172L, "Smith Machine Rear Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.SMITH, "1. Start by setting up a weighted smith machine with the bar positioned at the top rack with full upright bench positioned right underneath the bar.\n2. Sit on the bench with feet flat on the floor and remove the bar off of the rack.\n3. Slowly lower the weight behind your head, feeling a stretch in your shoulders and squeeze, and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8173L, "Handstand Push-Up", listOf(MuscleGroup.SHOULDERS), Equipment.BODYWEIGHT, "1. Start with your back up against a wall, then bend forward placing both hands on the floor in front of you shoulder width apart.\n2. Slowly kick your feet up against the wall, still keeping your arms straight, and walk your way up the wall with your feet so that your legs and arms are fully extended.\n3. Make sure that your body is straight and balanced before you move onto the next step.\n4. Slowly, through your shoulders, lower yourself towards the ground so that your head almost touches the floor and you feel a stretch in your shoulders and upper body.\n5. Push yourself back up until your elbows are near locked.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8174L, "Dumbbell Seated Dublin Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting up straight at the end of a flat bench, holding a dumbbell in each arm at shoulder level next to your head.\n2. Slowly extend your arms overhead, squeezing your shoulder and immediately return back to the starting position.\n3. Repeat for as many reps and sets as desired."),
        Exercise(8175L, "Shoulder Rotation", listOf(MuscleGroup.SHOULDERS), Equipment.BODYWEIGHT, "1. Start by standing up straight with your arms at your sides and feet shoulder width apart.\n2. Raise your hands and place them on your shoulders with your elbows at shoulder height pointing outward.\n3. Then slowly rotate your elbows in a circular motion so that you feel a stretch within your shoulders.\n4. Continue for as many reps and however long you desire and repeat."),
        Exercise(8176L, "Weight Plate Neck Extension (Prone)", listOf(MuscleGroup.SHOULDERS), Equipment.WEIGHTPLATE, "1. Start off by lying face down on a flat bench holding a weight plate behind your head.\n2. With the plate rested behind your head, slowly lower your neck down squeezing your shoulders and keeping the plate pressed.\n3. Then return back up to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8177L, "Dumbbell Reverse Fly with External Rotation", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off lying face down on an incline bench with a dumbbell in each hand rested on the floor in front of you but with palms facing down towards the ground.\n2. Then raise your arms so that they are parallel with your shoulders and extend out as in a regular flye.\n3. Hold onto this position for a few seconds.\n4. Return back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8178L, "Trap Bar Overhead Press", listOf(MuscleGroup.SHOULDERS), Equipment.TRAPBAR, "1. Begin by standing inside the trap bar with your feet shoulder-width apart.\n2. Position the handles of the trap bar so that they're in line with your shoulders.\n3. Grip the handles firmly with an overhand grip, palms facing forward.\n4. Engage your core muscles to stabilize your torso.\n5. Bend your knees slightly and push through your heels to lift the trap bar off the ground.\n6. Keep your back straight and chest up as you lift the trap bar to the starting position, just above your shoulders.\n7. Your elbows should be bent and pointing forward, with your upper arms parallel to the ground.\n8. Once you're in the starting position, exhale and press the trap bar directly overhead by extending your arms.\n9. Keep your core tight and maintain a neutral spine throughout the movement.\n10. As you press the trap bar overhead, avoid leaning back excessively or arching your lower back.\n11. Fully extend your arms at the top of the movement, but avoid locking out your elbows.\n12. Keep your head in a neutral position, looking straight ahead or slightly upward.\n13. Inhale and slowly lower the trap bar back down to the starting position, controlling the descent."),
        Exercise(8179L, "Barbell Push Press Behind the Neck", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off with a weighted barbell rested upon your shoulders behind your neck.\n2. Bend your knees slightly and explode upward using your upper legs to overhead press the barbell above your head.\n3. Lower the bar slowly back down to your shoulders.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8180L, "Cable Rope Row to Neck", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Start off by sitting down on a low pulley row machine and grab the ends of the rope with a palms-down grip keeping your back straight and knees slightly bent.\n2. Take the rope and start to lift it towards your neck, bending your elbows on the way up keeping your arms parallel to the floor.\n3. Hold this position for a few seconds then return back to the starting point.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8181L, "Kettlebell One-Arm Snatch", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by placing a kettlebell in front of your feet and bending down at your knees pushing your glutes out.\n2. Take the kettlebell and swing it between your legs and then with the momentum of the swing, push your hips and knees up allowing the kettlebell to be overhead pressed.\n3. Hold this position for a few seconds.\n4. Return back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8182L, "Dumbbell Deltoid Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by holding two dumbbells in front of your pelvis with your palms facing your thighs.\n2. Take the dumbbells and raise them in a semicircular motion so that they are overhead.\n3. Return back to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8183L, "Shoulder Circles", listOf(MuscleGroup.SHOULDERS), Equipment.BODYWEIGHT, "1. Start off standing up straight with your feet shoulder width apart and your arms rested at your sides.\n2. Slowly roll your shoulders up, then back and down, feeling a stretch in the muscles.\n3. Repeat for as many reps and sets as desired."),
        Exercise(8184L, "Dumbbell Seated Alternating Arnold Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Begin seated on the end of a flat bench with feet on the floor in front of you holding a dumbbell in each hand.\n2. Slowly, while using your thighs, raise the dumbbells to shoulder level and twist your palms so that they are facing in towards your body.\n3. From there raise one dumbbell above your head, while keeping the other one still, squeezing in your shoulder, and hold for a count.\n4. Return back to the starting position and repeat with the opposite hand.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8185L, "Weight Plate High Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.WEIGHTPLATE, "1. Start by standing up straight with your feet shoulder width apart and holding a weight plate together with both hands at waist level.\n2. Slowly, while squeezing your shoulders, elevate the weight plate above your head and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8186L, "Dumbbell Seated Front Raise (Hammer)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Begin by sitting on a flat bench, holding a dumbbell in each hand with arms extended down by your sides; use a hammer grip.\n2. Slowly elevate both dumbbells up and in front of you towards shoulder level.\n3. Focus on squeezing your shoulder muscles on the way up.\n4. Maintain a hammer grip during the entire exercise.\n5. Hold onto this position for a count then return back to the starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8187L, "Barbell Rear Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off with a weighted barbell and rest it on your shoulders behind your neck.\n2. Take the barbell and extend it overhead by pushing your arms upward.\n3. Hold onto this position for a few seconds.\n4. Return back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8188L, "Dumbbell Alternating Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight, holding a dumbbell in both arms at shoulder level next to your head.\n2. Slowly extend one of your arms overhead, squeezing in your shoulder and hold for a count.\n3. Return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8189L, "Kettlebell One-Arm Push Press", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by clean pressing a kettlebell to your shoulder with your palms facing outward in front of you.\n2. After lower your body by bending at the knees and keeping your chest and back straight.\n3. Push through your heels and lower legs to thrust the kettlebell overhead and your body upward keeping your feet firm on the floor.\n4. Return back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8190L, "Upward Stretch", listOf(MuscleGroup.SHOULDERS), Equipment.BODYWEIGHT, "1. Start off standing up straight with your feet shoulder width apart and your arms rested at your sides.\n2. Extend both of your hands up above your head, touching your palms together and then push your hands up and back keeping your back straight through the motion.\n3. Hold this position for 15 to 30 seconds, feeling a stretch in your shoulders, then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8191L, "Posterior Capsule Stretch", listOf(MuscleGroup.SHOULDERS), Equipment.BODYWEIGHT, "1. Start off standing up straight with your arms at your sides and your feet shoulder width apart.\n2. From there bring one of your arms across your chest so that the palm faces the body with your other arm putting pressure until you feel a stretch in your shoulder.\n3. Hold this position for 30 seconds to a minute and repeat with the opposite side."),
        Exercise(8192L, "Dumbbell Alternating Arnold Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight with feet shoulder width apart and holding a dumbbell in each hand.\n2. Slowly, while using your thighs, raise the dumbbells to shoulder level and twist your palms so that they are facing in towards your body.\n3. From there raise one dumbbell above your head, while keeping the other one still, squeezing in your shoulder, and hold for a count.\n4. Return back to the starting position and repeat with the opposite hand.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8193L, "Dumbbell Alternating Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder width apart and holding a dumbbell in each hand.\n2. While keeping your body still, slowly raise one of the dumbbells out to the side up to shoulder level, squeezing on the way up and hold for a count.\n3. Then return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8194L, "Band Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.BANDS, "1. Stand on an exercise band so that it is evenly distributed to be pulled by each arm.\n2. Grab the handles and press your arms up so that they are at shoulder level.\n3. Then using your shoulders, raise the hands above your sides so that they are above your head then lower the handles back down to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8195L, "Dumbbell Incline Shoulder Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting with your back flat on an incline bench holding a dumbbell in each hand.\n2. With the driving force of your legs, kick the weights above your shoulders and keep them overhead above your chest.\n3. Using your shoulders and keeping your arms straight, lift up your dumbbells and push them as high as you can without leaving the bench.\n4. Hold the position for a few seconds then return back to starting position.\n5. Repeat for as many repetitions as needed."),
        Exercise(8196L, "Dumbbell Lateral Raise (Side-Lying)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by holding a dumbbell in one hand and lying on your side on a flat bench.\n2. Have the dumbbell resting on the edge of the bench just across from your chest.\n3. Take the dumbbell and raise it with your arm until it is at shoulder height and parallel to the floor.\n4. Return the dumbbell back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8197L, "Smith Machine Deltoid Row", listOf(MuscleGroup.SHOULDERS), Equipment.SMITH, "1. Setting Up: Adjust the Smith Machine Bar. Set the bar on the Smith Machine to a height that allows you to grip it with your arms fully extended and your torso bent at a 45-degree angle.\n2. Choose the Appropriate Weight. Load the bar with an appropriate weight that you can lift with proper form.\n3. Position Your Body. Stand facing the Smith Machine bar. Place your feet shoulder-width apart.\n4. Bend your knees slightly and hinge at the hips to lower your torso to about a 45-degree angle.\n5. Your back should be straight, not rounded.\n6. Grip the Bar. Grasp the bar with an overhand grip (palms facing down), slightly wider than shoulder-width apart.\n7. Engage Your Core. Tighten your core muscles to stabilize your body throughout the movement.\n8. Lift the Bar. Exhale as you pull the bar up towards your lower chest or upper abdomen.\n9. Keep your elbows flared out to the sides to emphasize the deltoids.\n10. Squeeze your shoulder blades together at the top of the movement.\n11. Lower the Bar. Inhale as you slowly lower the bar back to the starting position with your arms fully extended.\n12. Maintain control to avoid letting the weights drop quickly."),
        Exercise(8198L, "Dumbbell Alternating Bent-Over Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder width apart, holding a dumbbell in each hand at your side.\n2. Bend down so that your body is parallel with the floor and bring the weights in front of you to about knee level.\n3. Slowly extend one of your arms up and out so that the weights are at level with your head and squeeze your shoulder.\n4. Hold for a count then return back to the starting position and repeat with the opposite arm.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8199L, "Kettlebell One-Arm Military Press", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by clean pressing a kettlebell to your shoulder with your palms facing inward towards your face.\n2. Then press the kettlebell up and out until it is overhead.\n3. Return the kettlebell back to the inward shoulder position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8200L, "Band Upright Row", listOf(MuscleGroup.SHOULDERS), Equipment.BANDS, "1. Stand on the band so that the handles are level with your upper thigh.\n2. With your back straight and abs drawn in raise your hands upward to your collarbone.\n3. Your elbows and arms should be parallel with the floor.\n4. Slowly lower your arms and return to starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8201L, "Dumbbell Dublin Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight, holding a dumbbell in each arm at shoulder level next to your head.\n2. Slowly extend your arms overhead, squeezing in your shoulder and immediately return back to the starting position.\n3. Repeat for as many reps and sets as desired."),
        Exercise(8202L, "Kettlebell Military Press", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by clean pressing kettlebells to your shoulder with your palms facing inward towards your face.\n2. Then press the kettlebells up and out until they overhead.\n3. Return the kettlebells back to the inward shoulder position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8203L, "Dumbbell Seated One-Arm Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting at the end of a bench straight up, gripping a dumbbell in one hand and keeping it parallel to your head.\n2. Slowly press the weight upward until the elbow is next to your ear and hold for a count.\n3. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(8204L, "Smith Machine Shoulder Press (Wide Grip)", listOf(MuscleGroup.SHOULDERS), Equipment.SMITH, "1. Start by setting up an incline bench underneath a smith machine bar so that the end of the bench is right underneath the weight.\n2. Place the amount of weight that you would like to use on the bar for this exercise.\n3. Sit down with your back flat on the bench, feet out in front of you and holding the bar with an overhand wide grip.\n4. Lift the bar off of the rack and slowly bring it down towards your chest, feeling a squeeze and stretch, then hold for a count.\n5. Return back up to the starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8205L, "Kettlebell Alternating Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking two kettlebells and clean pressing them to your shoulders keeping your palms inward.\n2. Then press the kettlebell in your right arm overhead keeping your palms facing outward holding onto the position for a few seconds.\n3. Return back to the starting clean pressed position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8206L, "Dumbbell Seated Alternating Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting up straight at the end of a flat bench with your feet shoulder width apart, holding a dumbbell in each hand with an overhand grip at your sides.\n2. Slowly elevate one arm up towards the ceiling, squeezing your shoulder and hold for a count.\n3. Return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8207L, "Cable Seated Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Start off by placing a bench in front of a low cable pulley machine or placing a bench in between two low cable pulley machines (depending on what your gym currently has).\n2. Grab the handles and bring the cables to shoulder level, keeping your arms bent in a 90 degree angle.\n3. Slowly extend through your elbows and push the handles up over your head and towards the ceiling until you feel a stretch in your shoulders.\n4. Hold for a count then return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8208L, "Cable Overhead Raise (Supine)", listOf(MuscleGroup.SHOULDERS), Equipment.MACHINE, "1. Begin by setting up a low pulley cable machine with a straight bar attachment.\n2. Lay down on the ground with your feet extended out towards the machine and hold the bar at your waist.\n3. Slowly extend the bar up and above your chest, squeezing in your shoulders and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8209L, "Dumbbell One-Arm Upright Row", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Stand with your feet shoulder-width apart.\n2. Hold a dumbbell in one hand with an overhand grip, allowing it to hang down in front of your thigh.\n3. Engage your core muscles to maintain a stable torso.\n4. Lift the dumbbell by bringing your elbow up and out to the side, keeping it close to your body.\n5. Continue lifting until it reaches chest level.\n6. Pause briefly at the top, squeezing your shoulder muscles.\n7. Slowly lower back to the starting position in a controlled manner."),
        Exercise(8210L, "Dumbbell Reverse Fly (Prone)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by setting up a flat bench with your chest rested upon the bench, feet extended behind you, holding a dumbbell in each hand.\n2. Using your shoulders, raise your arms up towards the ceiling, squeezing on the way up and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8211L, "Kettlebell Clean", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking a kettlebell in each hand and clean pressing them to your shoulders.\n2. Perform a squat and dip your body at the knees keeping your chest and back straight.\n3. Use your momentum to thrust the kettlebells overhead.\n4. Hold onto this position for a few seconds then return back to the starting point with the kettlebells clean pressed at the shoulder.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8212L, "Dumbbell One-Arm Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight, holding a dumbbell in one arm at shoulder level next to your head.\n2. Slowly elevate your arm up and above your head, squeezing in your shoulder and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8213L, "Dumbbell One-Arm Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder width apart and holding a dumbbell in one hand at your side.\n2. Slowly elevate your arm up in front of you to about head level, feeling a stretch in your shoulders and squeeze, and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8214L, "Dumbbell Seated One-Arm Lateral Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting down at the end of a flat bench with your feet shoulder width apart and holding a dumbbell in one hand.\n2. While keeping your body still, slowly raise the dumbbell out to the side up to shoulder level, squeezing on the way up and hold for a count.\n3. Then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8215L, "Barbell Bradford Rocky Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off sitting on a straight up military press bench with a weighted barbell rested on your upper chest.\n2. Keeping your palms facing out, push the barbell up in an overhead press above your head and hold for a few seconds.\n3. Then lower the bar down behind the back of your head and hold for a few seconds.\n4. Return back to the overhead position and then back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8216L, "Dumbbell Shoulder Press (Reverse Grip)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off sitting up straight on a bench, with your feet together flat on the floor, gripping dumbbells in each hand at shoulder height.\n2. Press the weights upward with your wrists rotating outward until you feel a stretch in your shoulders, and hold this position for a count.\n3. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(8217L, "Diagonal Plate Raise", listOf(MuscleGroup.SHOULDERS), Equipment.WEIGHTPLATE, "1. The diagonal plate raise is an exercise that primarily targets the shoulders, specifically the anterior and lateral deltoid muscles.\n2. Begin with the weight plate positioned at the midpoint of your body, in front of your thighs.\n3. Keeping your arms straight and your core engaged, lift the weight plate diagonally upwards and away from your body.\n4. Continue raising the weight plate until your arms are slightly above shoulder height.\n5. Slowly lower the weight plate back to the starting position in a controlled manner."),
        Exercise(8218L, "Dumbbell See Saw Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by grabbing a dumbbell in each hand and clean lift them so that your palms are facing in at chest level.\n2. Then take your left arm and extend it overhead, while it is being extended rotate your wrist so that the palms are facing inward, and bend your torso to the opposite direction.\n3. Repeat the exercise with the opposite hand and then return back to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8219L, "Smith Machine Shoulder Press (Close Grip)", listOf(MuscleGroup.SHOULDERS), Equipment.SMITH, "1. Start by setting up an incline bench underneath a smith machine bar so that the end of the bench is right underneath the weight.\n2. Place the amount of weight that you would like to use on the bar for this exercise.\n3. Sit down with your back flat on the bench, feet out in front of you and holding the bar with an overhand close grip.\n4. Lift the bar off of the rack and slowly bring it down towards your chest, feeling a squeeze and stretch, then hold for a count.\n5. Return back up to the starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8220L, "Dumbbell Shoulder Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting on top of a stability ball with your feet planted firmly on the floor in front of you, arms bent by your head at 90-degrees and dumbbells in each hand.\n2. Raise the dumbbells slightly in front of your head and elevate them over your head completely until they are touching at the ends.\n3. Keep your arms straight at the top and hold motion for a count then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8221L, "Barbell Rear Delt Row to Neck", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start by setting up a weighted barbell in front of you, keeping your feet shoulder width apart and bend down so that your back is parallel to the floor.\n2. Extend your arms down towards the floor, grab the barbell with an overhand grip and bring it to shin level.\n3. Slowly pull the barbell up towards your neck, feeling a stretch in your shoulders and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8222L, "Cable Decline Pullover", listOf(MuscleGroup.SHOULDERS), Equipment.CABLE, "1. Start by placing a decline bench in front of a high cable pulley machine with the head rest facing the machine.\n2. Attach a long bar to the machine and sit down with your back on the bench and feet planted firmly on the floor or in a foot rest.\n3. Grab the bar with both hands with palms facing out and slowly pull up and out with your shoulders until the bar reaches to around your pelvic area.\n4. Hold this position for a count then return back up slowly to the start.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8223L, "Barbell Incline Shoulder Raise", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off with lying flat back on an incline bench with a medium width grip upon the barbell.\n2. Take the bar off from the rack and hold it straight over your head with arms straight.\n3. With the bar above your head, raise the shoulders off from the bench and exhale.\n4. Return the bar back to the starting position and inhale.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8224L, "Kettlebell Push Press", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by clean pressing two kettlebells to your shoulders.\n2. Bend slightly at the knees and the push up using your heels to drive the kettlebells above your head.\n3. Hold for a few seconds then return back to the starting position.\n4. Repeat for as many repetitions as needed."),
        Exercise(8225L, "Kettlebell Arnold Press", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by clean pressing a kettlebell to your shoulder with your palms facing inward towards your head.\n2. Press the kettlebell out and thrust overhead.\n3. Return back to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8226L, "Dumbbell One-Arm Bent-Over Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder width apart, holding a dumbbell in one hand at your side.\n2. Bend down so that your body is parallel with the floor and bring the weight in front of you to about knee level.\n3. Slowly extend the arm holding the weight up and out so that the weight is at level with your head and squeeze your shoulder.\n4. Hold for a count then return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8227L, "Kettlebell Turkish Get-Up Lunge", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off lying flat on your back on the floor with a kettlebell pressed up above your chest.\n2. Take the knee that is on the same side as the kettlebell and bend it.\n3. Then use your opposite arm to help push yourself up into a lunge position and then move to resting on one knee.\n4. Slowly stand up with the kettlebell still pressed up overhead then reverse back down to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8228L, "Barbell Jerk", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off bringing yourself up as you would as in a normal jerk by standing up straight with the weighted barbell resting upon your shoulders and palms.\n2. Dip your knees a bit and use your momentum to overhead press the barbell above your head.\n3. Return back to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8229L, "Medicine Ball Overhead Throw", listOf(MuscleGroup.SHOULDERS), Equipment.MEDICINE_BALL, "1. You can either use a partner or stand in front of a wall for this exercise.\n2. Start by standing a few feet away from your partner with your back to them.\n3. Bend down towards the floor with your back almost parallel to the ground and your knees slightly bent holding an exercise ball in your hands in between your legs.\n4. Then in a reverse motion, forcefully extend your arms over your head and toss the ball behind your head towards your partner, following through with the throw so that you can feel it within your core and shoulders.\n5. Your partner will then catch the ball and roll it back to you.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8230L, "Barbell Round the World Shoulder Stretch", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off standing up straight holding a barbell, with palms up towards the ceiling, behind your back.\n2. Keep the barbell positioned behind your hips and then slowly lift your arms up so that they are behind your head.\n3. Return back to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8231L, "Dumbbell One-Arm Bent-Over Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting on the end of a flat bench with your feet together on the floor in front of you and a dumbbell in one hand.\n2. Bend down so that your chest is rested upon your thighs and position the dumbbell underneath your legs.\n3. Slowly elevate the dumbbell up and out to around head level and squeeze your shoulder.\n4. Hold for a count then return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8232L, "Dumbbell One-Arm Lateral Raise (Prone)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Lie face down on a 30-45 degree incline bench with feet flat on floor and head neutral.\n2. Hold a dumbbell in one hand.\n3. Begin the movement by raising your arm out to the side until it is at shoulder height.\n4. Keep a slight bend in your elbow to reduce stress on your joints.\n5. Your palm should face the floor as you lift the weight.\n6. Lift the weight in a controlled manner, avoiding momentum or swinging.\n7. Focus on using your lateral deltoid muscle to lift the weight.\n8. Once your arm reaches shoulder height, pause for a brief moment.\n9. Lower the weight back to the starting position in a controlled manner."),
        Exercise(8233L, "Smith Machine Incline Shoulder Raise", listOf(MuscleGroup.SHOULDERS), Equipment.SMITH, "1. Start off by placing an incline bench underneath a smith machine and align the barbell at a height that you are able to reach the bar.\n2. Grab onto the barbell and lift the bar off from the rack and hold it over you with your elbows, slightly bent.\n3. Then lift the bar up until your arms are fully extended holding on for a few seconds, returning it back to the starting position.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8234L, "Dumbbell Arnold Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting on an exercise ball straight up, gripping a dumbbell in each hand and keeping them elevated in front of your chest, palms facing in.\n2. Slowly press the weights upward by twisting the weights so that your palms are facing out and raised above your head until the elbow is next to your ear and hold for a count.\n3. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(8235L, "Dumbbell Lateral Raise (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting upright on a stability ball, holding a dumbbell in each hand hanging down by your sides.\n2. Then laterally lift up both arms to about shoulder height, feeling tension in your shoulders and hold for a count.\n3. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(8236L, "Stability Ball Neck Flexion", listOf(MuscleGroup.SHOULDERS), Equipment.EXERCISEBALL, "1. Begin by sitting on a stability ball, allowing your spine to stretch out and align straight, and keep your feet flat on the floor.\n2. Take your hands and grip the sides of the exercise ball, retract your shoulders and tuck in your chin.\n3. Then roll your head forward until your chin touches your chest and hold for 15 to 30 seconds.\n4. Repeat for as many times as you would like."),
        Exercise(8237L, "Barbell Shoulder Pull (Prone)", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Begin by setting up a weighted barbell and placing it in front of a flat bench.\n2. Lay down with your chest flat on the bench, feet extended behind you and take hold of the bar with an overhand shoulder-width grip.\n3. Slowly pull the barbell up to shoulder level, squeezing on the way up and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8238L, "Dumbbell Seated One-Arm Arnold Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by seated on the end of a flat bench with feet on the floor in front of you holding a dumbbell in one hand.\n2. Slowly, while using your thighs, raise the dumbbell to shoulder height and twist your palm so that it is facing in towards your body.\n3. From there raise the dumbbell above your head, squeezing your shoulder, and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8239L, "Dumbbell Alternating Press (Palms In)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting at the end of a flat bench with your feet on the floor in front of you, holding a dumbbell in each arm at shoulder level, and palms facing in next to your head.\n2. Slowly extend one of your arms overhead, squeezing your shoulder and hold for a count.\n3. Return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8240L, "Kettlebell Snatch", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by holding two kettlebells at knee level.\n2. Bend slightly at your knees and swing the kettlebells between your legs then drive up with your torso until they are overhead pressed.\n3. Hold onto this position for a few seconds then return back to the starting point.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8241L, "Dumbbell One-Arm Front Raise (Seated)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by setting up an incline bench and sit down with your back flat on the bench with your feet in front of you, holding a dumbbell in each hand at your sides.\n2. Slowly elevate your arm up and out to about head level and squeeze your shoulders on the way up.\n3. Hold for a count then return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8242L, "Barbell High Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start by standing up straight and setting up an EZ bar with the weight that you would like to perform with your feet shoulder width apart and keeping the weight at waist level.\n2. Slowly elevate your arms up and above your head, squeezing your shoulders in the process and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8243L, "Barbell Alternating Press", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Begin by standing up straight with your feet shoulder width apart, holding a weighted barbell at waist level with an overhand grip.\n2. Then push the barbell up and above your head so that your arms are fully extended.\n3. Slowly lower the bar towards your upper chest so that it is almost touching, then immediately push it back up to the starting position.\n4. As soon as you reach this position, lower the bar back down behind your neck and hold for a count.\n5. Return back to the starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8244L, "Barbell Rack Delivery", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off holding a weighted barbell palms down parallel with your torso.\n2. Then with a thrust of motion rotate the elbows around the bar pushing it up towards your shoulders with assistance from your forearms.\n3. Keep the bar as close to the body as possible as you perform this movement and make sure that you use your shoulders as a resting spot for the barbell.\n4. Return the barbell down slowly to its resting position at the torso.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8245L, "Kettlebell Alternating Press", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by clean pressing two kettlebells to your shoulders.\n2. Take one of the kettlebells and overhead press it, then return it back down to the starting position.\n3. On the return down immediately press the other kettlebell overhead.\n4. Return back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8246L, "Dumbbell One-Arm Hammer Shoulder Press", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Begin standing up straight with your feet shoulder width apart, holding a dumbbell in one arm at head level in a neutral grip so that your palms are facing in.\n2. Slowly elevate the dumbbell up and above your head while squeezing your shoulder.\n3. Hold for a count then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8247L, "Dumbbell Alternating Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by setting up an incline bench with your chest rested upon the bench with feet extended behind you, toes on the floor, holding a dumbbell in each hand, and arms rested down towards the floor.\n2. Slowly, using your shoulders, raise one of your arms up towards the ceiling, squeezing on the way up and hold for a count.\n3. Return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8248L, "Dumbbell Seated One-Arm Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting up straight at the end of a flat bench with your feet shoulder width apart, holding a dumbbell in one hand with an overhand grip at your side.\n2. Slowly elevate your arm up towards the ceiling, squeezing your shoulder and hold for a count.\n3. Return back to the starting position."),
        Exercise(8249L, "Kettlebell Jerk", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking a kettlebell in each hand.\n2. Clean press the kettlebells to shoulder level and hold onto this position.\n3. Push your body forward by bending at the knees keeping your back and chest straight keeping your front foot pressed to the floor and the back rested upon the knee.\n4. Overhead press the kettlebells in a thrusting motion as you bring your body to the floor.\n5. Return back to a standing position.\n6. Repeat this exercise for as many repetitions as needed."),
        Exercise(8250L, "Dumbbell One-Arm Reverse Fly", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Begin by setting up on a flat bench with your chest resting on the bench, feet extended behind you, holding a dumbbell in one hand, and arms rested down towards the floor.\n2. Slowly, using your shoulders, raise your arm up towards the ceiling, squeezing on the way up and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8251L, "Stability Ball Neck Extension", listOf(MuscleGroup.SHOULDERS), Equipment.EXERCISEBALL, "1. Begin by sitting on a stability ball keeping your back straight up and feet flat on the floor.\n2. Take your hands and grip the sides of the exercise ball allowing your shoulders to slide down.\n3. From there slowly roll your head back until you start to feel a stretch.\n4. Hold onto this position for 15 to 30 seconds and repeat for as many times as you would like."),
        Exercise(8252L, "Barbell Seated Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start by sitting on the end of a flat bench with your feet together on the floor in front of you and a weighted barbell in your hands rested upon your knees.\n2. Slowly elevate the barbell up to shoulder level, squeezing on the way up and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and set as desired."),
        Exercise(8253L, "Dumbbell Alternating Reverse Fly (Prone)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by setting up a flat bench with your chest rested upon the bench, feet extended behind you, holding a dumbbell in each hand, and arms rested down towards the floor.\n2. Slowly, using your shoulders, raise one of your arms up towards the ceiling, squeezing on the way up and hold for a count.\n3. Return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8254L, "Dumbbell Alternating Shoulder Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting on top of a stability ball with your feet planted firmly on the floor in front of you, arms bent by your head at 90-degrees and dumbbells in each hand.\n2. Raise one of the dumbbells slightly and elevate them over your head completely keeping the other next to your head in position.\n3. Keep your arm straight at the top and hold motion for a count then return back to the starting position.\n4. When you return back down with the first weight, elevate up with the opposite arm and perform the same motion.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8255L, "Dumbbell Seated Shoulder Raise (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting on top of a stability ball with your feet planted firmly on the floor in front of you.\n2. Raise both dumbbells, keeping both arms straight, until dumbbells are parallel to the floor.\n3. Keep your arms straight at the top and hold movement for a count then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8256L, "Upper Body Chair Stretch", listOf(MuscleGroup.SHOULDERS), Equipment.BENCH, "1. Start by sitting on a chair with your feet planted on the floor and your arms rested upon your thighs.\n2. Reach back with your hands, keeping your arms straight, and grip the back of the chair.\n3. Slowly lower your upper body forward, still keeping your arms straight, until your head is between your knees and you can feel a stretch within your shoulders.\n4. Hold onto this stretch for 15 to 30 seconds and then return back to the starting position.\n5. Repeat for as many reps and however long as desired."),
        Exercise(8257L, "Dumbbell Alternating Posterior Fly (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off sitting on a stability ball with both feet together, your chest close to your knees and arms hanging down in front with a dumbbell in each hand.\n2. While maintaining a flat back, lift one of the weights to shoulder height allowing the arm to bend slightly and hold for a count, as the other arm stays in front of you.\n3. Return back to the starting position and alternate the exercise with the opposite arm.\n4. Repeat for as many reps and sets desired."),
        Exercise(8258L, "Dumbbell Alternating Lateral Raise (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off sitting straight up on a stability ball with both feet together and each hand holding a dumbbell.\n2. Elevate one of the dumbbells to shoulder height, keeping the dumbbell straight during the entire motion then slowly return back to the starting position.\n3. Then alternate with the opposite arm with the dumbbell to shoulder level.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8259L, "Band Shoulder Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.BANDS, "1. Begin by sitting on an exercise ball that is placed on top of a stretched band with a grip held in each hand and keeping your feet flat on the floor.\n2. When balanced slowly press the bands upward so that they are elevated over your head and hold this position for a count and return back to the start.\n3. Repeat for as many reps and sets as desired."),
        Exercise(8260L, "Dumbbell One-Arm Shoulder Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting on a stability ball straight up, gripping a dumbbell in one hand and keeping it parallel to your head.\n2. Slowly press the weight upward until the elbow is next to your ear and hold for a count.\n3. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(8261L, "Dumbbell One-Arm Lateral Raise (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting straight up on a stability ball with both feet together and one hand holding a dumbbell.\n2. Lift the dumbbell to shoulder height, keeping the dumbbell straight during the entire motion then slowly return back to the starting position.\n3. Repeat for as many reps and sets as possible and then switch to the other arm."),
        Exercise(8262L, "Kettlebell One-Arm Split Snatch", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking a kettlebell in one hand and placing it between your legs.\n2. Bend at your knees keeping your back and chest straight.\n3. Then push through with your hips and raise the kettlebell overhead.\n4. With the kettlebell pressed overhead, shift your body into a lunge position so that one leg is forward with knee bent and the other backwards to maintain the weight of the kettlebell.\n5. Return back to the starting position.\n6. Repeat this exercise for as many repetitions as needed."),
        Exercise(8263L, "Dumbbell Alternating Arnold Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting on an exercise ball with a dumbbell in each hand.\n2. Elevate the dumbbells up towards your shoulders with your palms facing towards you in an Arnold Press position.\n3. Slowly press the dumbbells up towards the ceiling, rotating your wrists outward, until your arms are fully extended.\n4. Then return back to the starting position, rotating your wrists back inward, and repeat for as many reps and sets as desired."),
        Exercise(8264L, "Barbell Frankenstein Squat", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start off by placing a barbell on the front of your shoulders.\n2. Keeping the barbell still and in place, extend your arms out in front of you so that they are parallel with the floor and at shoulder level.\n3. Bend at the knees and lower your hips down towards the ground, keeping your chest and back straight along with the barbell secure on your shoulders.\n4. Continue in a basic squat motion until your upper legs come in contact with your calves.\n5. Return back to the starting position slowly with barbell in place.\n6. Repeat this exercise for as many repetitions as needed."),
        Exercise(8265L, "Barbell Seated High Front Raise", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start by sitting up straight at the end of a flat bench with your feet on the floor in front of you holding a weighted barbell on your knees with an overhand grip.\n2. While keeping your arms straight, slowly elevate the barbell up and over your head, squeezing your shoulders on the way up, and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8266L, "Kettlebell Alternating Hang Clean", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking two kettlebells and placing them in front of your feet and pushing your glutes out back.\n2. Then clean press one the kettlebell in your right arm to your shoulder and keep the other kettlebell in a hanging position.\n3. Return the right kettlebell back to the hanging position and repeat the exercise with the opposite hand.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(8267L, "Barbell Press on Stability Ball", listOf(MuscleGroup.SHOULDERS), Equipment.BARBELL, "1. Start by sitting upright on a stability ball with your feet in front of you and a weighted barbell rested upon your collarbone held in a shoulder width overhand grip.\n2. Slowly push the bar upward until your arms are fully extended above your head, squeezing your shoulders and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8268L, "Kettlebell One-Arm Split Jerk", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking a kettlebell in one hand and clean pressing it to your shoulder with palms facing out in front of you.\n2. Bend down at your knees and keep your chest and back straight.\n3. With your momentum, thrust the leg on the same side of the kettlebell back so that you are resting upon your heel and keep the front leg still bent with weight upon that leg.\n4. As you shift your legs, thrust the kettlebell in an overhead press.\n5. Hold onto this position for a few seconds and then return back to the starting point.\n6. Repeat this exercise for as many repetitions as needed."),
        Exercise(8269L, "Dumbbell Kneeling Lateral Raise (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by kneeling on an exercise ball, keeping your body upright with your arms at your sides holding a dumbbell in each hand.\n2. Slowly extend and lift your arms to about shoulder height and then return back to the start, repeating for as many reps and sets as desired."),
        Exercise(8270L, "Dumbbell One-Arm Arnold Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start by sitting on an exercise ball with a dumbbell in each hand.\n2. Elevate the dumbbells up towards your shoulders with your palms facing towards you in an Arnold Press position.\n3. Slowly press one of the dumbbells up towards the ceiling, rotating your wrist outward, until your arm is fully extended.\n4. Then return back to the starting position, rotating your wrist back inward, and repeat for as many reps and sets as desired."),
        Exercise(8271L, "Kettlebell One-Arm Jerk", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking a kettlebell in one hand and clean pressing it to your shoulder.\n2. Perform a squat and dip your body at the knees keeping your chest and back straight.\n3. As you perform this movement, use your momentum to thrust the kettlebell overhead.\n4. Hold onto this position for a few seconds then return back to the starting point with the kettlebell clean pressed at the shoulder.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8272L, "Kettlebell Jerk", listOf(MuscleGroup.SHOULDERS), Equipment.KETTLEBELL, "1. Start off by taking a kettlebell in both hands and clean pressing them to your shoulder.\n2. Perform a squat and dip your body at the knees keeping your chest and back straight.\n3. As you perform this movement, use your momentum to thrust the kettlebells overhead.\n4. Hold onto this position for a few seconds then return back to the starting point with the kettlebells clean pressed at the shoulder.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(8273L, "Dumbbell One-Arm Posterior Fly on Stability Ball", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off sitting on a stability ball with both feet together, your chest close to your knees and arms hanging down in front with a dumbbell in one hand.\n2. While maintaining a flat back, lift the weight to shoulder height allowing the arm to bend slightly and hold for a count, as the other arm stays in front of you.\n3. Return back to the starting position and repeat for as many reps and sets desired."),
        Exercise(8274L, "Dumbbell One-Arm Lateral Raise (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting straight up on a stability ball with both feet together and each hand holding a dumbbell.\n2. Elevate one of the dumbbells to shoulder height, keeping the dumbbell straight during the entire motion then slowly return back to the starting position.\n3. Then alternate with the opposite arm with the dumbbell to shoulder level.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8275L, "Band Shoulder Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.BANDS, "1. Begin by sitting on an exercise ball that is placed on top of a stretched band with a grip held in each hand and keeping your feet flat on the floor.\n2. When balanced slowly press the bands upward so that they are elevated over your head and hold this position for a count and return back to the start.\n3. Repeat for as many reps and sets as desired."),
        Exercise(8276L, "Dumbbell Alternating Shoulder Press (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting on top of a stability ball with your feet planted firmly on the floor in front of you, arms bent by your head at 90-degrees and dumbbells in each hand.\n2. Raise one of the dumbbells slightly and elevate them over your head completely keeping the other next to your head in position.\n3. Keep your arm straight at the top and hold motion for a count then return back to the starting position.\n4. When you return back down with the first weight, elevate up with the opposite arm and perform the same motion.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8277L, "Dumbbell Seated Shoulder Raise (Stability Ball)", listOf(MuscleGroup.SHOULDERS), Equipment.DUMBBELL, "1. Start off by sitting on top of a stability ball with your feet planted firmly on the floor in front of you.\n2. Raise both dumbbells, keeping both arms straight, until dumbbells are parallel to the floor.\n3. Keep your arms straight at the top and hold movement for a count then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),

        // TRICEPS
        Exercise(8300L, "Cable Tricep Pushdown (Rope)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Stand in front of a high pulley cable machine with a rope attachment.\n2. Grasp the rope with a neutral grip and pull your elbows down to your sides.\n3. Extend your arms downward by contracting your triceps.\n4. Hold for a count at the bottom, then slowly return to the starting position."),
        Exercise(8301L, "Cable Tricep Pushdown (V-Bar)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Stand in front of a high pulley cable machine with a V-bar attachment.\n2. Grasp the V-bar with a shoulder-width grip.\n3. Pull down by extending your arms and contracting your triceps.\n4. Hold briefly at the bottom, then slowly return to start."),
        Exercise(8302L, "Cable Rope Overhead Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Attach a rope to a high pulley cable machine.\n2. Stand facing the machine with one hand on each side of the rope.\n3. Reach your arms up and overhead.\n4. Slowly lower the rope behind your head by bending your elbows.\n5. Extend your arms back up to the starting position."),
        Exercise(8303L, "Dip", listOf(MuscleGroup.TRICEPS, MuscleGroup.CHEST), Equipment.BENCH, "1. Grip the dip bars and lift yourself up until your arms are fully extended.\n2. Lower your body by bending your elbows until your shoulders are below your elbows.\n3. Push yourself back up to the starting position by extending your arms."),
        Exercise(8304L, "Dumbbell Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Sit on a bench and hold a dumbbell with both hands.\n2. Extend your arms straight up.\n3. Lower the dumbbell behind your head by bending your elbows.\n4. Pause, then extend your arms back up to start."),
        Exercise(8305L, "Cable One-Arm Tricep Pushdown", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Attach a handle to a high pulley cable machine.\n2. Face the machine and grasp the handle with one hand.\n3. Pull down by extending your arm while keeping your elbow close to your side.\n4. Hold at the bottom, then slowly return to starting position."),
        Exercise(8306L, "Machine Dip", listOf(MuscleGroup.TRICEPS), Equipment.MACHINE, "1. Sit in a dip machine and grasp the handles.\n2. Lift yourself by extending your arms.\n3. Lower your body by bending your elbows.\n4. Push back up to the starting position."),
        Exercise(8307L, "Barbell Bench Press (Close Grip)", listOf(MuscleGroup.TRICEPS, MuscleGroup.CHEST), Equipment.BARBELL, "1. Lie on a flat bench and grab the barbell with a close grip (hands shoulder-width apart).\n2. Press the barbell up over your chest.\n3. Lower the barbell slowly to your chest.\n4. Press it back up to starting position."),
        Exercise(8308L, "Machine Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.MACHINE, "1. Sit at a tricep extension machine.\n2. Grab the handles and extend your arms.\n3. Lower the handles by bending your elbows.\n4. Extend your arms back to starting position."),
        Exercise(8309L, "Bench Dip", listOf(MuscleGroup.TRICEPS), Equipment.BENCH, "1. Place your hands on the edge of a bench.\n2. Lift your body off the bench with arms extended.\n3. Lower your body by bending your elbows.\n4. Push back up to starting position."),
        Exercise(8310L, "Dumbbell One-Arm Tricep Kickback", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Hold a dumbbell in one hand.\n2. Bend forward at the waist.\n3. Extend your arm back by straightening your elbow.\n4. Hold, then return to starting position."),
        Exercise(8311L, "Dumbbell One-Arm Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart, back straight.\n2. Hold dumbbell in hand with palms facing up.\n3. Raise dumbbell over head.\n4. Lower in arc behind head to spine level.\n5. Hold position.\n6. Raise back up.\n7. Switch arms."),
        Exercise(8312L, "Dumbbell Tricep Extension (Floor, Supine)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Lie flat on mat with feet on floor.\n2. Grab dumbbells in each hand.\n3. Raise dumbbells at arms length over shoulders.\n4. Lower in arc until forearms touch biceps.\n5. Return to starting position."),
        Exercise(8313L, "Cable Rope High Pulley Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Set up high cable pulley with rope extension.\n2. Stand back to machine with neutral grip.\n3. Bend down waist so body is almost parallel with floor.\n4. Push rope out until arms fully extended.\n5. Return to starting position."),
        Exercise(8314L, "Cable Tricep Kickback", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Set up handle on low pulley cable machine.\n2. Bend body parallel with ground facing machine.\n3. Grab handle, bring to side, tuck elbow in.\n4. Extend arm back as far as possible.\n5. Return to starting position."),
        Exercise(8315L, "Dumbbell Tricep Extension (Supine)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Lie on flat bench with back pressed against it.\n2. Feet flat on floor.\n3. Hold dumbbells in each hand, palms facing inward.\n4. Extend arms straight up.\n5. Keeping upper arms stationary, lower dumbbells toward head.\n6. Pause at bottom.\n7. Extend back to start."),
        Exercise(8316L, "Barbell Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Lie down on bench with head at one end.\n2. Grasp barbell with underhand grip.\n3. Move arms beyond head keeping them in straight line.\n4. Bending only elbows, slowly lower and raise barbell."),
        Exercise(8317L, "Barbell Skull Crusher (Reverse Grip)", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Set up weighted barbell or EZ bar.\n2. Hold above chest laying with back flat on bench.\n3. Slowly lower weight down toward head until almost touching.\n4. Return to starting position."),
        Exercise(8318L, "Dumbbell Tricep Kickback", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart, knees bent.\n2. Hold dumbbells with elbows bent 90-degrees.\n3. Bend body forward so dumbbells parallel with legs.\n4. Lift dumbbells behind you to feel stretch.\n5. Hold and return."),
        Exercise(8319L, "Cable High Pulley Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Set up high cable pulley machine with straight bar.\n2. Stand back to machine with overhand grip.\n3. Bend down so body is almost parallel with floor.\n4. Push bar out until arms fully extended.\n5. Return to starting position."),
        Exercise(8320L, "Dumbbell Seated One-Arm Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Sit on bench with back straight, abs drawn in.\n2. Grab dumbbell and place behind neck with elbow bent.\n3. Slowly extend arm straight up over head.\n4. Return to starting position."),
        Exercise(8321L, "Cable One-Arm Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Attach handle to low cable pulley machine.\n2. Stand with back to weight stack, feet shoulder-width apart.\n3. With left hand, reach behind and grasp handle.\n4. Place right hand on left elbow.\n5. Extend left arm straight up, lower to starting position.\n6. Repeat and switch arms."),
        Exercise(8322L, "Cable One-Arm Tricep Pushdown (Reverse Grip)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Set up handle on high cable pulley machine.\n2. Face machine and grab handle with underhand grip.\n3. Pull down so elbow is tucked in at side and hand is around chest level.\n4. Extend arm down as far as possible.\n5. Return to starting position."),
        Exercise(8323L, "Dumbbell Press (Close Grip)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Lay with back on flat bench, feet in front.\n2. Hold dumbbell in each hand elevated above chest.\n3. Slowly lower dumbbells to chest, keeping them close together without touching.\n4. Return to starting position."),
        Exercise(8324L, "Dumbbell Incline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Grab dumbbell in each hand and lie against incline bench facing up.\n2. Extend arms over shoulders with palms facing each other.\n3. Slowly lower dumbbells behind head by bending elbows.\n4. Hold position.\n5. Raise arms back up to starting position."),
        Exercise(8325L, "Barbell JM Press", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Place back flat on bench as if performing close grip bench press.\n2. Make sure bar is above upper part of chest.\n3. Lower bar down toward chest as if performing lying triceps extension.\n4. Push bar back up into position."),
        Exercise(8326L, "Tricep Push-Up", listOf(MuscleGroup.TRICEPS), Equipment.BODYWEIGHT, "1. Kneel on floor or mat, place hands with thumbs together.\n2. Raise body up on toes.\n3. Draw abs in and keep back and neck straight.\n4. Slowly lower body toward floor until nearly touching ground.\n5. Raise body back up."),
        Exercise(8327L, "Barbell Overhead Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Stand with feet shoulder-width apart, back straight.\n2. Hold barbell or EZ Curl bar about 6-8 inches apart with palms facing up.\n3. Raise bar over head.\n4. Slowly lower bar in arc behind head toward back.\n5. Bring bar back up to starting position."),
        Exercise(8328L, "EZ Bar French Press", listOf(MuscleGroup.TRICEPS), Equipment.EZCURLBAR, "1. Take weighted EZ bar with neutral grip.\n2. Elevate bar over top of head with arms straight.\n3. Slowly lower bar behind head in back and semi-circular motion.\n4. Squeeze triceps as lowering bar.\n5. Return to starting position."),
        Exercise(8329L, "Dual Cable Triceps Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start off by standing with the cable machine at your back.\n2. Grab onto overhead cables that are attached to a pulley machine.\n3. Grab each cable with the opposite hand so that your arms are criss-crossed.\n4. Extend your arms down.\n5. Return to starting position."),
        Exercise(8330L, "Dumbbell Alternating Tricep Kickback", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by standing with your feet shoulder width apart, knees bent at around 25-degrees.\n2. Hold dumbbells with your elbows bent at 90-degrees.\n3. Bend body forward so dumbbells parallel with legs.\n4. Lift dumbbells behind you to feel stretch.\n5. Hold and return.\n6. Alternate arms."),
        Exercise(8331L, "Smith Machine Bench Press (Close Grip)", listOf(MuscleGroup.TRICEPS, MuscleGroup.CHEST), Equipment.SMITH, "1. Use the Smith machine close grip bench press exercise.\n2. The smith machine close grip bench press exercise uses a close grip to isolate the triceps and also work the chest muscles.\n3. Lie on the bench beneath the bar.\n4. Grip the bar close together.\n5. Press and lower the bar.\n6. Extend arms and lower with triceps."),
        Exercise(8332L, "Barbell Seated Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start by sitting on a short back chair with your feet firmly placed on the floor and your back straight.\n2. Grab an EZ, Curl bar or barbell with a grip about 6 inches apart.\n3. Extend your arms up.\n4. Lower behind your head by bending elbows.\n5. Extend back to starting position."),
        Exercise(8333L, "Tricep Stretch", listOf(MuscleGroup.TRICEPS), Equipment.BODYWEIGHT, "1. Stand straight up with your arms at your sides and feet close together.\n2. Reach up with both hands and extend them up and behind your head.\n3. Stretch your triceps."),
        Exercise(8334L, "EZ Bar Incline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.EZCURLBAR, "1. Start by grabbing onto a barbell with a close grip (4 to 6 inches apart) and lie on an incline bench, holding the barbell over your head.\n2. Extend arms over shoulders.\n3. Slowly lower barbell behind head by bending elbows.\n4. Hold position.\n5. Raise arms back up to starting position."),
        Exercise(8335L, "Dumbbell Tate Press", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by lying flat on a bench with your head at one end and your feet firmly planted on the floor at the other end.\n2. Hold a dumbbell in each hand so your palms are faced towards your feet.\n3. Press the dumbbells up.\n4. Lower to chest level.\n5. Repeat."),
        Exercise(8336L, "Cable Reverse Grip Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Begin by attaching a bar to a low pulley cable machine.\n2. Lie with your back on an inline bench with your feet flat on the floor.\n3. Grab the bar with an underhand grip.\n4. Lower the bar behind your head.\n5. Extend arms back up."),
        Exercise(8337L, "Dumbbell Bent-Over Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start off with a dumbbell in each hand.\n2. Bend your knees and bring your upper body down and forward.\n3. Keep the arms at your waist with dumbbells parallel from the floor.\n4. Raise the dumbbells up and out by extending your arms.\n5. Lower dumbbells behind head by bending elbows.\n6. Return to starting position."),
        Exercise(8338L, "EZ Bar Tricep Extension (Close Grip)", listOf(MuscleGroup.TRICEPS), Equipment.EZCURLBAR, "1. Start by lying flat on a bench with your head at one end and feet planted on the floor on the other end.\n2. Grab an ez-bar or barbell with a grip about 8 inches apart.\n3. Lower the bar behind your head.\n4. Pause.\n5. Return to starting position."),
        Exercise(8339L, "Weighted Bench Dip", listOf(MuscleGroup.TRICEPS), Equipment.BENCH, "1. Sit on inside of one of two benches placed parallel, slightly less than leg's length away.\n2. Place hands on edge of bench.\n3. Straighten arms, slide rear end off of edge of bench and position heels on adjacent bench with legs straight.\n4. Lift body up.\n5. Lower body down.\n6. Push back up."),
        Exercise(8340L, "Dumbbell Incline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by sitting your back flat on an incline bench with your feet on the floor in front of you, holding a dumbbell on your legs.\n2. Extend arms over shoulders.\n3. Slowly lower dumbbell behind head by bending elbows.\n4. Hold position.\n5. Raise arm back up."),
        Exercise(8341L, "Dumbbell One-Arm Tricep Kickback", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start off with a dumbbell in one hand.\n2. Bend your knees and bring your upper body down and forward.\n3. Keep the arm with the dumbbell at your waist and the other on your thigh for support.\n4. Extend arm back by straightening elbow.\n5. Hold and return."),
        Exercise(8342L, "Dumbbell Decline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start off by lying face up (back flat) on a decline bench with a dumbbell in each hand.\n2. Extend your arms so they are perpendicular to your chest.\n3. Keeping your elbows in one place, lower your hands so the dumbbells are lowered near your head.\n4. Hold.\n5. Return to starting position."),
        Exercise(8343L, "Barbell Tricep Press (Close Grip)", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start by lying on a flat bench with your head at one end and holding a barbell with a close grip, with an overhand grip, above your shoulders as this will be your starting position.\n2. Press the barbell up.\n3. Lower behind head by bending elbows.\n4. Return to starting position."),
        Exercise(8344L, "Barbell Incline Bench Press (Close Grip)", listOf(MuscleGroup.TRICEPS, MuscleGroup.CHEST), Equipment.BARBELL, "1. Start by laying back on an incline bench press with your feet flat on the floor in front of you, grabbing the barbell with a close overhand grip.\n2. Press the barbell up.\n3. Lower toward chest.\n4. Press back up."),
        Exercise(8345L, "Dumbbell Tricep Extension (Supine)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by laying with your back on a flat bench with your legs in front of you, holding a single dumbbell up above your chest.\n2. Slowly lower the dumbbell to your head, bending only at your elbows and squeezing your triceps.\n3. Return to starting position."),
        Exercise(8346L, "Cable Tricep Kickback", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start by setting up a low pulley cable machine with either a long rope or two single grip handles.\n2. Next, grasp either the rope or handles with a neutral grip.\n3. Take a few steps back from the machine.\n4. Extend arm back.\n5. Hold.\n6. Return to starting position."),
        Exercise(8347L, "Dumbbell Alternating Kickback", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Begin by sitting up straight on a flat bench with your feet shoulder width apart, holding a dumbbell in each hand.\n2. Move your back down towards the floor so that your chest is resting on your thighs.\n3. Bring the dumbbells to your sides and tuck your upper arms towards your body.\n4. Slowly raise one dumbbell up behind you until your arm is fully extended and squeeze your tricep.\n5. Hold for a count then return back to the starting position.\n6. Repeat for as many reps and sets as desired.\n7. Switch arms."),
        Exercise(8348L, "Cable Incline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start by placing an incline bench facing away from a cable pulley and attaching a short straight bar to the pulley, adjusting the height so that your arms can extend fully.\n2. Lie face up (back flat) on the bench and grasp the bar with a narrow overhand grip.\n3. Starting with your elbows bent overhead, slowly lower the bar towards your feet.\n4. Pause at the bottom and then return to starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8349L, "Dumbbell Alternating Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by laying down on flat bench with your feet on the floor in front of you, holding a dumbbell in each hand in a neutral grip elevated above your head.\n2. Slowly extend one arm upward.\n3. Maintain the same elbow position during the movement.\n4. Return back to the starting position and repeat with the opposite arm.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8350L, "Cable One-Arm Tricep Kickback (Reverse Grip)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start by setting up a handle on a low pulley cable machine.\n2. Grab one of the handles with an underhand grip.\n3. Keep your back bent so that it is parallel to the floor.\n4. Bring your elbow up as high as possible and tight to your side then extend it out, squeezing your tricep and holding for a count.\n5. Return back to the starting position.\n6. Repeat for as many reps and sets as desired and repeat on opposite side."),
        Exercise(8351L, "Dumbbell Cross Tricep Extension (Supine)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by lying on a flat bench with your head at one end and your feet panted firmly on the floor on the other end.\n2. Grab a dumbbell in each hand, with a palms up grip.\n3. Raise it over your body.\n4. While keeping your upper arms and elbows still, lower the dumbbell slowly over your face bending only your elbow.\n5. Slowly raise the dumbbell back to the starting position and repeat with your other arm.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8352L, "Barbell Tricep Press (Supine)", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start by lying on a flat bench with your head at one end and feet planted firmly on the floor at the other end.\n2. Grab a EZ or Curl bar with an overhand grip.\n3. Raise the bar straight up over your shoulders, keeping your elbows close in.\n4. Slowly lower the bar in an arc over your head until you feel a stretch in your tricep muscle.\n5. Return the bar to the starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8353L, "Single-Leg Bench Dip", listOf(MuscleGroup.TRICEPS), Equipment.BENCH, "1. Begin by setting up a flat bench and positioning yourself in between the bench so that your hands are about shoulder width apart on the bench.\n2. Move your feet out in front of you so that your legs are bent.\n3. Extend one leg straight and hold throughout the exercise.\n4. Straighten out your arms on the bench so that you are elevated and tension is placed on your triceps.\n5. Slowly lower your upper body down towards the floor with your elbows so that they are at level with your shoulders.\n6. Hold for a count, squeezing your triceps and return back to the starting position.\n7. Repeat for as many reps and sets as desired.\n8. Switch to other leg."),
        Exercise(8354L, "Cable Lying Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start off by placing a flat bench with the end towards a weight stack and attaching a short straight bar to the pulley and lower the pulley to the bottom of the stack.\n2. Lie face up (back flat) on the bench and grasp the bar with a narrow overhand grip.\n3. Starting with your arms extended lower the bar towards the stack by bending your elbows.\n4. Slowly extend your arms upright and return to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8355L, "Tricep Side Stretch", listOf(MuscleGroup.TRICEPS), Equipment.BODYWEIGHT, "1. Start by standing up straight with your feet shoulder width apart and your arms rested at your sides.\n2. Then bring your right arm across your body and above your left shoulder.\n3. With your opposite left hand, hold the elbow of your right arm until you feel a stretch in your tricep, holding for about 15 to 30 seconds.\n4. Return back to the starting position and repeat for as many sets and however long you desire.\n5. Repeat with other side."),
        Exercise(8356L, "Dumbbell Rotational Bench Press", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by laying down on a flat bench with a dumbbell rested in each hand in the starting position of a dumbbell chest press with the dumbbells rested at around shoulder level.\n2. Slowly elevate the dumbbells up and above your chest, rotating in during the process, squeezing your triceps and hold for a count when the weights are above chest level.\n3. Hold for a count then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8357L, "Cable Rope Incline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start by setting up an incline bench in front of a low pulley cable machine and attach a rope extension for the exercise.\n2. Sit down facing away from the machine, holding the rope with an overhand grip behind your head as this will be your starting position.\n3. Slowly push the rope above your head, squeezing your triceps and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8358L, "Barbell Rear Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start by laying down with your back on a flat bench, feet on the floor in front of you, holding a weighted barbell above your head.\n2. Keep your elbows fixed in one position, slowly lower the bar down until it is almost touching the top of your head, squeezing your triceps and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8359L, "Dumbbell Seated One-Arm Supported Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by laying flat with your back on a bench holding a dumbbell in one hand at arms length, above your head, and the inside of your hand facing towards your face with a supinated grip.\n2. Take your opposite hand and place it underneath your elbow for support.\n3. Slowly lower the dumbbell down towards your face.\n4. Hold this position for a count.\n5. Slowly lift the dumbbell back upward squeezing your triceps.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8360L, "EZ Bar Seated Reverse Grip French Press", listOf(MuscleGroup.TRICEPS), Equipment.EZCURLBAR, "1. Start by loading up a weighted barbell or EZ bar with the weight that you would like to perform for this exercise.\n2. Sit down on a the end of a flat bench and this will be your starting position.\n3. Grab the bar with an underhand grip, lift it above your head.\n4. Then slowly while keeping your elbows close to your body, lower the weight behind your head while squeezing your triceps and hold for a count.\n5. Return back to the starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8361L, "Cable One-Arm Tricep Extension (Kneeling)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start by attaching a stirrup handle to a cable pulley and adjust the pulley up high.\n2. Kneeling on your left knee (with the left side of your body turned towards the machine), keep your right bent and the upper portion of your thigh parallel to the floor.\n3. With your right elbow and upper arm pressed against your inner thigh just above your knee, pull the cable down towards the floor in a slight arcing motion.\n4. Slowly to return to starting position.\n5. Repeat for as many reps and sets as desired.\n6. Switch arms and repeat the steps."),
        Exercise(8362L, "Barbell Reverse Tricep Bench Press", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start off lying on a flat bench with your head at one end and your feet placed firmly on the floor at the other end.\n2. Grabbing a barbell with a reverse grip about 16 inches apart and Move the bar over your chest.\n3. Extend your arms fully raising the bar fully and then lower the bar to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8363L, "Dumbbell One-Arm Tricep Extension (Reverse Grip)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by placing a handle on a low cable pulley machine and placing a flat bench in front of the machine.\n2. Sit down on the bench with your back facing the machine, grabbing the handle with one hand and extending it over your head, as this will be your starting position.\n3. Slowly lower the weight behind your head, squeezing your tricep and holding for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8364L, "Dumbbell One-Arm Tricep Extension (Pronated)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by lying flat on a bench with your head at one end and your feet placed firmly on the floor.\n2. Grab a dumbbell in one hand and raise it to a position above your chest, your palm should be facing your feet.\n3. Place your free hand under the shoulder to support your other arm.\n4. Slowly lower the weight moving only your forearm and elbow towards and away from your chest.\n5. Return to the starting position and repeat.\n6. Switch with your other arm and repeat."),
        Exercise(8365L, "Dumbbell French Press (Stability Ball)", listOf(MuscleGroup.TRICEPS), Equipment.EXERCISEBALL, "1. Start by sitting on an exercise ball with a dumbbell in each hand.\n2. Slowly roll down making sure that your head and shoulders are on the ball and your feet are planted firmly on the floor in front of you.\n3. Extend the dumbbell behind your head with bent elbows and hold.\n4. Then push the weight to the ceiling until your arm is fully extended.\n5. Return the dumbbell back to the starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8366L, "Dumbbell One-Arm Tricep Extension (Supinated)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start off lying flat in a bench with your head at one end and your feet placed firmly on the floor at the other end.\n2. Grab a dumbbell in one hand and raise it to a position above your chest, your palm should be facing the floor.\n3. Place your free hand under the shoulder to support your other arm.\n4. Slowly bend your elbow over your head with the weight moving only your forearm and elbow.\n5. Return to the starting position and repeat."),
        Exercise(8367L, "Dumbbell Seated Bent-Over Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. To begin this exercise; start off sitting down at the end of a flat bench.\n2. With your knees bent, move your upper chest forward so that they are closer to your knees.\n3. Take the dumbbells and place them at the sides next to your knees.\n4. Use your triceps to extend and lift the dumbbells up behind your back.\n5. Once the dumbbells are in the final position, hold and squeeze the triceps for a few seconds.\n6. Then return back to the starting position."),
        Exercise(8368L, "Barbell Pin Press", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start by setting up a flat bench between a power rack, setting the pins to about chest level and place the bar onto the pins.\n2. Lay flat on your back on the bench with the bar directly above your chest.\n3. Then tuck your feet underneath you, arch your back.\n4. Drive the bar up with as much force as possible, feeling a stretch within your triceps.\n5. Hold the bar at the peak position for a count then return back to the starting position."),
        Exercise(8369L, "Cable Tricep Extension (Kneeling)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start off by placing a bench sideways in front of a high pulley machine and attaching a straight bar onto the machine.\n2. Grab onto the straight bar with an overhand grip and kneel on the floor in front of the bench, keeping your back straight and head down.\n3. Positioning your elbows and your forearms above your head, push down on the bar in an arc motion so that your forearms are touching the bench.\n4. Hold onto this position for a count, isolating the triceps and return back up to the start.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8370L, "Smith Machine Incline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.SMITH, "1. Start by placing an incline bench underneath a smith machine at a 30 to 45 degree angle, highest end underneath the bar and lay down with your back flat on the bench, feet in front of you.\n2. Lift the bar off of the rack with an underhand grip.\n3. Slowly, while keeping your elbows fixed, lower the bar behind your head as far as possible, squeezing your triceps.\n4. Hold for a count then return back to the starting position."),
        Exercise(8371L, "EZ Bar Decline Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.EZCURLBAR, "1. Start off lying face up (back flat) on a decline bench and grabbing an EZ bar with an overhand grip.\n2. Extend your arms up and out so that they are perpendicular with your chest, keeping your elbows tucked in at one place.\n3. Slowly lower the EZ bar towards your head, feeling a stretch in your tricep muscle and hold the position for a count.\n4. Return back up to the starting position and repeat."),
        Exercise(8372L, "EZ Bar French Press (Reverse Grip)", listOf(MuscleGroup.TRICEPS), Equipment.EZCURLBAR, "1. Start by loading up a EZ bar with the weight that you would like to perform for this exercise.\n2. Hold the bar with an underhand grip, lift it above your head.\n3. Then slowly while keeping your elbows close to your body, lower the weight behind your head while squeezing your triceps and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8373L, "Medicine Ball Chest Throw (Supine)", listOf(MuscleGroup.TRICEPS), Equipment.MEDICINE_BALL, "1. Begin by lying on the floor, knees bent and feet flat on the floor with a medicine ball in your hands rested above your chest.\n2. Forcefully extend your elbows up and push the ball up directly above your body as high as possible.\n3. Follow through feeling a stretch on your triceps then catch the ball as it comes back down.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8374L, "Dumbbell Seated Bent-Over One-Arm Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by sitting on the edge of a bench with your feet rested flat on the floor in front of you and holding a dumbbell in your right hand.\n2. Slowly bring your right arm up to your side so that your dumbbell is almost parallel with your chest.\n3. Making sure that you keep your lower arm vertical and pressing your arm back in an arc.\n4. Hold this position for a count.\n5. Return back to the starting position.\n6. Switch arms and repeat."),
        Exercise(8375L, "Dumbbell One-Arm French Press (Stability Ball)", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by sitting on a stability ball with a dumbbell in one hand.\n2. Slowly roll down making sure that your head and shoulders are on the ball and your feet are planted firmly on the floor in front of you.\n3. Extend the dumbbell behind your head with bent elbow.\n4. Then push the weight up towards the ceiling until your arm is fully extended.\n5. Return the weight back down to the starting position and repeat."),
        Exercise(8376L, "Three Bench Dip", listOf(MuscleGroup.TRICEPS), Equipment.BENCH, "1. Start by setting up 3 benches, one horizontally in front of you and two vertically positioned at your sides for this exercise.\n2. Place your hands at the end of the two vertical benches while your feet are extended out and heels are resting in the middle of the horizontal bench.\n3. Push up with your arms so that your body is elevated and arms straight.\n4. Then slowly lower your body down until your elbows are at shoulder level and hold for a count.\n5. Return back to the starting position."),
        Exercise(8377L, "Stability Ball Weight Plate Pullover", listOf(MuscleGroup.TRICEPS), Equipment.EXERCISEBALL, "1. Start off grabbing a weight plate and sit on an exercise ball with your feet planted firmly on the floor in front of you.\n2. Lower your body so your upper abs are the only part of your body supported on the ball.\n3. Bring the weight plate to your chest with your arms extend.\n4. In an arcing motion raise the weight plate over and behind your head towards the floor until you start to feel a stretch in your core, back and chest muscles.\n5. Hold the position for a count.\n6. Return to starting position and repeat."),
        Exercise(8378L, "Stability Ball Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by laying on your back on a stability ball with the top of the ball underneath your upper back, your feet firmly on the floor and holding a dumbbell in one hand.\n2. Slowly raise your arm with the dumbbell straight up towards the ceiling and keeping the other arm at your side.\n3. Bend your arm and bring the weight slowly down behind your head feeling a stretch in your tricep and hold for a count.\n4. Then bring the weight back up to the starting position and repeat."),
        Exercise(8379L, "Weighted Three Bench Dip", listOf(MuscleGroup.TRICEPS), Equipment.BENCH, "1. Start by setting up 3 benches, one horizontally in front of you and two vertically positioned at your sides for this exercise.\n2. Place your hands at the end of the two vertical benches while your feet are extended out and heels are resting in the middle of the horizontal bench.\n3. Then place a weight plate on your hips.\n4. Push up with your arms so that your body is elevated and arms straight.\n5. Then slowly lower your body down until your elbows are at shoulder level and hold for a count.\n6. Push back up.\n7. Repeat for as many reps and sets as desired."),
        Exercise(8380L, "Cable Low Tricep Extension (Supine)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start by attaching a rope to the cable pulley at of a seated row station.\n2. Lie on the bench or floor with your head facing the weight stack.\n3. Grab the rope with your palms facing each other and raise your arms over your chest, with your forearms parallel to the floor at a 90 degree angle.\n4. Slowly extend your arms upward squeezing your triceps.\n5. Return to starting position and repeat."),
        Exercise(8381L, "Smith Machine Reverse Bench Press (Close Grip)", listOf(MuscleGroup.TRICEPS, MuscleGroup.CHEST), Equipment.SMITH, "1. Start by setting up a smith machine for the close grip bench press exercise by placing a flat bench underneath the bar and laying down with your back flat on the bench, feet in front of you.\n2. Grab the bar with a reverse grip, palms facing inward.\n3. Then lift the bar off of the rack and slowly lower it down towards your chest.\n4. Keep your elbows tucked in at your sides, until the bar is almost touching your chest and hold for a count.\n5. Return back to the starting position."),
        Exercise(8382L, "Barbell Reverse Grip Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start by laying on an incline bench with your feet flat on the floor, holding a barbell with both hands over your eyes with palms facing inward.\n2. Slowly lower the barbell towards the top of your head feeling tension in your triceps.\n3. Hold this position for a count and return back to the start.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8383L, "Cable Rope Tricep Extension (Supine)", listOf(MuscleGroup.TRICEPS), Equipment.CABLE, "1. Start by setting up a rope attachment on a low pulley cable machine and laying on the floor with your head facing towards the machine and knees bent.\n2. Hold the rope with a neutral grip, keeping it close together, elevated behind your head as this will be your starting position.\n3. Slowly push the rope up and out in front of your body so that your arms are completely extended and squeeze your triceps.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8384L, "Towel Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.BODYWEIGHT, "1. Start by standing with your feet shoulder width apart, your back straight and your abs drawn in.\n2. Hold a towel or rope facing up behind and in back of your head.\n3. Have a partner hold the towel tight during the exercise so the resistance is constant.\n4. Lower your forearms down until they reach your biceps.\n5. Then slowly raise your arms back up to starting position.\n6. Repeat for as many reps and sets as desired."),
        Exercise(8385L, "Barbell Supine Reverse Extension", listOf(MuscleGroup.TRICEPS), Equipment.BARBELL, "1. Start by laying on your back on a flat bench with your feet on the floor in front of you, holding a weighted barbell or EZ bar behind your head dangling towards the floor.\n2. Slowly elevate the bar up and out so that it creates a straight line with your body and squeeze your triceps.\n3. Hold for a count then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(8386L, "Stability Ball Dip", listOf(MuscleGroup.TRICEPS), Equipment.EXERCISEBALL, "1. Start by sitting on an exercise ball and placing your hands on each side of the ball.\n2. Slowly, while maintaining your balance, lift your buttocks off of the ball, keeping your elbows tight at your sides.\n3. Bend at your elbows and perform a tricep dip, feeling a stretch and pull in your muscle.\n4. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(8387L, "Dumbbell Lunge Tricep Extension", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder width apart holding dumbbells behind your head.\n2. Lunge forward with one leg by bending at your hips and keeping the other leg straight.\n3. Keep most of the weight and focus positioning the dumbbells on the lunging leg and do an overhead tricep extension, feeling a stretch in your muscles.\n4. Lower the weights slowly back down and then return back to the starting position, repeating in the opposite direction on the other leg.\n5. Repeat for as many reps and sets desired."),
        Exercise(8388L, "Dumbbell Tricep Kickback with Stork Stance", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by standing on one leg bending the knee at 20-degrees and holding dumbbells in front of your chest with elbows bent at around 90-degrees.\n2. Slowly bend forward in your core raising one of your legs behind you creating a body line that is parallel with the floor.\n3. After gaining your balance, execute a tricep kickback by extending your elbows back and feeling a stretch in your triceps.\n4. Hold this position for a few seconds then return back to the starting position.\n5. Repeat for as many reps and sets desired."),
        Exercise(8389L, "Stability Ball Dumbbell Kickback", listOf(MuscleGroup.TRICEPS), Equipment.DUMBBELL, "1. Start by laying with your chest on a stability ball, knees on the ground and feet extended behind you, holding a dumbbell in each hand.\n2. Raise your elbows up as high as possible and tuck your arms in against your body as this will be your starting position.\n3. Extend your arms back as far as possible, squeezing your triceps and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(8390L, "Stability Ball Tricep Stretch", listOf(MuscleGroup.TRICEPS), Equipment.EXERCISEBALL, "1. Start by sitting on an exercise ball with your back straight and feet firmly on the floor.\n2. Slowly reach up with both of your hands, grasp them together, bring them over your head and touch your upper back feeling a stretch in your triceps.\n3. Hold this position for 15 to 30 seconds and return to the start.\n4. Repeat for as many reps and sets desired."),

        // BICEPS
        Exercise(3001L, "Dumbbell Alternating Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1. Start by standing with your feet shoulders width apart.\n2. Pick up the dumbbells using a palm inward grip.\n3. Curl each dumbbell alternating each time.\n4. Repeat for the desired amount of reps."),
        Exercise(3002L, "Barbell Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "1. Start off standing up straight with your feet shoulder-width apart, keeping your knees slightly bent and abs drawn in tight.\n2. Grab a barbell with a shoulder width underhand (palms up) grip.\n3. Slowly raise the bar towards your upper chest.\n4. Hold this position for a count and then return back to the starting position."),
        Exercise(3003L, "Dumbbell Alternating Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1. Start off standing with your feet shoulder-width apart.\n2. Grab a dumbbell in each hand with your palms facing inward and extend your arms out at the sides of your body.\n3. While keeping your elbows locked in at your sides, slowly lift your left arm in an arc motion towards your left shoulder.\n4. Repeat the same steps with your right arm."),
        Exercise(3004L, "Dumbbell Incline Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1. Start by taking an incline bench and adjusting it to a 45-degree incline angle.\n2. Once in position let your arms hang down at your sides and while keeping your elbows straight, raise the dumbbells up towards your head.\n3. In the top position, hold for a count and then return back to the starting position."),
        Exercise(3005L, "Cable Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.CABLE, "1. Start by attaching a short bar to a cable pulley at the bottom of the machine then stand with your feet shoulder width apart.\n2. Grab the bar with a close underhand grip, lower your arms down towards your thighs and then, by bending through your elbows, raise the bar up towards your upper chest."),
        Exercise(3006L, "Preacher Curl Machine", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1. Start off by adjust the seat of the bench so your arms are level with the top of the bench and resting your forearms against the bench and extend them fully.\n2. Grasp the bar underhand (palms up) and pull it towards your head, isolating and squeezing the bicep muscle."),
        Exercise(3007L, "EZ Bar Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "1. Start by standing up straight with your feet shoulder-width apart and your knees slightly bend.\n2. Grab onto the barbell in front of you with an underhand (palms up) grip and lower the bar until it is up against your thighs.\n3. Making sure that you keep your elbows still, raise the bar slowly up towards your chest."),
        Exercise(3008L, "Dumbbell Alternating Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by standing with your feet shoulders width apart. 2.) Pick up the barbells using a palm inward grip. 3.) Curl each barbell alternating each time. 4.) Repeat for the desired amount of reps."),
        Exercise(3009L, "Barbell Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "1.) Start off standing up straight with your feet shoulder-width apart, keeping your knees slightly bent and abs drawn in tight. 2.) Grab a barbell with a shoulder width underhand (palms up) grip. 3.) Slowly raise the bar towards your upper chest. 4.) Hold this position for a count and then return back to the starting position."),
        Exercise(3010L, "Dumbbell Alternating Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start off standing with your feet shoulder-width apart. 2.) Grab a dumbbell in each hand with your palms facing inward and extend your arms out at the sides of your body. 3.) While keeping your elbows locked in at your sides, slowly lift your left arm in an arc motion towards your left shoulder. 4.) Repeat the same steps with your right arm."),
        Exercise(3011L, "Dumbbell Incline Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by taking an incline bench and adjusting it to a 45-degree incline angle. 2.) Once in position let your arms hang down at your sides and while keeping your elbows straight, raise the dumbbells up towards your head. 3.) In the top position, hold for a count and then return back to the starting position."),
        Exercise(3012L, "Cable Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.CABLE, "1.) Start by attaching a short bar to a cable pulley at the bottom of the machine then stand with your feet shoulder width apart. 2.) Grab the bar with a close underhand grip, lower your arms down towards your thighs and then, by bending through your elbows, raise the bar up towards your upper chest."),
        Exercise(3013L, "Preacher Curl Machine", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Start off by adjust the seat of the bench so your arms are level with the top of the bench and resting your forearms against the bench and extend them fully. 2.) Grasp the bar underhand (palms up) and pull it towards your head, isolating and squeezing the bicep muscle."),
        Exercise(3014L, "EZ Bar Curl", listOf(MuscleGroup.BICEPS), Equipment.EZCURLBAR, "1.) Start by standing up straight with your feet shoulder-width apart and your knees slightly bend. 2.) Grab onto the barbell in front of you with an underhand (palms up) grip and lower the bar until it is up against your thighs. 3.) Making sure that you keep your elbows still, raise the bar slowly up towards your chest."),
        Exercise(3015L, "Barbell Preacher Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "1.) Start off by adjusting the seat of a preacher bench so that your arms are level with the top of the bench. 2.) Grab onto a bicep curl bar with an underhand (palms up) grip, keeping your arms shoulder-width apart, resting them against the bench, and extending them fully."),
        Exercise(3016L, "Dumbbell Concentration Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by sitting on the end of a flat bench with your feet flat and your legs spread in a V position. 2.) Grab a dumbbell in one of your hands with a palms up grip, placing this arm in between your legs and up against your inner thigh just above your knee."),
        Exercise(3017L, "Cable Rope Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.CABLE, "1.) Start by attaching a rope to a cable pulley to the bottom of the weight stack and stand in front of the machine with your feet shoulder width apart, your knees slightly bent and your abs drawn in. 2.) Grab the rope with a close underhand grip (palms facing up). 3.) Lower your arms fully to above your thighs and bending only your elbows, raise the rope to your upper chest."),
        Exercise(3018L, "Dumbbell Seated Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Begin by sitting up straight with your feet shoulder-width apart, abs tight, knees slightly bent and a dumbbell in each hand with a palms up grip. 2.) While holding the dumbbells, extend your arms at the side of your body, then slowly lift your arms up towards your chest until your forearms touch your biceps."),
        Exercise(3019L, "Dumbbell One-Arm Preacher Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by taking a preacher bench and adjusting the seat so that your arm is level with the top of the bench. 2.) Grab a dumbbell with an underhand (palms up) grip and rest your arm against the bench with your arm extended fully down. 3.) Slowly curl the dumbbell up towards your head, keeping your arm on the bench at all times."),
        Exercise(3020L, "Dumbbell Hammer Curl (Cross Body)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by standing up straight and grabbing a dumbbell in each hand with palms facing inward. 2.) While keeping your palms facing in, curl the dumbbell up towards the opposite shoulder, isolating the bicep and squeezing the muscle."),
        Exercise(3021L, "Cable One-Arm Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.CABLE, "1.) Start off by attaching a stirrup bar to a low cable pulley and standing on the side of the weight stack with your legs shoulder width apart and your knees slightly bent. 2.) Grasp the stirrup in one hand with an underhand grip (palms facing up) and lower the stirrup to the top of your thighs. 3.) Keeping your elbows still, curl the stirrup up towards your chest."),
        Exercise(3022L, "Dumbbell Zottman Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start off standing with your feet shoulder-width apart, your knees slightly bent and abs drawn in. 2.) Grab a dumbbell in each hand with your palms facing each other and hands at your sides. 3.) Curl your arms up turning your palms so they are facing down as the dumbbells reach your chest, squeezing your bicep muscles."),
        Exercise(3023L, "Dumbbell Alternating Seated Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by setting up a flat bench and then sit down on the bench, with a dumbbell in each hand and feet flat on the floor. 2.) Hold the dumbbells in an underhand grip with your palms facing up, then slowly lift one dumbbell up towards your shoulder, isolating the bicep and hold for a count."),
        Exercise(3024L, "Cable Reverse Curl", listOf(MuscleGroup.BICEPS), Equipment.CABLE, "1.) Start by grabbing onto a cable bar with a shoulder-width overhand grip. 2.) Keep your elbows down to your side and then raise the bar up towards your face, squeezing and isolating the biceps. 3.) Hold this position for a count and then return back to the starting position."),
        Exercise(3025L, "Dumbbell Incline Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start by sitting on an incline bench with a dumbbell in each hand, arms to your side, with your feet planted firmly in front of you. Keep your palms are facing in towards each other (i.e. hammer grip) throughout the exercise. Flex at your elbows bringing the weights up to your shoulders, isolating the forearms and biceps, until you feel tension in the muscles."),
        Exercise(3026L, "EZ Bar Preacher Curl (Close Grip)", listOf(MuscleGroup.BICEPS), Equipment.EZCURLBAR, "Start by setting up either weighted EZ bar with the weight that you would like to use to perform this exercise. Then sit down on the bench with your feet flat on the floor and arms extended out grabbing onto the bar with a close underhand grip. Slowly curl the bar up towards your shoulders, isolating and squeezing your shoulders. Return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3027L, "Cable Bicep Curl (Close Grip)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start by standing up straight in front of a low pulley cable machine with a straight bar attached to the machine, with your arms rested at your sides and feet flat on the floor. Grab the bar in a close underhand grip then slowly, then raise it up towards your shoulders, isolating the bicep and hold for a count. Return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3028L, "Dumbbell Seated Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start by setting up a flat bench and then sit down on the bench, with a dumbbell in each hand and feet flat on the floor. Hold the dumbbells in a neutral grip with your palms facing inward. Slowly lift the dumbbells up towards your shoulder, isolating the bicep and hold for a count. Return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3029L, "Dumbbell Alternating Incline Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start off by taking either a pre-set incline bench or an adjustable bench and setting it to a 45 degree angle. Grab a dumbbell in each hand, sit back on the bench with your feet planted firmly on the floor in front of you and hand your arms down at your sides. Keeping your elbows straight, raise your right arm up towards your head, isolating the bicep and squeezing the muscle. Hold the position for a count then lower down to the starting position. Repeat the same steps with your left arm."),
        Exercise(3030L, "Machine Bicep Curl (Reverse Grip)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start by sitting on a bicep curl machine that has rotating handles. Rest your arms over the padding keeping them straight and grab onto the handles with a overhand (reverse) grip. Slowly raise the handles up towards your shoulders, squeezing and isolating your biceps, and hold for a count. Return to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3031L, "Dumbbell Spider Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start by holding a dumbbell in each hand and position yourself lying face first on an inclined bench. Then extend your biceps down and out in front of you so that you are able to fully contract your biceps. Contract your biceps and curl the weights up towards your shoulders, squeezing your muscles in the process and isolating the biceps. Hold for a count when you reach the top position then return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3032L, "Barbell Bicep Curl (Wide Grip)", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "Start by standing with your feet shoulder width apart, your knees slightly bent and your abs drawn in. Grab a barbell with an underhand (palms up) grip as wide as you comfortably can and extend your arms fully against your thighs. Keeping your elbows straight, raise the bar towards your chest till your forearms touch your chest, squeezing your bicep muscle. Pause for moment and then return to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3033L, "Dumbbell Inner Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "To begin this exercise; sit down on a flat bench at the very edge with a dumbbell in each hand and elbows close to the pelvis. Keep the palms of the hands so that they are facing inward towards the body. Curl the dumbbell out and up, keeping the forearms lined up with the deltoids. Continue performing until the biceps are fully contracted and squeeze tightly, holding for a few seconds then bring back down to the starting positions. Repeat this exercise for as many repetitions as needed."),
        Exercise(3034L, "Dumbbell Reverse Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Stand with your feet shoulder width apart, your knees slightly bent and a your abs drawn in. Grasp a dumbbell in each hand with an overhand (palms facing down) grip. Keeping your arms at your side and your elbows steady. Lift the dumbbells up towards your shoulders. Pause for a moment and then return to the starting position."),
        Exercise(3035L, "Dumbbell Alternating Preacher Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start by sitting on a preacher curl bench with a dumbbell in each hand, resting your forearms upon the bench and feet flat on the floor. Hold the dumbbells with your palms facing towards you and let the weights fully extend out in front of you. Slowly elevate one of the dumbbells up towards your chest, squeezing and isolating your bicep, then hold for a count. Return back to the starting position and repeat with the opposite arm. Repeat for as many reps and sets as desired."),
        Exercise(3036L, "Dumbbell Rotational Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Begin by standing up straight with a dumbbell in each hand and your feet flat on the floor. Slowly curl on of the dumbbells up towards your shoulders. While curling it up, rotate the dumbbell from a neutral position to an underhand position and hold for a count. Return back to the starting position and repeat with the opposite arm. Repeat for as many reps and sets as desired."),
        Exercise(3037L, "Cable Incline Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start by setting up an incline bench in between two low pulley cable machines with handles attached to each machine. Sit with your back flat on the incline bench with each hand holding onto the cables and your feet flat on the floor. Keep your arms outstretched then slowly curl the cables in towards your chest, isolating your biceps, and hold for a count. Return back to the starting position and repeat for as many reps and set as desired."),
        Exercise(3038L, "Cable One-Arm High Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Begin by standing sideways next to a high pulley machine, arm extended out at about shoulder height and gripping the handle with one of your hands. Slowly curl the cable towards your head, isolating the bicep until you feel tension, and hold for a count. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(3039L, "Cable Dual Overhead Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start off by attaching a stirrup handle to each side of two high pulley cable machines and grab the handles with an under-hand grip (palms up), standing in between the machines with your feet shoulder width apart as this will be your starting position. Once in position extend your arms out to your sides, keeping your elbows steady and then slowly curl your biceps towards the side of your head, isolating and squeezing the biceps. Hold this position for a count while squeezing your biceps and then return back to the starting position."),
        Exercise(3040L, "EZ Bar Close Grip Curl", listOf(MuscleGroup.BICEPS), Equipment.EZCURLBAR, "Start by standing up straight with your feet shoulder width apart, knees slightly bent and abs drawn in. Grab an EZ bar with an underhand close grip on the inner-most part of the bar. Extend your arms fully against your thighs. Keeping your elbows straight, raise the bar towards your chest, squeezing your biceps as much as possible. Pause for moment and then return to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3041L, "Machine Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start by sitting on a bicep curl machine that has rotating handles. Rest your arms over the padding keeping them straight and grab onto the handles with a neutral (hammer) grip. Slowly elevate the handles up towards your shoulders, squeezing and isolating your biceps, and hold for a count. Return to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3042L, "Dumbbell Preacher Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start off by adjust the seat of the bench so your arms are level with the top of the bench. Grab a dumbbell in each hand with an underhand (palms facing up) grip. Picking up the dumbbells, rest your arms against the bench and extend them fully towards the floor. Keeping your arms on the bench at all times, curl the weight up towards your head, squeezing and isolating your biceps. Pause for a moment and then lower the weights back to starting position. Repeat for as many reps and sets as desired."),
        Exercise(3043L, "Cable Standing Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start by standing in front of a low pulley machine with a straight bar attached to it. Keeping your knees bent and back straight, grasp the bar with an underhand grip with your arms and hands extended. Make sure that you keep your upper arms tight up against your body and then slowly curl the bar up towards your chest until you feel tension on your biceps. Hold this position for a few seconds and then return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3044L, "Barbell Spider Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "The spider curl exercise utilizes the straight side of a preacher bench to increase the range of motion of the exercise."),
        Exercise(3045L, "Dumbbell Preacher Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "The dumbbell preacher hammer curl exercise combines a hammer curl with a preacher bench to isolate the bicep muscle and build bigger arms."),
        Exercise(3046L, "Dumbbell One-Arm Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Hold the dumbbell in an underhand grip with your palms facing up, then slowly lift the dumbbell up towards your shoulder, isolating the bicep and hold for a count."),
        Exercise(3047L, "Barbell Curl (Close Grip)", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "The close-grip standing barbell curl uses a barbell to help isolate the bicep during the curl."),
        Exercise(3048L, "Dumbbell Seated Alternating Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Hold the dumbbells in a neutral grip with your palms facing inward, then slowly lift one dumbbell up towards your shoulder, isolating the bicep and hold for a count."),
        Exercise(3049L, "Dumbbell One-Arm Preacher Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Hold the dumbbell in a neutral grip with your palms facing inward, then slowly lift the dumbbell up towards your shoulder, isolating the bicep and hold for a count."),
        Exercise(3050L, "Bicep Stretch", listOf(MuscleGroup.BICEPS), Equipment.BODYWEIGHT, "Extend your arms behind you and grabbing your hands together behind your back. Slowly raise your arms, turn your hands so that your palms are facing outward, and feel a stretch in the bicep."),
        Exercise(3051L, "Cable Drag Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Grab the bar in an underhand grip then slowly, keeping the bar as close as possible to your body, raise it up towards your shoulders, isolating the bicep and hold for a count."),
        Exercise(3052L, "Cable Preacher Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "The cable preacher curl exercise uses a special bench to support the triceps and isolate the biceps to build toner and bigger arms."),
        Exercise(3053L, "Barbell Bicep Drag Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "Then take the barbell and curl it towards your upper chest as in a way to 'Drag' the bar up."),
        Exercise(3054L, "Dumbbell Incline Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Bring your arms down to your sides, keeping your wrists as straight as possible (i.e. hammer grip), raise your wrists to your shoulders. Concentrate on squeezing your biceps as you raise up your arms."),
        Exercise(3055L, "Dumbbell One-Arm Preacher Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "The dumbbell one-arm preacher curl exercise is an intermediate-level bicep exercise where you use an incline bench to support the triceps and isolate the biceps."),
        Exercise(3056L, "Band Alternating Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.BANDS, "Curl your arms up and down in an alternating motion, keeping your body straight, and isolating the bicep muscle."),
        Exercise(3057L, "Dumbbell One-Arm Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Hold the dumbbell in a neutral grip with your palms facing inward, then slowly lift the dumbbell up towards your shoulder, isolating the bicep and hold for a count."),
        Exercise(3058L, "Cable Pulldown Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Slowly curl the bar down and behind your head, isolating your biceps, and hold for a count."),
        Exercise(3059L, "Cable Bicep Curl (Supine)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Pull the bar in an arc to your chest. Hold for a count by contracting your biceps, and then return to the starting position."),
        Exercise(3060L, "Weight Plate Reverse Curl", listOf(MuscleGroup.BICEPS), Equipment.WEIGHTPLATE, "Grab a plate in your hands with an overhand (palms down) grip at the 11:00 and 1:00 o'clock position. Keeping your elbows and arms at your side, curl the slowly up towards your head, squeezing and isolating the bicep muscle."),
        Exercise(3061L, "Barbell Drag Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "Grab the bar with a shoulder-width overhand grip (palms down) and extend your arms fully so they are against your thighs. Slowly raise your arms, palms down, to touch your chest."),
        Exercise(3062L, "Cable Seated Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Begin by placing a flat bench in front of a low pulley cable machine. Begin in a seated position with your feet flat on the floor and arms grasping onto a straight bar attached to the machine. 2.) Hold the bar with an underhand grip and let your arms rest between your thighs, keeping them still by squeezing with your legs. 3.) Slowly curl the bar up towards your shoulders, isolating the bicep, and hold for a count. 4.) Return back to the starting position. 5.) Repeat for as many reps and sets as desired."),
        Exercise(3063L, "Dumbbell Incline Spider Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by adjusting an incline bench to a 45-degree angle. 2.) Grasp dumbbells in each hand and lean face down against the bench, with your feet resting on the floor for support. 3.) Allow your arms to hang down at your sides. 4.) Keeping your elbow straight, raise the dumbbells up towards your head, contracting your biceps. 5.) In a controlled manner lower the weight and repeat."),
        Exercise(3064L, "Dumbbell High Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Stand up straight with a dumbbell in each hand, keeping feet about shoulder width apart, bringing your arms up to shoulder level and extend out in a T shape. 2.) Then slowly curl your biceps so that the dumbbells are brought to your head, isolating the muscle, and keeping your arms at shoulder level during the entire motion. 3.) Hold this position for a count then return back to the starting position. 4.) Repeat for as many reps and sets as desired."),
        Exercise(3065L, "Dumbbell Incline Alternating Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by setting up an incline bench to either a 30 or 45 degree angle and then sit with your back flat on the bench, with a dumbbell in each hand and feet flat on the floor. 2.) Hold the dumbbells in a neutral grip with your palms facing inward, then slowly lift one dumbbell up towards your shoulder, isolating the bicep and hold for a count. 3.) Return back to the starting position and repeat with the opposite arm. 4.) Repeat for as many reps and sets as desired."),
        Exercise(3066L, "Cable One-Arm Concentration Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Start by setting up a handle on a low cable pulley machine and then placing a flat bench in front of the machine. 2.) Sit down and grasp the handle with one hand, holding it in a concentration curl position. 3.) Slowly curl the cable up towards your shoulder, isolating the bicep, until you feel a stretch and tension in the muscle. 4.) Hold for a count then return back to the starting position. 5.) Repeat for as many reps and sets as desired."),
        Exercise(3067L, "Cable One-Arm Preacher Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Start off setting up either a handle on a low pulley cable machine and place a preacher bench in front of the machine. 2.) Grab onto the handle with an underhand grip, then sit down on the bench with your forearm rested over the padding and feet flat on the floor in front of you. 3.) Keep your arm extended out in front of you then slowly curl the handle up towards your chest, isolating your bicep and squeeze. 4.) Hold for a count then return back to the starting position. 5.) Repeat for as many reps and sets as desired."),
        Exercise(3068L, "EZ Bar Seated Curl (Close Grip)", listOf(MuscleGroup.BICEPS), Equipment.EZCURLBAR, "1.) Start by sitting on the end of a flat bench with your feet flat and your legs spread live a V. 2.) Bend forward at your waist keeping your back straight. 3.) Grasp a barbell in your hands with a close grip, palms facing up. 4.) With your elbow pressed against your inner thigh just above your knee, curl the bar up towards your chest. 5.) Slowly lower the bar to the starting position near the floor. 6.) Repeat for as many reps and sets as desired."),
        Exercise(3069L, "Dumbbell Bicep Curl (Supine)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start off lying on a flat bench with your head at one end and your feet planted firmly on the floor at the other end. 2.) Grabbing a dumbbell in each hand, palms facing in, bring your arms down to your sides, hanging off the bench. 3.) Slowly raise your arms up until they are level with your chest, then curl the dumbbells twisting your palms so your forearms touch your biceps. 4.) Hold this position for a count, isolating the bicep muscle and squeezing. 5.) Slowly lower your arms to the starting position. 6.) Repeat for as many reps and sets as desired."),
        Exercise(3070L, "Cable Rope One-Arm Preacher Curl (Hammer)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Start by setting up a rope extension attachment to a low pulley cable machine and placing a preacher bench in front of the machine. 2.) Grab hold of the rope with one arm in a neutral hammer grip, then sit down on the bench with your forearm rested over the padding and feet flat on the floor in front of you. 3.) Keep your arm extended out in front of you then slowly curl the bar up towards your chest, isolating your bicep and squeeze. 4.) Hold for a count then return back to the starting position. 5.) Repeat for as many reps and sets as desired."),
        Exercise(3071L, "Dumbbell One-Arm Incline Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by setting up an adjustable bench to an incline level so that you can comfortably rest your arm down the back of the headrest. 2.) Grab a dumbbell in one arm and extend it over the bench so that your forearm and tricep are rested upon the bench. 3.) Hold onto the top of the bench with the opposite arm to stabilize your body and to balance the weight. 4.) Slowly elevate the dumbbell up towards your shoulder, isolating the bicep and squeeze your muscle. 5.) Hold this position for a count then return back to the starting position. 6.) Repeat for as many reps and sets as desired."),
        Exercise(3072L, "Smith Machine Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.SMITH, "1.) Start by setting up a smith machine with the amount of weight you would like to perform for a bicep curl. 2.) Stand up straight in front of the machine grabbing the bar with an underhand grip. 3.) Slowly take the bar up off of the supports and lower it so that your arms are rested at your sides. 4.) Then curl the bar up towards your shoulders, isolating the bicep, and hold for a count. 5.) Return back to the starting position. 6.) Repeat for as many reps and sets as desired."),
        Exercise(3073L, "Cable Seated Overhead Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Start by setting up handles on two upper pulley cables machines and placing a vertical bench in between both machines. 2.) Grab each handle with an overhand grip and sit down on the middle of the bench keeping your arms extended out towards your sides. 3.) Slowly curl the cables in towards your head, isolating the bicep, and squeeze. 4.) Hold for a count then return back to the starting position. 5.) Repeat for as many reps and sets as desired."),
        Exercise(3074L, "Dumbbell Concentration Curl on Stability Ball", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "1.) Start by sitting on a stability ball with your feet spread apart, grasping a dumbbell in one hand and keeping in between your legs. 2.) Slowly lift the weight up towards your chest in a controlled movement, making sure that you isolate the bicep, hold for a 2 count and then lower back down to the starting position. 3.) Repeat for as many reps and sets as desired and then repeat with the other arm."),
        Exercise(3075L, "Dumbbell Squat to Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Stand with your feet shoulder-width apart, your knees slightly bent and your abs drawn in, holding a dumbbell in each hand. 2.) As you perform a squat, keep both arms extended holding the dumbbells. 3.) As you come out of the squat position, focus on extending the legs as you curl the dumbbells upward towards the shoulders. 4.) Pause for a moment and repeat for desired repetitions. Tips: 1.) Contract your biceps as you curl your arms up."),
        Exercise(3076L, "Dumbbell One-Arm Seated Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "1.) Start by setting up a flat bench and then sit down on the bench, with a dumbbell in one hand and feet flat on the floor. 2.) Hold the dumbbell in an underhand grip with your palms facing up, then slowly lift the dumbbell up towards your shoulder, isolating the bicep and hold for a count. 3.) Return back to the starting position. 4.) Repeat for as many reps and sets as desired."),
        Exercise(3077L, "Cable Seated Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Start by sitting up straight on a bench in front of a low pulley cable machine with a straight bar attached to the machine, with your arms rested at your sides and feet flat on the floor. 2.) Grab the bar in an underhand grip then slowly raise it up towards your shoulders, isolating the bicep and hold for a count. 3.) Return back to the starting position. 4.) Repeat for as many reps and sets as desired."),
        Exercise(3078L, "Barbell Concentration Curl (Close Grip)", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "1.) To begin this exercise; sit down on a flat bench at the very edge with a barbell. 2.) Keeping your knees bent at all times, pick up the barbell, curl the weight up and forward while squeezing and tightening your biceps as you exhale. 3.) The only part of your body that should be moving are the forearms as they bring the barbell to shoulder level. 4.) Hold the biceps in position for a few seconds then return back to the starting position as you inhale. 5.) Repeat this exercise for as many repetitions as needed."),
        Exercise(3079L, "Dumbbell Alternating Preacher Curl (Hammer)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "1.) Start by sitting on a preacher curl bench with a dumbbell in each hand, resting your forearms upon the bench and feet flat on the floor. 2.) Hold the dumbbells in a hammer or neutral grip and let the weights fully extend out in front of you. 3.) Slowly elevate one of the dumbbells up towards your chest, squeezing and isolating your bicep, then hold for a count. 4.) Return back to the starting position and repeat with the opposite arm. 5.) Repeat for as many reps and sets as desired."),
        Exercise(3080L, "Cable Squat Curl", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Set up low pulley cable with straight bar. Squat to parallel thighs. Curl bar to shoulders, hold, return. Repeat for desired reps."),
        Exercise(3081L, "Cable Rope Preacher Curl (Hammer)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Attach rope to low pulley cable. Sit on preacher bench, forearm on padding. Curl rope up to chest, squeeze, hold, return. Repeat."),
        Exercise(3082L, "Barbell Curl Against an Incline", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "Set incline bench at 45 degrees. Grip barbell shoulder-width. Raise bar to head, hold, return. Repeat."),
        Exercise(3083L, "Cable Bicep Curl (Supine Close Grip)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Place flat bench under cable stack. Lie on bench, head to stack. Grab bar palms down, arms up. Curl bar to chin, hold, return. Repeat."),
        Exercise(3084L, "Dumbbell One-Arm Seated Hammer Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Sit on bench, hold dumbbell palm inward. Lift to shoulder, hold, return. Repeat."),
        Exercise(3085L, "Dumbbell Incline Hammer Curl (Prone)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Elevate bench 30 degrees. Lie prone with dumbbells. Curl weights to shoulders, hold, return. Repeat."),
        Exercise(3086L, "Dumbbell Bicep Curl With Stork Stance", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Stand on one foot, extend other leg back. Hold dumbbells palms up. Curl arms up, squeeze, return, switch legs."),
        Exercise(3087L, "Dumbbell Forward Lunge with Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Hold dumbbells palms up, stand straight. Lunge forward, curl arms up to shoulders. Return, switch legs."),
        Exercise(3088L, "Cable High Curl (Supine)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Place flat bench near high pulley. Lie on back, head to stack. Grip bar palms in, arms over head. Pull bar down, hold, return."),
        Exercise(3089L, "Dumbbell Bicep Curl (Supine Wide Grip)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Lie flat on bench, feet on floor, arms out. Hold dumbbells palms up. Curl to shoulders, twist to underhand, hold, return."),
        Exercise(3090L, "Dumbbell Bicep Curl Step-Up", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Step onto box with one leg, raise other leg. Curl arms up to shoulders. Return, switch legs. Repeat."),
        Exercise(3091L, "Dumbbell Preacher Curl (Stability Ball)", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Lie over stability ball, chest on ball. Lift dumbbells to chest, hold, return. Repeat for reps."),
        Exercise(3092L, "Barbell Spider Curl (Prone)", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "Lie face down on high bench. Grip barbell palms up, arms extended. Curl arms to head, return. Repeat."),
        Exercise(3093L, "Barbell One-Arm Bicep Curl", listOf(MuscleGroup.BICEPS), Equipment.BARBELL, "Stand with knees bent. Grip bar with one hand, balanced. Curl bar to forearm, squeeze. Lower, switch arms."),
        Exercise(3094L, "Dumbbell Seated Alternating Bicep Curl (Stability Ball)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Sit on stability ball, feet flat. Lift one dumbbell to shoulder, squeeze. Return, alternate arms."),
        Exercise(3095L, "Cable One-Arm Preacher Curl (Reverse)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Set low pulley cable with handle. Sit on preacher bench, reverse grip. Curl handle to chest, squeeze. Repeat."),
        Exercise(3096L, "Dumbbell Reverse Spider Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Lie face down on incline bench. Hold dumbbells reverse grip. Curl weights to shoulders, squeeze. Repeat."),
        Exercise(3097L, "Dumbbell One-Arm Bicep Curl (Prone)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Elevate bench 30 degrees. Lie with legs extended, dumbbell in hand. Curl weight to shoulders, hold, return."),
        Exercise(3098L, "Dumbbell Lunge with Bicep Curl Bowling Motion", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start by holding a medicine ball or dumbbell in both hand with your palms facing up at shoulder height. Bring one foot back and into a lunge, keeping your front foot stationary and not letting your back knee touch the ground. While lunging bring the ball or dumbbells down and back as if you were bowling, feeling a stretch in your biceps. Bring your arm back up to the starting position, switch legs and repeat."),
        Exercise(3099L, "Dumbbell Hammer Curl on Stability Ball", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Start by sitting on an exercise ball with dumbbell in each hand rested at your sides. With both of your arms raise the weights up towards your shoulder, keeping the elbow close to your body and squeezing the bicep. Return back to the starting position in a slowed and controlled motion. Repeat for as many reps and sets desired."),
        Exercise(3100L, "Dumbbell Bicep Curl on Dome", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start by grabbing a dumbbell in each hand and sit on a dome, keeping your legs together and your knees bent. With you arms extended to your sides, curl and contract your biceps, bringing your forearms towards your shoulders, squeezing your bicep muscles. Slowly return to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3101L, "Dumbbell One-Arm Reverse Spider Curl", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start by grabbing a dumbbell in one hand, holding it with a reverse grip so that your palm is facing inward and position yourself lying face first on an inclined bench. Extend your bicep down and out in front of you so that you are able to fully contract your bicep and curl the weight up towards your shoulder, squeezing your muscle in the process and isolating the bicep. Hold for a count when you reach the top position then return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3102L, "Dumbbell One-Arm Hammer Curl (Prone)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Start by taking an adjustable bench and elevating it to around 30 degrees, with your legs extended behind you and toes on the floor, and your arms in front of you with a dumbbell in one hand. Hold the dumbbell in a neutral grip and let it hang towards the ground. Slowly elevate the weight up towards your shoulders, isolating your bicep, and hold for a count. Return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3103L, "Dumbbell Alternating Hammer Curl (Stability Ball)", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Start off by sitting on a stability ball with dumbbell in each hand rested at your sides. With one of your arms raise the weight up towards your shoulder, keeping the elbow close to your body and squeezing the bicep. Return back to the starting position and repeat with the other arm. Repeat for as many reps and sets desired."),
        Exercise(3104L, "Cable Dual Overhead Curl (Stability Ball)", listOf(MuscleGroup.BICEPS), Equipment.MACHINE, "Start by setting up handles on two cable pulley machines and placing a stability ball in between the machines. Place the handles in a position where it is at shoulder level when you sit down on the exercise ball. Grab the handles with an underhand grip and sit down on the exercise ball, keeping your body straight up, and arms extended out towards your sides. Slowly curl the cables up towards your head, isolating the biceps, and squeeze. Hold for a count then return back to the starting position. Repeat for as many reps and sets as desired."),
        Exercise(3105L, "Dumbbell Kneeling Bicep Curl (Stability Ball)", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Start off kneeling on an exercise ball, making sure that you find and get your balance first, with a dumbbell in one of your hands. Hold the dumbbell palms up at hip level and slowly curl the weight to chest level, pause and then lower back down to the starting position under control. Repeat for the number of reps and sets desired and switch arms."),
        Exercise(3106L, "Dumbbell One-Arm Single-Leg Bicep Curl on Stability Ball", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Start by sitting on an exercise ball, holding onto a dumbbell in one hand and elevating a leg on the same side. Lift up the weight, while keeping the leg raise, and curl it up to chest level, making sure to isolate the bicep and then return back to the starting position. Repeat for as many repetitions as desired and then switch arms."),
        Exercise(3107L, "Dumbbell Alternating Bicep Curl (Stability Ball)", listOf(MuscleGroup.BICEPS), Equipment.DUMBBELL, "Begin by standing up straight with a dumbbell in each hand and a stability ball placed behind you. Lift up one of your legs and place it behind you onto the stability ball making sure that your shin is placed on the top of the ball. Slowly lift one of the dumbbells up to chest level, isolating the bicep, hold for a 2 count and then lower back down to the starting position under control. Repeat with the other for as many reps and sets as desired."),
        Exercise(3108L, "Dumbbell One-Arm Bicep Curl on Stability Ball", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Begin by sitting on an exercise ball holding a dumbbell in one hand and keeping both feet evenly planted on the floor. Slowly lift the weight up towards your shoulders and stopping at chest level, making sure to squeeze your bicep and isolate the motion. Return back to the starting position and repeat for as many reps as desired. Switch arms and repeat."),
        Exercise(3109L, "Dumbbell Bicep Curl on Stability Ball", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Start by holding a dumbbell in each hand with a palms up grip. Place the top of one foot behind you on an exercise ball as if you were stretching your leg. While keeping your back straight and your abs drawn in, bring your arms down in front of your legs. Raise your arms up, curling and contracting your biceps, squeezing the muscle as much as possible. Lower your arms and return to starting position and switch legs. Repeat for as many reps and sets as desired."),
        Exercise(3110L, "Medicine Ball Bicep Curl on Stability Ball", listOf(MuscleGroup.BICEPS), Equipment.EXERCISEBALL, "Start by sitting on an exercise ball with your feet firmly on the floor in front of you. Hold a Medicine Ball in one hand and curl it up bringing your forearm up to your bicep, isolating the muscle as much as possible. Return to starting position and switch arms. Repeat for as many reps and sets as desired."),

        // GLUTES
        Exercise(7001L, "Machine Hip Abduction", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit on machine and place knees against pads.\n2. Draw abs in and move thighs apart against pads.\n3. Slowly return to starting position and repeat."),
        Exercise(7002L, "Barbell Hip Thrust", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Start seated on ground with back on bench.\n2. Keep weighted barbell above hips.\n3. Lean back against bench and rest shoulders on top.\n4. Push hips up vertically and repeat."),
        Exercise(7003L, "Cable Leg Kickback", listOf(MuscleGroup.LEGS), Equipment.CABLE, "1. Attach ankle strap to low pulley cable machine.\n2. Stand in front with arms against it for support.\n3. Move weighted leg backward, extending as far as possible.\n4. Return and repeat."),
        Exercise(7004L, "Barbell Glute Bridge", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Begin with back flat on floor and weighted barbell above legs.\n2. Roll bar above thighs at hip increase.\n3. With bar on hips, extend upward with back and heels supporting weight."),
        Exercise(7005L, "Machine Single-Leg Press", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Set up leg press machine with desired weight.\n2. Sit down placing one leg up against foot rest.\n3. Extend foot to release weight and slowly lower until leg at 45-degree angle."),
        Exercise(7006L, "Bridge", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Lie on back with knees bent and feet flat on floor.\n2. Lift hips off floor drawing abs in and keeping glutes tight.\n3. Hold position then return to start."),
        Exercise(7007L, "Cable Hip Abduction", listOf(MuscleGroup.LEGS), Equipment.CABLE, "1. Stand alongside cable pulley stack with cuff at ankle.\n2. Step away holding stack for support.\n3. While standing firm, slowly abduct cuffed ankle in front of stabilizing leg."),
        Exercise(7008L, "Glute Kickback (Kneeling)", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start with knees on floor in kneeling push-up position.\n2. Raise right leg until hamstrings parallel with back maintaining 90-degree level.\n3. Squeeze glutes throughout movement."),
        Exercise(7009L, "Cable Pull Through", listOf(MuscleGroup.LEGS), Equipment.CABLE, "1. Stand few feet from cable machine holding rope between legs under glutes.\n2. Keep knees slightly bent, pull rope through with only use of hips.\n3. Refrain from using shoulders or arms."),
        Exercise(7010L, "Single-Leg Glute Bridge", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Lie on floor with feet flat on ground and knees bent.\n2. Slowly raise one leg off ground pulling knee toward chest.\n3. Extend hip upward raising glutes and lower body up."),
        Exercise(7011L, "Bench Hip Thrust", listOf(MuscleGroup.LEGS), Equipment.BENCH, "1. Lay with back on flat bench with feet hanging off one end.\n2. Keep feet and knees together, slowly bring up toward ceiling keeping straight.\n3. Thrust hips up then slowly low back down."),
        Exercise(7012L, "Smith Machine Split Squat", listOf(MuscleGroup.LEGS), Equipment.SMITH, "1. Begin in lunge position under smith machine bar with one foot in front.\n2. Release bar off guides and slowly lower until thighs parallel to floor."),
        Exercise(7013L, "Hip Extension (Standing)", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand facing wall positioning both hands on wall for support.\n2. Stand tall throughout.\n3. Engage core and swing leg backward, keeping leg straight.\n4. Return to starting position."),
        Exercise(7014L, "Flutter Kick", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start prone on floor resting forehead on hands out in front.\n2. While keeping both legs straight, raise one leg off floor a few inches.\n3. Lower and repeat on opposite side."),
        Exercise(7015L, "Glute Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start flat on back with knees bent and feet flat on floor.\n2. Take ankle and place on opposite knee.\n3. Grab knee with bottom leg and pull both legs close to chest."),
        Exercise(7016L, "Reverse Hyper (Flat Bench)", listOf(MuscleGroup.LEGS), Equipment.BENCH, "1. Lay face down in prone position on bench with toes touching floor and legs extended straight behind.\n2. Pull legs up toward ceiling until feeling tension in glutes."),
        Exercise(7017L, "Stability Ball Hamstring Curl to Bridge", listOf(MuscleGroup.LEGS), Equipment.EXERCISEBALL, "1. Lay flat on back with both feet on exercise ball, arms flat on floor by side.\n2. Bend knees and curl heels toward glutes.\n3. Kick up one leg diagonally."),
        Exercise(7018L, "Barbell Lateral Lunge", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Stand straight with feet shoulder width apart, holding barbell across upper back.\n2. Take short lateral step in one direction, sitting back while bending at one knee."),
        Exercise(7019L, "Iron Cross Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1.) Begin by laying flat on your back in a cross position so that you are forming the \"T\" shape, arms out to the sides and legs together.\n2.) Slowly kick one leg towards the opposite hand through a rotation in your lower back and hips.\n3.) Hold onto this position for 15 to 30 seconds and then repeat for as many reps and sets as desired."),
        Exercise(7020L, "Hip Adduction", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1.) Begin standing with one leg straight and in front of the other leg, keeping both feet pointed forward.\n2.) Slowly shift your body in a sideways motion towards the bent leg until you a feel a stretch in your groin area.\n3.) Move side to side for 15 to 30 seconds repeating as many reps and sets as desired."),
        Exercise(7021L, "Barbell Kneeling Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1.) To begin this exercise; start off in a kneeling position with a weighted barbell upon your shoulders.\n2.) Lean back with your pelvis and touch your calves with your glutes and then return back to the starting position.\n3.) Repeat this exercise for as many repetitions as needed."),
        Exercise(7022L, "Stability Ball Hip Thrust", listOf(MuscleGroup.LEGS), Equipment.EXERCISEBALL, "1.) Start by sitting on an exercise ball and slowly walk your feet out and lay with your back on the ball.\n2.) Keeping your shoulders and head on the exercise ball, cross your arms across your chest.\n3.) Lift your hips up slowly in a smooth motion, holding for a few seconds then return back to the starting position.\n4.) Repeat for as many sets and reps as desired."),
        Exercise(7023L, "Knee to Chest (Supine)", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1.) To begin this exercise; start off positioned on your your back with your knees bent as in a standard sit-up position.\n2.) Push your right leg out and straight followed by taking your left knee and pulling it tightly to your chest bringing the knee as close as you can to your head.\n3.) Repeat this exercise for as many repetitions as needed."),
        Exercise(7024L, "Hip Abduction", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1.) Start off standing up straight with your arms extended again a wall.\n2.) Slowly cross one of your legs behind you then flexing away with your upper body away from the stretched leg until you feel tension in your hips and legs.\n3.) Move side to side for about 15 to 30 seconds and repeat for as many reps and sets as desired."),
        Exercise(7025L, "Band Hip Lift", listOf(MuscleGroup.LEGS), Equipment.BANDS, "1.) To begin this exercise; take a band and secure it underneath two dumbbells so that they wont move.\n2.) Move your body so that your hips are right under the bands and set up for a basic sit up position with your knees up and feet firm on the floor.\n3.) Keep your hands extended behind your head.\n4.) Push your shoulders to the floor as you raise your hips and extend the band as high as possible.\n5.) Hold onto the position for a few seconds and return to the start.\n6.) Repeat this exercise for as many repetitions as needed."),
        Exercise(7026L, "Knee Across the Body", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1.) To begin this exercise; start off lying down flat on your back with your legs straight out and arms to their sides.\n2.) Take your left leg and bend it across your body so that it is over your right with the left foot on the floor.\n3.) Take your left arm and hold down the right knee down in position.\n4.) Then place your alternate arm to the side and turn your head to the opposite direction.\n5.) Return back to the starting position and repeat the exercise to the alternate direction.\n6.) Repeat this exercise for as many repetitions as needed."),
        Exercise(7027L, "Seated Glute Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1.) You will need a partner for this stretch.\n2.) Start off in a seated position with your knees bent and one ankle crossed over one knee.\n3.) With your partner standing behind you, lean forward as your partner braces your shoulders then try to push your body back for 15 to 30 seconds while your partner tries to prevent any movements.\n4.) Relax your muscles and have your partner gently push your body forward for 15 to 30 seconds to increase the stretch.\n5.) Repeat for as many reps and however long as desired."),
        Exercise(7028L, "Barbell Kneeling Jump Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1.) To begin this exercise; start off in a kneeling position on the floor with a weighted barbell rested upon your shoulders.\n2.) Lean back with your pelvis and let your butt touch your feet then explode forward and up with your hips with enough power that allows you to lift your feet up off of the floor and land flat.\n3.) Then push your body up into a full standing position.\n4.) Repeat this exercise for as many repetitions as needed.\nTips: 1.) Make sure that you are doing the exercise with as much weight as you are able to handle."),

        // LEGS
        Exercise(20001L, "Machine Leg Extension", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Adjust seat for full range of motion.\n2. Sit upright with hips against bench.\n3. Extend legs straight, hold, then return.\n4. Avoid locking knees."),
        Exercise(20002L, "Machine Leg Press", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit with feet close together.\n2. Grasp handles and bend knees to bring weight toward chest.\n3. Hold then return.\n4. Do not lock knees at top."),
        Exercise(20003L, "Barbell Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Position bar on upper back.\n2. Feet shoulder-width apart.\n3. Lower body until thighs parallel ground.\n4. Drive through heels to stand."),
        Exercise(20004L, "Machine Seated Leg Curl", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Adjust footpad above heels.\n2. Sit upright, curl legs toward buttocks.\n3. Hold for one or two counts before returning."),
        Exercise(20005L, "Machine Leg Curl (Prone)", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Lie prone with knees beyond bench edge.\n2. Flex knees to raise lever pads.\n3. Lower until straight.\n4. Repeat."),
        Exercise(20006L, "Barbell Romanian Deadlift", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Grip bar wider than shoulders.\n2. Slight knee bend, hinge hips back, lowering bar.\n3. Keep back straight until floor contact."),
        Exercise(20007L, "Machine Hip Adduction", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Rest knees against pads.\n2. Draw abs in and squeeze thighs together.\n3. Return to starting position slowly."),
        Exercise(20008L, "Dumbbell Bulgarian Split Squat", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Rest non-working foot on bench.\n2. Hold dumbbells.\n3. Sink into squat.\n4. Drive working leg down and back up."),
        Exercise(20009L, "Hack Squat", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Lie face up with shoulders against pad.\n2. Extend body upright.\n3. Lower body down feeling quad stretch.\n4. Return."),
        Exercise(20010L, "Dumbbell Romanian Deadlift", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Stand hip-width apart.\n2. Hinge at hips pushing back.\n3. Lower weights while keeping back flat.\n4. Squeeze glutes to rise."),
        Exercise(20011L, "Kettlebell Goblet Squat", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. Hold kettlebell at chest.\n2. Squat down until hamstrings touch calves.\n3. Hold briefly.\n4. Return to standing."),
        Exercise(20012L, "Dumbbell Lunge", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Step forward about three feet.\n2. Lower knee without touching ground.\n3. Keep other knee at ninety degrees.\n4. Return."),
        Exercise(20013L, "Dumbbell Squat", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Hold weights with feet wider than shoulders.\n2. Descend bending knees and hips.\n3. Hold at lowest point before rising."),
        Exercise(20014L, "Smith Machine Squat", listOf(MuscleGroup.LEGS), Equipment.SMITH, "1. Set bar height to shoulders.\n2. Feet wider than hips.\n3. Descend bending knees.\n4. Stand upright and repeat."),
        Exercise(20015L, "Bodyweight Squat", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Feet shoulder-width apart.\n2. Bend knees and hips.\n3. Lower until knees parallel glutes.\n4. Return and repeat."),
        Exercise(20016L, "Dumbbell Walking Lunge", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Hold weights, step forward.\n2. Lower knee.\n3. Push off with back foot and step through.\n4. Alternate legs."),
        Exercise(20017L, "Machine Single-Leg Extension", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit with back flat.\n2. Elevate one leg while keeping other still.\n3. Squeeze quads.\n4. Return slowly."),
        Exercise(20018L, "Dumbbell Reverse Lunge", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Stand holding dumbbells.\n2. Step backward and lower body.\n3. Push back up on the leading leg.\n4. Switch sides."),
        Exercise(20019L, "Dumbbell Step-Up", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Place a bench, box or step in front of you.\n2. Grasp a dumbbell in each hand.\n3. Step up on the bench with your left leg, follow with your right leg.\n4. Step down with your left leg, then your right leg.\n5. Repeat starting with your right leg."),
        Exercise(20020L, "Machine Leg Press (Wide Stance)", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Set up the amount of weight on the machine.\n2. Sit down and place your legs on the rest with a wide stance and back flat on padding.\n3. Release weight and bring it down to 90-degree angle.\n4. Hold for a count then return to starting position.\n5. Repeat for desired reps and sets."),
        Exercise(20021L, "Barbell Front Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Place barbell on your upper chest across front deltoids with arms crossed.\n2. Slowly squat until thighs are parallel to ground.\n3. Return back up to starting position.\n4. Practice without weight first for comfort."),
        Exercise(20022L, "Barbell Lunge", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Place barbell across upper back with shoulder-width grip.\n2. Step forward 2-3 feet keeping abs tight.\n3. Lower back knee toward floor while keeping other knee bent at 90 degrees.\n4. Hold for a count then return.\n5. Knee should not move beyond toe."),
        Exercise(20023L, "Kettlebell Swing", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. Stand feet wider than shoulder-width.\n2. Bend at hips and knees to grab kettlebell handle.\n3. Keep back flat, chest up.\n4. Drive through heels and hips to swing kettlebell forward.\n5. Keep arms straight.\n6. Thrust hips forward to propel kettlebell upward to chest level.\n7. Swing back between legs.\n8. Continue rhythmically."),
        Exercise(20024L, "Kettlebell Single-Leg Deadlift", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. Hold kettlebell in one hand while standing on one leg.\n2. Perform stiff legged deadlift by bending at hip and pushing alternate leg straight out behind.\n3. Lower kettlebell until it touches the floor.\n4. Return to starting position.\n5. Repeat."),
        Exercise(20025L, "Barbell Deep Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Place weighted barbell on shoulders behind neck.\n2. Bend knees and sit back with hips.\n3. Continue squatting until hamstrings near calves.\n4. Pause briefly then return.\n5. Use force of heels to straighten."),
        Exercise(20026L, "Machine Kneeling Leg Curl", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Get into position with forearms in front and leg under curling pad.\n2. Keep upper body still.\n3. Slowly curl pad toward glutes, squeezing hamstrings.\n4. Hold for a count then return.\n5. Repeat for desired reps."),
        Exercise(20027L, "Dumbbell Plie Squat", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Stand feet 2-4 inches wider than shoulders, toes pointed out 45 degrees.\n2. Grab one dumbbell with both hands, hanging straight down.\n3. Squat down until thighs are parallel to floor.\n4. With controlled motion return to starting position.\n5. Repeat for repetitions."),
        Exercise(20028L, "Barbell Bulgarian Split Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Place barbell on back with wide grip.\n2. Place one foot behind on bench.\n3. Lower down until about parallel to floor with involved leg.\n4. Return upright focusing on hip and thigh.\n5. Switch legs and repeat."),
        Exercise(20029L, "Bodyweight Lunge", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand up straight with knees slightly bent.\n2. Get into lunge position and squat down through hips.\n3. Squat so front leg is parallel with floor.\n4. Return to starting position.\n5. Repeat."),
        Exercise(20030L, "Dumbbell Farmers Carry", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Stand with weights at side.\n2. Hinge at hips to grab each dumbbell.\n3. Lift with legs to stand upright.\n4. Walk with weights maintaining steady position.\n5. Keep traps relaxed and eyes forward.\n6. Use short strides."),
        Exercise(20031L, "Machine Leg Press (Narrow Stance)", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit down and place legs in narrow stance with toes pointed out.\n2. Lower safety bars to release platform.\n3. Push platform up until legs fully extended.\n4. Lower platform to 90-degree angle.\n5. Return and repeat."),
        Exercise(20032L, "Bodyweight Sumo Squat", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand feet wider than shoulder-width with toes slightly outward.\n2. Bend at hips and knees, lowering torso.\n3. Keep chest up and back straight.\n4. Lower until thighs parallel to ground.\n5. Push through heels to rise, squeezing glutes at top."),
        Exercise(20033L, "Machine Squat", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Adjust shoulder rack for comfortable foot reach.\n2. Press feet forward and release safety locks.\n3. Slowly lower weight while keeping abs drawn in.\n4. Don't lock knees or bounce weight.\n5. Return to start."),
        Exercise(20034L, "Machine Single-Leg Curl", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Set up with desired weight.\n2. Face down on machine with padding above ankles.\n3. Curl weight up with one leg, feeling hamstring stretch.\n4. Return to starting position.\n5. Repeat for reps and sets."),
        Exercise(20035L, "Machine Single-Leg Press", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit on leg press machine with one foot on platform, other extended to side.\n2. Select desired weight.\n3. Push against platform using hamstrings and quads until feeling stretch.\n4. Return to starting position.\n5. Repeat."),
        Exercise(20036L, "Jump Squat", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Cross arms over chest standing straight.\n2. Squat down until thighs parallel to floor.\n3. Push up from heels to jump as high as possible.\n4. Immediately repeat once on floor.\n5. Continue repeating."),
        Exercise(20037L, "Dumbbell Hamstring Curl", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Start by setting up an elevated flat bench on either a block or step and making sure that your resting point is secure.\n2. Lie face down with dumbbell between feet.\n3. Curl dumbbell up toward buttocks by bending knees.\n4. Hold for a count when you feel a stretch in your hamstrings then return back to the starting position.\n5. Repeat."),
        Exercise(20038L, "Prisoner Squat", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start by standing up straight with wide feet and your hands behind your head.\n2. Lower body in controlled squat.\n3. Return back to the starting position and repeat for as many reps and sets as desired."),
        Exercise(20039L, "Smith Machine Bulgarian Split Squat", listOf(MuscleGroup.LEGS), Equipment.SMITH, "1. Set the barbell at the proper height on your shoulders behind your neck.\n2. Position one leg on flat bench behind smith machine.\n3. Lower your knee close to the floor until your knee forms a 90-degree angle.\n4. Return to starting position."),
        Exercise(20040L, "Hack Squat (Reverse Position)", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Place yourself with your chest flat on the pad and shoulders up against the shoulder rests.\n2. Push up with body to remove weights from stacks.\n3. Slowly lower the weight down until your thighs create right angles with your calves.\n4. Return to starting position."),
        Exercise(20041L, "Hack Squat (Narrow Stance)", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Start off with your back flat on the back pad of the hack squat machine and placing your shoulders underneath the pads.\n2. Then place your legs less than shoulder width apart in a very narrow stance with toes pointed out.\n3. Straighten legs, then lower the machine down as you bend your knees continuing on until your upper legs and knees form a 90-degree angle."),
        Exercise(20042L, "Machine Single-Leg Curl", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit down on leg curl machine with one of your legs rested on top of the curling pad and the other off to the side.\n2. While keeping your upper body still and other leg in place, slowly curl the pad down as far as possible, squeezing your quads and hamstrings.\n3. Hold then return to starting position."),
        Exercise(20043L, "Quadricep Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Begin by wrapping either a belt, rope or exercise band around one of your feet and lay on your side, with the top foot being the one that is wrapped and the other extended out behind you.\n2. Slowly flex the top knee and bring your foot back in attempt to touch your glutes with your heel.\n3. Pull on belt to increase tension.\n4. Return to the starting position and repeat for as many reps, sets and duration as you desire."),
        Exercise(20044L, "Bodyweight Side Lunge", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start by standing up straight with a slight bend in the knees.\n2. Step out to your side with your left leg and squat down through your hips.\n3. Lower yourself towards the floor so that your front leg is parallel with the floor and hold for a count.\n4. Return to starting position."),
        Exercise(20045L, "Split Squat", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start with your feet hip-width apart.\n2. Place your right foot forward and the left foot behind your body.\n3. Keep hands on hips, back straight.\n4. Lower your left knee (back leg) toward the floor.\n5. Get the knee of your front leg to a 90-degree angle and keep your front knees behind your toes.\n6. Press down on right foot to pull back on right knee before left knee touches floor."),
        Exercise(20046L, "Dumbbell Bench Squat", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Start off with dumbbells in both arms rested on your side positioned right in front of a bench.\n2. Bend at knees, continue on with the squat until your hamstrings and glutes are rested upon the box and hold on for a few seconds.\n3. Using the force of your heels and lower legs, straighten out and extend your hips to get back to your starting position."),
        Exercise(20047L, "Kettlebell Farmer's Carry", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. Stand upright with your feet shoulder-width apart.\n2. Place a kettlebell on the ground next to each foot.\n3. Bend at the hips and knees, maintaining a flat back and neutral spine.\n4. Reach down and grip the handles of the kettlebells firmly.\n5. Lift the kettlebells off the ground simultaneously.\n6. Walk forward in controlled manner."),
        Exercise(20048L, "Box Jumps", listOf(MuscleGroup.LEGS), Equipment.BOX, "1. Select a sturdy box or platform that is appropriate for your fitness level.\n2. Bend your knees slightly and engage your core muscles.\n3. Swing your arms back for momentum as you prepare to jump.\n4. Explosively extend your hips, knees, and ankles as you jump upwards.\n5. Land softly on box with both feet, step down carefully from the box rather than jumping down to reduce the risk of injury."),
        Exercise(20049L, "Kettlebell Front Squat", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. Start off by clean pressing two kettlebells to your shoulders.\n2. Squat down as low as you can as in a normal full squat and hold down for a few seconds when you reach the bottom.\n3. Return back to the starting position.\n4. Repeat."),
        Exercise(20050L, "Kneeling Hip Flexor", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Begin by kneeling on the ground or mat keeping one knee on the floor and the opposite knee bent and foot flat on the floor.\n2. Tighten up on your glutes and then do a pelvic tilt rocking on your back leg and hold for 15 to 30 seconds.\n3. Switch legs and repeat."),
        Exercise(20051L, "Side-Lying Hip Abduction", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Lie on your side on a mat or other comfortable surface.\n2. Ensure your body is in a straight line from head to heels.\n3. Prop yourself up on your bottom elbow, which should be directly beneath your shoulder.\n4. Lift your top leg upward as high as you comfortably can without rotating your hips backward or leaning backward.\n5. Focus on using the muscles on the side of your hip (abductors) to lift your leg.\n6. Slowly lower leg back down."),
        Exercise(20052L, "Cable Standing Leg Curl", listOf(MuscleGroup.LEGS), Equipment.CABLE, "1. Start off standing at a leg curl machine adjust the rear footpad so it is just above your ankle.\n2. Grasp the handles of the machine for support and draw your abs in.\n3. Raise your foot up towards your back slowly in a controlled motion.\n4. Return to the starting position and change legs.\n5. Repeat."),
        Exercise(20053L, "Kettlebell One-Arm Swing", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. Start off by placing one kettlebell between your feet and bend down at your knees pushing your glutes out.\n2. Take the kettlebell and swing it between your legs and then use the force to drive the kettlebell out and in front of your chest.\n3. Return back to the starting position.\n4. Repeat."),
        Exercise(20054L, "Outdoor Hiking", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. It can vary in intensity, from easy flat trails to steep, challenging climbs.\n2. Hiking is primarily considered a cardiovascular (aerobic) exercise, especially when done on moderate to steep inclines or for long durations.\n3. Hiking works the major muscles in your legs, including the quadriceps, hamstrings, calves, and glutes.\n4. Maintaining balance on uneven surfaces engages your core muscles."),
        Exercise(20055L, "Bodyweight Step-Up", listOf(MuscleGroup.LEGS), Equipment.BOX, "1. Set up a horizontal bench.\n2. Lift left foot, step up onto platform.\n3. Raise right foot onto platform.\n4. Return to starting position.\n5. Repeat"),
        Exercise(20056L, "Bodyweight Walking Lunge", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand straight with knees slightly bent.\n2. Step forward with left leg, squat down driving body toward floor.\n3. Alternate lunge with opposite leg.\n4. Repeat"),
        Exercise(20057L, "Bodyweight Rear Lunge", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand with slight knee bend.\n2. Step behind you with one leg, maintaining balance.\n3. Lower until front knee parallel with ground.\n4. Return to starting position.\n5. Repeat"),
        Exercise(20058L, "Bodyweight Wall Squat", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Position back flat against wall with feet forward.\n2. Slowly slide torso down until thighs parallel with ground.\n3. Hold then return to starting position.\n4. Repeat"),
        Exercise(20059L, "Barbell Zercher Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Lift barbell off rack, hold across chest with arms crossed.\n2. Place feet wider than shoulder width.\n3. Descend by bending knees and hips.\n4. Lower as far as controlled.\n5. Return upright"),
        Exercise(20060L, "Weight Plate Wall Sit", listOf(MuscleGroup.LEGS), Equipment.WEIGHTPLATE, "1. Press back firmly against wall.\n2. Walk feet out, slide down until knees at 90°.\n3. Hold weight plate at chest.\n4. Hold position 20-30 seconds.\n5. Push through heels to stand"),
        Exercise(20061L, "World's Greatest Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start in lunge position.\n2. Hold 15-30 seconds.\n3. Place arm on ground next to front foot.\n4. Raise other hand parallel to front leg.\n5. Return to starting position"),
        Exercise(20062L, "Seated Floor Hamstring Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Sit on mat with one foot extended, toes up.\n2. Other leg bent inward against opposite leg's inner thigh.\n3. Lean forward reaching for ankle.\n4. Hold 15-30 seconds.\n5. Return to starting position"),
        Exercise(20063L, "Front to Back Leg Swings", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand tall, feet hip-width apart.\n2. Engage core.\n3. Swing one leg forward, knee straight.\n4. Swing backward, bending knee.\n5. Switch legs"),
        Exercise(20064L, "Sissy Squat", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand straight, feet shoulder-width apart.\n2. Place one arm across chest.\n3. Use other arm to hold support.\n4. Lower body backward, heels off ground.\n5. Return to starting position"),
        Exercise(20065L, "Kettlebell Suitcase Carry", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. Stand next to kettlebell, feet shoulder-width apart.\n2. Hinge at hips, grab kettlebell with one hand.\n3. Brace core, stand tall.\n4. Walk slowly while holding kettlebell.\n5. Lower and switch sides"),
        Exercise(20066L, "90/90 Hamstring Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Lie flat on back with one leg extended.\n2. Bend other leg, grab knee with hands.\n3. Extend bent leg into air.\n4. Hold 15 seconds.\n5. Alternate legs"),
        Exercise(20067L, "Barbell Bench Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Start with barbell on shoulders behind neck.\n2. Bend knees, sit back with hips.\n3. Squat until hamstrings and glutes rest on box.\n4. Straighten legs using heels.\n5. Repeat"),
        Exercise(20068L, "Machine Single-Leg Press", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit on leg press with one leg off side.\n2. Push up against platform fully extending leg.\n3. Hold, then return to starting position.\n4. Repeat"),
        Exercise(20069L, "Barbell Romanian Deadlift From Deficit", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Stand on elevated platform with barbell in front of shins.\n2. Bend knees, back straight, pull up from heels.\n3. Keep back straight as barbell crosses knees.\n4. Hold barbell steady.\n5. Repeat"),
        Exercise(20070L, "Toe Touch Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand straight, feet hip-width apart.\n2. Bend at waist with slight leg bend.\n3. Let body hang down, hands reaching to ground.\n4. Hold 15-30 seconds.\n5. Return to start"),
        Exercise(20071L, "Hamstring Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Lie flat on back with one knee bent.\n2. Extend other foot, sole pointed up.\n3. Place hands around extended leg.\n4. Straighten leg, pull toward nose.\n5. Hold 15-30 seconds"),
        Exercise(20072L, "Barbell Single-Leg Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Place bench 12-18 inches tall behind you.\n2. Position barbell on shoulders.\n3. Place one foot on bench, other on floor.\n4. Descend by bending front knee and hip.\n5. Pause, then return upright.\n6. Switch legs"),
        Exercise(20073L, "Side to Side Leg Swings", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Begin by swinging one leg across your body to the opposite side in a controlled motion.\n2. Keep your knee straight but not locked, and aim to swing your leg as high as is comfortable."),
        Exercise(20074L, "Walking High Knees", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start walking forward at a slow to moderate pace.\n2. As you walk, lift your right knee up towards your chest as high as you comfortably can."),
        Exercise(20075L, "Straddle Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Begin in a seated upright position with your legs extended out in front of you in a 'V' shape and arms pointed out straight."),
        Exercise(20076L, "Trap Bar Romanian Deadlift", listOf(MuscleGroup.LEGS), Equipment.TRAPBAR, "1. Place the trap bar on the ground and load it with an appropriate amount of weight.\n2. Stand in the center of the trap bar with your feet shoulder-width apart."),
        Exercise(20077L, "Barbell Squat (Wide Stance)", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Start by lifting a barbell off of a weight rack and position it on your shoulders.\n2. Stand with your feet wider than shoulder width apart."),
        Exercise(20078L, "Barbell Landmine Squat", listOf(MuscleGroup.LEGS), Equipment.LANDMINE, "1. Place one end of the barbell into the landmine attachment or secure it in a corner.\n2. Load weight plates onto the other end of the barbell."),
        Exercise(20079L, "Barbell Hack Squat", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Start by placing a barbell on the floor just behind your legs, standing with your feet shoulder width apart and your toes pointing forward."),
        Exercise(20080L, "Hip Flexor Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Start by standing up straight with your spine vertical and your left foot in front of the right.\n2. Bend slowly at both knees and lift your back heel up off the floor."),
        Exercise(20081L, "Barbell Clean", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. To begin this exercise; start off with a weighted barbell right in front of your shins using an overhand grip.\n2. Bend down at the knees with your back straight, chest out and head facing forward."),
        Exercise(20082L, "Barbell Step-Up", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Start by placing a bench, box or step in front of you and grabbing a barbell with a wide grip and placing it across your shoulders."),
        Exercise(20083L, "Kettlebell Pistol Squat", listOf(MuscleGroup.LEGS), Equipment.KETTLEBELL, "1. To begin this exercise; start off by picking up a kettlebell with two hands and holding it against your chest right below your neck."),

        // LOWER LEGS
        Exercise(23001L, "Machine Seated Calf Raise", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Start sitting at a calf raise machine with balls of feet on footpad and thighs under leg pad.\n2. Unlock bar, raise toes up high, feeling calf stretch.\n3. Hold at top, return to start.\n4. Repeat."),
        Exercise(23002L, "Machine Calf Raise", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Stand straight with toes on footpads, shoulders under upper pads.\n2. Raise on balls of feet, hold.\n3. Return to starting position and repeat."),
        Exercise(23003L, "Calf Press On Leg Press", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit on Leg Press Machine and press plate up.\n2. Slide feet down so balls of feet press against rack with heels free.\n3. Press up and flex toes, then dorsiflex slowly.\n4. Perform movements slowly for maximum benefit."),
        Exercise(23004L, "Dumbbell Calf Raise", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Grasp dumbbell, position toes and balls of feet on calf block with arches and heels extending off.\n2. Place hand on support.\n3. Raise heels by extending ankles high.\n4. Lower heels until calves stretched.\n5. Repeat."),
        Exercise(23005L, "Barbell Standing Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Place block/plates on floor, barbell across back, step up with balls of feet on block.\n2. Lift heels up, then lower for calf stretch.\n3. Return and repeat."),
        Exercise(23006L, "Machine Calf Press", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Sit on leg press machine with balls of feet on bottom of platform, narrow width.\n2. Using calves, push against platform, feel stretch, hold.\n3. Return to start.\n4. Repeat."),
        Exercise(23007L, "Bodyweight Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Set up step/block next to support or smith machine.\n2. Place balls of feet on edge, heels drop toward floor.\n3. Raise heels up high, squeeze calves, hold.\n4. Return to start.\n5. Repeat."),
        Exercise(23008L, "Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand to side of smith machine/support, hold on.\n2. Lift one heel off floor as far as possible, other leg extended behind.\n3. Squeeze calf, hold, return.\n4. Repeat."),
        Exercise(23009L, "Hack Calf Raise", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Set up hack squat machine, lay chest flat on pad, shoulders under shoulder pads.\n2. Stand on platform, push weight up, hold hand rests.\n3. Keep legs straight, raise heels up high, squeeze calves, hold.\n4. Return and repeat."),
        Exercise(23010L, "Smith Machine Reverse Calf Raise", listOf(MuscleGroup.LEGS), Equipment.SMITH, "1. Place block under bar at smith machine, stand on edge with toes hanging off.\n2. Place bar across shoulders, lean forward, lift ankles off box.\n3. Return to start.\n4. Repeat."),
        Exercise(23011L, "Barbell Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Set up barbell across top of upper back.\n2. Lean forward, raise heels up high, squeezing calves at top.\n3. Hold for two count, return.\n4. Repeat."),
        Exercise(23012L, "Dumbbell Seated Calf Raise", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Sit on flat bench with block in front, hold dumbbells on legs.\n2. Dip heels down as far as possible.\n3. Keep dumbbells pressed against knees, raise heels up high, squeeze calves, hold.\n4. Return and repeat."),
        Exercise(23013L, "Machine Single-Leg Calf Press", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Set up leg press machine with desired weight.\n2. Sit with back flat, one leg on platform.\n3. Lift weight, shift foot so only ball of foot is on edge.\n4. Extend heel down far, feel stretch, squeeze calf, hold, return.\n5. Repeat."),
        Exercise(23014L, "Wall Calf Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand in front of wall, place one foot forward, lean toward wall.\n2. Lean closer, rest hands on wall, keep heels, hips, head in straight line, feet flat.\n3. Extend forward until calf stretch, hold 15-30 seconds.\n4. Return and repeat."),
        Exercise(23015L, "Smith Machine Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.SMITH, "1. Set up smith machine with block under bar.\n2. Position under bar so it rests on upper back.\n3. Step up on block with right foot (ball of foot), other leg extended behind.\n4. Release bar, lower heel to floor, then elevate heel up high, squeezing calf.\n5. Hold, return.\n6. Repeat."),
        Exercise(23016L, "Barbell Seated Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Place block about one foot in front of bench.\n2. Rest barbell across upper thighs, sit on bench with balls of feet on block.\n3. Keep barbell on thighs, raise and lower heels up high without lifting foot off block.\n4. Repeat."),
        Exercise(23017L, "Donkey Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BENCH, "1. Bend at waist, lean arms against weight rack or bench waist height.\n2. Have partner sit on lower back or place weight plate on back.\n3. Raise on toes, lean slightly forward until calf stretch.\n4. Pause at top, lower heels.\n5. Repeat."),
        Exercise(23018L, "Calf Raise On A Dumbbell", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Hang onto sturdy object, stand on dumbbell handle with small plate loaded.\n2. Roll foot forward for calf stretch (starting position).\n3. Lift calf, roll foot over top of handle for full extension.\n4. Exhale while lifting.\n5. Inhale as you roll dumbbell forward, come back down.\n6. Repeat."),
        Exercise(23019L, "Machine Seated Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Set up a seated calf raise machine with desired weight.\n2. Sit with one foot on foot rest, other leg extended.\n3. Take weight off rack, lower heel as far as possible.\n4. Lift heel up high, squeeze calf, hold briefly.\n5. Return to starting position and repeat."),
        Exercise(23020L, "Dumbbell Seated Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Place a block in front of a bench.\n2. Sit on bench with dumbbell on knee, ball of foot on block.\n3. Raise and lower heel as high as possible without lifting foot.\n4. Switch feet and repea t."),
        Exercise(23021L, "Barbell Rocking Standing Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BARBELL, "1. Stand with bar across shoulders.\n2. Lift feet up as in calf raise, rock back onto ankles.\n3. Return to starting position.\n4. Repeat for desired reps and sets."),
        Exercise(23022L, "Ankle Circles", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Sit on an exercise mat.\n2. Lift foot and draw circles clockwise in the air with toes.\n3. Reverse direction counter-clockwise.\n4. Switch feet."),
        Exercise(23023L, "Dumbbell Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.DUMBBELL, "1. Sit on flat bench with block in front, dumbbell on right leg.\n2. Extend left leg out, dip right heel toward floor.\n3. Raise heel up high squeezing calf, hold briefly.\n4. Return to starting position and repeat."),
        Exercise(23024L, "Cable Calf Raise", listOf(MuscleGroup.LEGS), Equipment.CABLE, "1. Set up dip belt, rope or bar on low pulley.\n2. Place step in front of machine, stand on it with balls of feet.\n3. Let heels drop down without touching floor.\n4. Raise heels high, squeeze calves, hold.\n5. Return to starting position and repeat."),
        Exercise(23025L, "Posterior Lower Leg Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Kneel on one knee, opposite foot planted flat.\n2. Keep spine straight, hips and shoulders aligned.\n3. Place hand on knee of outstretched leg, lunge forward slightly.\n4. Hold for a few seconds, switch legs and repeat."),
        Exercise(23026L, "Smith Machine Toe Raise", listOf(MuscleGroup.LEGS), Equipment.SMITH, "1. Set up Smith Machine with desired weight.\n2. Position under bar across upper back.\n3. Step onto block with heels on platform edge.\n4. Lower toes toward floor, then raise as high as possible.\n5. Hold briefly and return to starting position."),
        Exercise(23027L, "Posterior Tibialis Stretch", listOf(MuscleGroup.LEGS), Equipment.BANDS, "1.Sit with belt or band looped around one foot.\n2. Extend both legs out, pull belt until foot is everted.\n3. Hold position for 15 to 30 seconds.\n4. Return and repeat for desired duration."),
        Exercise(23028L, "Knee Circles", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand with feet closer than shoulder width apart.\n2. Move both knees in circular motion keeping feet flat.\n3. Perform clockwise then counter-clockwise.\n4. Repeat until loosened up."),
        Exercise(23029L, "Cable Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.CABLE, "1. Set up dip belt, rope or bar on low pulley cable machine.\n2. Stand on block with balls of feet on edge, heels dropped.\n3. Raise one heel high, keeping other leg extended behind.\n4. Squeeze calf, holdbriefly, return and repeat."),
        Exercise(23030L, "Heel Walking", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand tall with feet hip-width apart, arms by sides.\n2. Lift toes off ground so only heels contact floor.\n3.Take small steps forward using only heels.\n4. Keep upper body upright and core engaged.\n5. Walk for20-30 meters or 30-60 seconds."),
        Exercise(23031L, "Hack Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.MACHINE, "1. Set up hack squat machine with desired weight.\n2. Stand on platform, push weight up, hold hand rests.\n3. Raise one heel high keeping legs straight, other leg extends behind.\n4. Squeeze calf, hold briefly, return and repeat."),
        Exercise(23032L, "Soleus and Achilles Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Stand with feet hip distance apart, one foot slightly forward.\n2. Bend slowly at knees keepingback heel on floor.\n3. Hold stretch for 15 to 30 seconds.\n4. Return to starting position and repeat."),
        Exercise(23033L, "Band Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BANDS, "1. Stand on exercise band with equal amount on both sides.\n2. Hold handles elevating arms toward sides of head.\n3. Stand on toes squeezing calves tightly.\n4. Hold briefly, release and return to starting position.\n5. Repeat for desired repetitions."),
        Exercise(23034L, "Single-Leg Donkey Calf Raise", listOf(MuscleGroup.LEGS), Equipment.BENCH, "1. Set up incline bench with balls of feet on step behind bench.\n2. Bend forward resting forearms on bench, extend one leg behind.\n3. Let heel drop toward floor as starting position.\n4. Raise heel highsqueezing calf, hold briefly.\n5. Return to starting position and repeat."),
        Exercise(23035L, "Stability Ball Calf Raise", listOf(MuscleGroup.LEGS), Equipment.EXERCISEBALL, "1. Rest chest on exercise ball against wall, dumbbells at sides.\n2. Walk feet backward extending legs behind you.\n3. Raise heels high off floor rolling ball up wall.\n4. Squeeze calves, hold briefly.\n5. Return to starting position and repeat."),
        Exercise(23036L, "Box Jump with Single-Leg Stabilization", listOf(MuscleGroup.LEGS), Equipment.BOX, "1. Stand on plyo box with arms at sides and feet together.\n2. Jump off platform and gently land on ball of foot.\n3. Hold landing position.\n4. Repeat landing on opposite leg."),
		Exercise(23037L, "Smith Machine Single-Leg Calf Raise", listOf(MuscleGroup.LEGS), Equipment.SMITH, "1. Stand facing the Smith Machine in the standing calf raise position.\n2. Place one leg on a bench while keeping the other on the floor.\n3. Lower the heel of the raised foot toward the floor.\n4. Raise onto the balls of your foot and hold the top position for a moment.\n5. Lower slowly and repeat with the opposite leg."),
		Exercise(23038L, "Band Seated Calf Stretch", listOf(MuscleGroup.LEGS), Equipment.BANDS, "1. Sit on the floor with legs extended in front of you.\n2. Loop a resistance band around one foot.\n3. Gently pull the foot back while keeping the knee straight.\n4. Feel the stretch in the calf muscle.\n5. Hold for 15-30 seconds.\n6. Switch to the other leg."),
		Exercise(23039L, "Bench Calf Stretch", listOf(MuscleGroup.LEGS), Equipment.BENCH, "1. Stand facing a bench or wall.\n2. Place balls of both feet on the bench.\n3. Extend your hips forward keeping heels down.\n4. Keep back straight.\n5. Feel the stretch in calves and lower legs.\n6. Hold for 30 seconds.\n7. Slowly return to starting position."),
		Exercise(23040L, "Calf Stretch with Rope", listOf(MuscleGroup.LEGS), Equipment.CABLE, "1. Attach a rope to a low cable pulley.\n2. Stand facing the machine with the rope around both feet.\n3. Lean backward gently while keeping heels on the floor.\n4. Feel the stretch in the calves.\n5. Hold for 15-30 seconds.\n6. Return to starting position."),
		Exercise(23041L, "Peroneal Stretch", listOf(MuscleGroup.LEGS), Equipment.BODYWEIGHT, "1. Sit cross-legged on the floor.\n2. Gently pull one foot across your body toward the opposite knee.\n3. Keep your leg relaxed and follow through with your hand.\n4. Feel the stretch in the outer leg and ankle area.\n5. Hold for 15-30 seconds.\n6. Switch to the other leg."),

        // BACK
        Exercise(21001L, "Cable Lat Pulldown (Wide Grip)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start by sitting under a cable pull down machine that has a wide bar attachment and grab it with a wide overhand grip.\n2. While keeping your abs drawn in and back straight, pull down the bar to your upper chest.\n3. Hold for a count at the bottom position, squeeze your lats and then slowly return back to the starting position."),
        Exercise(21002L, "Cable Seated Row", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Set Up the Machine: Attach the desired handle to the cable row machine. Adjust the seat and chest pad if available so that you can reach the handle comfortably without overextending.\n2. Starting Position: Sit down on the machine with your feet securely placed on the footrests. Your knees should be slightly bent.\n3. Grasp the handle with both hands, using an overhand or neutral grip (palms facing each other).\n4. Sit with a straight back and slight lean forward from the hips, keeping your chest up and core engaged.\n5. Executing the Row: Pull the handle towards your torso, leading with your elbows. Your elbows should stay close to your body.\n6. As you pull, squeeze your shoulder blades together and keep your back straight.\n7. End Position: Pull the handle until it reaches your torso, typically around the lower chest or upper abdomen.\n8. Hold this position for a brief moment to maximize the contraction in your back muscles.\n9. Slowly extend your arms and return the handle to the starting position, maintaining control of the weight throughout the movement."),
        Exercise(21003L, "Dumbbell One-Arm Row", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Start by kneeling over the side of a bench placing the knee and hand of the supporting arm on the bench and then position the opposite foot on the floor.\n2. Grab a dumbbell from the floor opposite of the side supporting the body and pull the dumbbell up slowly to your chest, feeling a stretch in your back until it almost makes contact with your chest.\n3. Hold this position for a count, then return slowly back to the starting position.\n4. Repeat for as many reps and sets as desired and switch with the opposite arms."),
        Exercise(21004L, "Cable Rope Face Pull", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Start by facing a high pulley cable machine with either a rope or dual handles connected to the machine.\n2. Grab onto the handles and pull the weight directly towards your face, using your shoulders, and separating your shoulders as you pull the weights back.\n3. Hold for a count then return back to the starting position."),
        Exercise(21005L, "Pull-Up", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Grab the bar with an overhand grip.\n2. Lift your self up till your chin is above the bar.\n3. Pause for a few seconds.\n4. Lower yourself down slowly.\n5. Repeat for the desired amount of reps."),
        Exercise(21006L, "Barbell Deadlift", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Start by standing in front of a barbell with your feet shoulder-width apart.\n2. Pick up the barbell while keeping your arms extended straight down.\n3. Stand up straight with the barbell in your hands, and refrain from moving your arms.\n4. Bend back down at the knees with barbell.\n5. Repeat for the desired amount of reps."),
        Exercise(21007L, "Barbell Bent-Over Row", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Setup: Load the barbell with an appropriate amount of weight for your fitness level. Stand with your feet shoulder-width apart, the barbell in front of you on the floor.\n2. Grasping the Barbell: Bend at your hips and knees, and grasp the barbell with a grip slightly wider than shoulder-width apart.\n3. Starting Position: Lift the barbell to your shins, then stand up, keeping your back straight.\n4. Bend at your hips until your torso is almost parallel to the floor.\n5. The Rowing Motion: Engage your core and back muscles. Exhale as you pull the barbell towards your lower ribcage or upper abdomen.\n6. Keep your elbows close to your body and squeeze your shoulder blades together at the top of the movement.\n7. Lowering the Barbell: Inhale as you slowly lower the barbell back to the starting position with controlled movement, fully extending your arms."),
        Exercise(21008L, "Machine Seated Row", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start off sitting on a fixed row machine, grabbing the handles in front of you so that your arms are in a full extension and chest is up against the pad in front of you.\n2. Slowly contract your back muscles moving your shoulder blades with your arms and pull back on the machine.\n3. Hold as you reach a peak position and then return back to the starting position."),
        Exercise(21009L, "Dumbbell Shoulder Shrug", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Starting Position: Stand with your feet shoulder-width apart. Hold a dumbbell in each hand with your arms fully extended by your sides, palms facing your body (neutral grip).\n2. Keep your back straight, chest up, and head facing forward.\n3. Shrug Your Shoulders: Lift your shoulders straight up towards the ears as high as you can.\n4. Imagine trying to touch your shoulders to your ears.\n5. Lower Your Shoulders: Slowly lower your shoulders back to the starting position in a controlled manner."),
        Exercise(21010L, "Back Hyperextension", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start by adjusting the hyper-extension machine so that your ankles are tucked under the footpads and thighs are across the top pad as this will be your starting position.\n2. Keeping your arms folded across your chest and your back straight, slowly bend at your waist towards the ground until you feel a stretch in your core and lower back.\n3. Hold for a count and then slowly return back to the starting position."),
        Exercise(21011L, "Machine Lat Pulldown", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start by sitting on a lat pull down machine, grabbing the handles with an overhand grip, keeping your knees positioned underneath the padding and feet flat on the floor.\n2. Once in position, slowly pull down on the handles and bring them down towards your sides, and squeeze with your lat and back muscles.\n3. Hold for a count then return back up to the starting position."),
        Exercise(21012L, "Cable Shoulder Extension", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Begin by standing in front of a cable machine and attach a short bar to a high pulley.\n2. Take hold of the handle with an overhand grip.\n3. Keeping your arms straight and elbows at your side as you push the handle down towards your thighs.\n4. Pause for a moment and then return to the starting position."),
        Exercise(21013L, "Cable Front Lat Pulldown (Close Grip)", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Start by sitting down at a pull-down machine and place your knees underneath the padding on the machine.\n2. Grab onto the bar with a close overhand grip and pull the bar down straight until it is even with your upper chest.\n3. Once in the final position hold for a count while squeezing the lat muscles and then slowly return back to the starting position."),
        Exercise(21014L, "Machine Assisted Pull-Up", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start by setting up the weight that will allow your body to lower towards the floor and that you would like to perform for this exercise, making sure that the knee rests are in position for your body to rest upon.\n2. Climb onto the machine and place your knees upon the pad, then once in position grab the pull-up handles above you and lift yourself up towards the ceiling.\n3. Squeeze your lat and back muscles as your body comes up towards the ceiling until your shoulders are at hand level and hold for a count."),
        Exercise(21015L, "Leverage Machine Iso Row", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start by loading the amount of weight that you want onto the machine and then adjusting the levels of the seat so that the handles are just at chest level.\n2. Grab the handles with either a grip that is comfortable for you and will target your back muscles the best.\n3. Slowly pull the handles in towards your chest, retracting your shoulders back through the elbows until you feel tension on your muscles.\n4. Hold for a count then return back to the starting position."),
        Exercise(21016L, "Dumbbell Pullover", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. To begin this exercise; start off by placing a dumbbell standing up on a flat bench.\n2. With the dumbbell standing up, lie your shoulders flat down upon the surface of the bench with your hips below and your legs bent so that your feet are firmly upon the floor.\n3. Take the dumbbell with one hand and lift it straight up over your chest as the palms rest on the underside of one of the sides of the dumbbell.\n4. Lower the weight down in an arc behind your head, stretching out your chest and hold for a few seconds.\n5. Return the dumbbell back to the starting position."),
        Exercise(21017L, "Weighted Pull-Up", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start by positioning yourself in front of a pull-up bar with a weight attached to a dip belt that is secured around your waist.\n2. Grab the pull-up bar with an overhand grip and slowly pull yourself up squeezing your back muscles.\n3. Hold this position for a count then return back to the start."),
        Exercise(21018L, "Dumbbell Bent-Over Row", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Start by holding a dumbbell in each hand with palms facing towards you, bending slightly at your knees and at your torso as if you were to pick up something.\n2. Hold you arms straight down with a weight in each hand and then slowly lift the dumbbells to your sides.\n3. Once at the top position hold for a count while squeezing your back muscles and then return back to the starting position."),
        Exercise(21019L, "Barbell Shrug", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Stand with feet shoulder-width apart.\n2. Grip barbell overhand slightly wider than shoulders.\n3. Lift shoulders straight up toward ears, squeezing traps.\n4. Slowly lower with control."),
        Exercise(21020L, "T Bar Row", listOf(MuscleGroup.BACK), Equipment.LANDMINE, "1. Stand over barbell.\n2. Hinge at hips with straight back.\n3. Pull handle toward torso, squeezing shoulder blades together.\n4. Lower bar to starting position in controlled manner."),
        Exercise(21021L, "Dumbbell Incline Bench Row", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Lay on incline bench at 35-45 degrees with dumbbells in each hand.\n2. Pull dumbbells up toward chest, squeezing back.\n3. Return to starting position."),
        Exercise(21022L, "Cable V Bar Pulldown", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Sit upright with abs drawn in, grab V-bar with overhand grip.\n2. Pull bar straight down to upper chest.\n3. Hold and return to starting position."),
        Exercise(21023L, "Cable One-Arm Lat Pulldown", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Sit in front of low pulley machine with one handle.\n2. Pull handle down in pronated grip until tension felt in lats.\n3. Hold and return to starting position.\n4. Repeat on opposite side."),
        Exercise(21024L, "Machine Back Extension", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Position on machine with feet on platform.\n2. Hold handles at sides, back flat on padding.\n3. Extend back, pushing padding backward.\n4. Hold and return to starting position."),
        Exercise(21025L, "Dumbbell Deadlift", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart, grab dumbbells with overhand grip.\n2. Keep back straight, bend at waist with slight knee bend.\n3. Lower dumbbells to just above floor.\n4. Return to starting position."),
        Exercise(21026L, "Cable One-Arm Seated Row", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Sit on floor or bench facing low pulley.\n2. Keep body straight with feet on foot rests.\n3. Grab handle with overhand grip and pull back, twisting with wrists.\n4. Squeeze back muscles."),
        Exercise(21027L, "Machine Reverse Lat Pulldown (Close Grip)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Attach lat pulldown machine, grab with reverse grip so palms face toward you.\n2. Pull v-bar down to almost hit chest while keeping back straight.\n3. Hold and return to starting position."),
        Exercise(21028L, "Barbell Row", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Place barbell in corner, load weight on one end.\n2. Bend forward nearly parallel to ground with knees bent.\n3. Grab bar with one hand over other, just beneath plates.\n4. Pull bar up to lower chest, squeezing back.\n5. Return to starting position."),
        Exercise(21029L, "Dumbbell Rear Delt Row", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Lie on flat bench with dumbbells in each hand extended out front.\n2. Pull dumbbells up until elbows are just above shoulders.\n3. Hold and squeeze muscles.\n4. Return to starting position."),
        Exercise(21030L, "Leverage Machine High Row", listOf(MuscleGroup.BACK), Equipment.LEVERAGE, "1. Load weight and adjust settings so handles are just above you with knee pads.\n2. Pull handles down toward abs while retracting shoulders back.\n3. Hold when feeling tension in lower back.\n4. Return to starting position."),
        Exercise(21031L, "Chin-Up with Knee Raise", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Grab bar with underhand grip, hang from bar with arms straight.\n2. Pull up until chin is higher than bar, squeezing back muscles and lats.\n3. Drive knees upward toward chest.\n4. Return slowly to starting position."),
        Exercise(21032L, "Barbell Stiff-Leg Deadlift", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Stand with feet shoulder-width apart holding weighted barbell at thigh level.\n2. Keeping knees still, lower upper body and barbell toward floor.\n3. Move forward until feeling hamstring stretch.\n4. Extend through hips to return to start."),
        Exercise(21033L, "Dumbbell Stiff-Leg Deadlift", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Stand with feet shoulder-width apart holding dumbbells at sides.\n2. Lower upper body and dumbbells toward floor while keeping knees still.\n3. Feel hamstring stretch, then extend through hips to return to starting position."),
        Exercise(21034L, "Smith Machine Shrug", listOf(MuscleGroup.BACK), Equipment.SMITH, "1. Adjust bar to just below hips, load appropriate weight.\n2. Stand facing bar with feet shoulder-width apart.\n3. Unlock bar from safety catches.\n4. Shrug shoulders straight up toward ears.\n5. Hold top position, squeezing traps.\n6. Lower slowly."),
        Exercise(21035L, "Barbell Good Morning", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Place barbell at shoulder height on rack.\n2. Position under bar resting on upper back.\n3. Grip with hands wider than shoulders.\n4. Hinge at hips, pushing hips back while keeping back flat.\n5. Lower until torso nearly parallel to ground.\n6. Return upright by engaging glutes and hamstrings."),
        Exercise(21036L, "Chin-Up (Close Grip)", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Stand in front of bar, grab with overhand grip about foot apart.\n2. Lift body off floor.\n3. Pull up until chin is above bar, squeezing lats.\n4. Return to starting position."),
        Exercise(21037L, "Cable Grip Lat Pulldown (Narrow Grip)", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Sit down on a cable machine and grab a narrow grip bar.\n2. Pull the bar down towards your chest.\n3. Return back to the starting position and repeat."),
        Exercise(21038L, "Trap Bar Deadlift", listOf(MuscleGroup.BACK), Equipment.TRAPBAR, "1. Stand with feet shoulder-width apart.\n2. Grip handles with firm grip.\n3. Drive through heels, extend hips and knees to lift.\n4. Keep bar close to body."),
        Exercise(21039L, "Cable Rear Pulldown (Wide Grip)", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Sit on bench with pulldown bar.\n2. Pull down behind back until bar is at base of neck and squeeze shoulder muscles.\n3. Return up to starting position."),
        Exercise(21040L, "Cable Rope Seated Row", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Attach rope extension to low pulley.\n2. Sit with feet on rests, grab rope neutral grip.\n3. Pull weight towards sides squeezing back.\n4. Hold, return, repeat."),
        Exercise(21041L, "Barbell Bent-Over Row (Reverse Grip)", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Stand with feet shoulder-width apart.\n2. Grip bar underhand.\n3. Bend hips, lower torso parallel to ground.\n4. Pull bar toward lower abdomen, lower controlled."),
        Exercise(21042L, "Cable Pullover (Supine)", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Lay down with back on bench, head near machine.\n2. Grab bar overhand grip.\n3. Pull hands up creating 45-degree angle.\n4. Feel stretch in shoulders and lats."),
        Exercise(21043L, "Machine Lat Pulldown (Reverse Grip)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Set up wide grip bar.\n2. Grasp with underhand shoulder-width grip.\n3. Pull down towards upper chest squeezing lats.\n4. Return to starting position."),
        Exercise(21044L, "Machine Iso Lateral High Row", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Set up weight on high iso lateral machine.\n2. Sit with feet in front.\n3. Reach up with one hand, lower handle to side squeezing back.\n4. Return and repeat."),
        Exercise(21045L, "Smith Machine Bent-Over Row", listOf(MuscleGroup.BACK), Equipment.SMITH, "1. Stand shoulder-width apart.\n2. Lean forward until chest parallel to floor.\n3. Grab bar wide overhand.\n4. Pull up until almost touching chest.\n5. Hold, squeeze."),
        Exercise(21046L, "Pull-Up (Hammer Grip)", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Grab hammer grip section of bar.\n2. Lift feet off floor.\n3. Pull up slowly squeezing lats until shoulders level with head.\n4. Hold, return, repeat."),
        Exercise(21047L, "Machine T Bar Reverse Row", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Set up T-Bar Row machine with desired weight.\n2. Lay down with chest flat on pad.\n3. Pull bar up towards chest, bringing handles to sides.\n4. Squeeze back."),
        Exercise(21048L, "Cable Pulldown (Underhand)", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Sit upright with abs drawn in.\n2. Grasp pull down bar underhand grip shoulder-width apart.\n3. Pull bar down till it reaches upper chest.\n4. Return slowly."),
        Exercise(21049L, "Machine Vertical Row (Close Grip)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Sit on vertical row machine grabbing handles with hammer grip.\n2. Pull handles in towards sides squeezing back and lat muscles.\n3. Hold for count."),
        Exercise(21050L, "Cable Rope Lat Pulldown", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Set up rope extension on lat pulldown.\n2. Grab neutral grip.\n3. Pull rope down squeezing lats as far as possible.\n4. Hold then return to start."),
        Exercise(21051L, "Leverage Machine Shrug", listOf(MuscleGroup.BACK), Equipment.LEVERAGE, "1. Load leverage machine.\n2. Stand between handles gripping firmly.\n3. Lean forward.\n4. Raise weight by shrugging shoulders up to ears.\n5. Hold, return."),
        Exercise(21052L, "Barbell Sumo Deadlift", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Start with weighted barbell on ground spread feet wide.\n2. Grip with one underhand one overhand.\n3. Drive hips and knees to lift.\n4. Return to start."),
        Exercise(21053L, "Cat Cow Stretch", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Hands and knees tabletop position.\n2. Arch back lifting chest while exhale.\n3. Round spine upward tucking chin.\n4. Flow between poses with breath."),
        Exercise(21054L, "Cable Shrug", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Sit down on machine with feet on footrests.\n2. Grasp handle overhand or neutral.\n3. Pull handle towards torso squeezing shoulder blades.\n4. Hold and return."),
        Exercise(21055L, "Cable Upper Row", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Start standing in front of high pulley cable with narrow grip grip.\n2. Keep knees bent, pull bar back and down toward pecs with elbows bending inward.\n3. Hold for few seconds then return to starting position and repeat."),
        Exercise(21056L, "Pelvic Tilt to Glute Bridge", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Lying on mat with feet flat and heels under knees.\n2. Lift through tailbone, bring torso up to ceiling stretching lower back.\n3. Hold 15-30 seconds when tension felt, return to start and repeat."),
        Exercise(21057L, "Cable One-Arm Row", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Set up handle with one hand in overhand grip.\n2. Knees slightly bent, pull handle toward side while squeezing back.\n3. Return to starting position and repeat for reps."),
        Exercise(21058L, "Superman", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Lie flat on stomach with arms stretched out.\n2. Slowly raise arms and legs off floor, hold until feeling tight stretch in core and back.\n3. Return to starting position."),
        Exercise(21059L, "Cable Elevated Row", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Place platform on bench for cable row machine.\n2. Sit on bench, grab handle and pull toward lower chest.\n3. Feel stretch in lats and lower back.\n4. Hold then return to start."),
        Exercise(21060L, "Smith Machine Deadlift", listOf(MuscleGroup.BACK), Equipment.SMITH, "1. Stand with feet shoulder-width apart, keep back straight and bend at waist.\n2. Grab bar with overhand grip and elevate through legs.\n3. Hold then return to starting position."),
        Exercise(21061L, "Machine Inverted Row", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Position underneath bar with heels on ground.\n2. Grip bar with overhand grip and pull chest toward bar until feeling stretch in middle to lower back.\n3. Hold and return."),
        Exercise(21062L, "One-Arm Hang", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Grip pull-up bar with one hand, palms facing out.\n2. Keep feet flat on floor and hold all weight on that hand for 15 seconds.\n3. Repeat for repetitions needed."),
        Exercise(21063L, "Cable Reverse Crossover", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Stand between machines, grab handles with opposite hands extended to sides.\n2. Let cables return inward while hugging body.\n3. Squeeze then return to starting position."),
        Exercise(21064L, "Barbell Incline Bench Row", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Lay prone on incline bench with legs extended.\n2. Grab bar with shoulder-width grip and raise toward chest while squeezing back.\n3. Hold then return to start."),
        Exercise(21065L, "Machine Assisted Chin-Up", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Adjust weight and position knees on rests.\n2. Grab handles with underhand grip and lift body until shoulders at hand level.\n3. Squeeze lats and hold then return down."),
        Exercise(21066L, "Dumbbell Prone Incline Shrug", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Lie on stomach on incline bench holding dumbbells.\n2. Pull up using shoulders lifting dumbbells toward chest.\n3. Squeeze back tightly then return to start."),
        Exercise(21067L, "Pendlay Row", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Stand with feet shoulder-width apart, torso at 45 degrees.\n2. Pull barbell up toward lower chest while retracting shoulder blades.\n3. Hold and squeeze then return to starting position."),
        Exercise(21068L, "Weight Plate Shrug", listOf(MuscleGroup.BACK), Equipment.WEIGHTPLATE, "1. Stand holding weight plate in each hand at sides.\n2. Shrug shoulders as high as possible, hold for count then return.\n3. Repeat for desired reps and sets."),
        Exercise(21069L, "Machine Lat Pulldown (Reverse Grip)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Sit on machine with knees under padding.\n2. Grab handles with underhand reverse grip and pull down toward sides while squeezing lats.\n3. Hold then return up."),
        Exercise(21070L, "Barbell Rack Pull", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Set barbell on pins just below knees.\n2. Position against bar, extend through hips pulling up until knees locked.\n3. Hold then return to starting position."),
        Exercise(21071L, "Cobra", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Lie face down with arms by sides.\n2. Squeeze glutes lifting chest off floor with arms behind.\n3. Hold for moments then return to starting position and repeat."),
        Exercise(21072L, "Cable Deadlift", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Attach bar to low pulley, stand with back straight.\n2. Bend down and grab bar with overhand grip.\n3. Lift bar to upper thigh level while keeping back, arms, and legs straight."),
        Exercise(21073L, "Dumbbell Bent-Over Row (Palm in)", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Stand tall.\n2. Hinge forward slightly.\n3. Row dumbbells to chest, squeezing back.\n4. Return slowly."),
        Exercise(21074L, "Hip Stretch", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Sit with one leg extended, other crossed over.\n2. Rotate torso toward bent leg.\n3. Hold 15-30 seconds."),
        Exercise(21075L, "Cable Standing Row", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Grab narrow grip.\n2. Keep knees bent.\n3. Pull bar to pecs, elbows in.\n4. Hold, then return."),
        Exercise(21076L, "Smith Machine Stiff-Leg Deadlift", listOf(MuscleGroup.BACK), Equipment.SMITH, "1. Set bar parallel to thighs.\n2. Hold with palms forward.\n3. Lower bar near feet squeezing hamstrings.\n4. Rise up."),
        Exercise(21077L, "Machine One-Arm Pulldown", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Sit on iso lateral machine.\n2. Grab one handle overhand.\n3. Pull to side, squeeze lat/back.\n4. Return and repeat."),
        Exercise(21078L, "Machine Assisted Pull-Up (Hammer Grip)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Position knees on rest.\n2. Grab handles with neutral grip.\n3. Lift body to shoulder level.\n4. Hold, then lower."),
        Exercise(21079L, "Trap Bar Shrugs", listOf(MuscleGroup.BACK), Equipment.TRAPBAR, "1. Stand inside bar with neutral grip.\n2. Elevate shoulders toward ears.\n3. Squeeze trapezius.\n4. Lower shoulders slowly."),
        Exercise(21080L, "Barbell Behind the Back Shrug", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Place bar behind back against quads.\n2. Raise to glutes with shoulders.\n3. Hold, then return."),
        Exercise(21081L, "Barbell Pullover", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Lie on bench holding bar above chest.\n2. Lower arms behind head until chest stretches.\n3. Return to start."),
        Exercise(21082L, "Machine Inverted Row (Feet Elevated)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Lie under bar aligned at mid chest.\n2. Feet across bench.\n3. Row body up.\n4. Return controlled."),
        Exercise(21083L, "Cat Stretch", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Kneel on floor, hands at shoulder level.\n2. Round back and drop head.\n3. Hold.\n4. Return to neutral."),
        Exercise(21084L, "Dumbbell Renegade Row", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Place dumbbells shoulder-width.\n2. Assume high plank.\n3. Lift one dumbbell toward ribcage.\n4. Lower controlled."),
        Exercise(21085L, "Dumbbell Bent-Over Row (Palms in)", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Stand straight.\n2. Bend torso until almost parallel.\n3. Row dumbbells to lower chest.\n4. Return."),
        Exercise(21086L, "Cable Incline Pulldown (Supine)", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Lie back flat on incline bench facing away from machine.\n2. Extend bar down to thighs.\n3. Return squeezing back."),
        Exercise(21087L, "Standing Trunk Rotation", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Stand straight.\n2. Twist waist toward one side.\n3. Hold 15-30 seconds.\n4. Return and repeat opposite."),
        Exercise(21088L, "Barbell Landmine Double Arm Row", listOf(MuscleGroup.BACK), Equipment.LANDMINE, "1. Secure one end in landmine.\n2. Stand facing machine.\n3. Pull bar to lower ribcage.\n4. Squeeze shoulder blades.\n5. Lower."),
        Exercise(21089L, "Machine Vertical Row (Reverse Grip)", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Sit facing vertical row machine with underhand grip.\n2. Pull handles to sides.\n3. Hold.\n4. Return."),
        Exercise(21090L, "Dumbbell Pullover on Stability Ball", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Sit on ball with head/shoulders on surface.\n2. Extend dumbbells behind head.\n3. Lift straight up.\n4. Hold and return."),
        Exercise(21091L, "Kettlebell One-Arm Row", listOf(MuscleGroup.BACK), Equipment.KETTLEBELL, "1. Start off with keeping a kettlebell right in front of you, bending your knees and pushing your glutes out.\n2. Take the kettlebell and pull it up towards your stomach using both your shoulders and back.\n3. As you reach your torso, squeeze your back tightly and hold for a few seconds.\n4. Return back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(21092L, "Cable V-Bar Row", listOf(MuscleGroup.BACK), Equipment.CABLE, "1. Start by setting up a V-Bar attachment to a high pulley cable machine and stand in front of the machine with your feet shoulder width apart.\n2. Grab the handles with a neutral grip and slowly pull the bar in towards your chest, feeling a stretch in your back and lat muscles.\n3. Squeeze and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(21093L, "Chin-Up (Mixed Grip)", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start by standing in front of and grabbing a pull up bar with one hand facing forward palms out and the opposite facing inward palms in.\n2. Once you have a firm grip, slowly pull yourself up and squeezing on your back muscles as you reach the peak position.\n3. Make sure that you keep your elbows as close to your body as possible so you can get the best contraction on your muscles.\n4. Hold this position for a count then return back to the start.\n5. Repeat for as many reps and sets as desired."),
        Exercise(21094L, "Kettlebell Row", listOf(MuscleGroup.BACK), Equipment.KETTLEBELL, "1. Start off with keeping two kettlebell right in front of you, bending your knees and pushing your glutes out.\n2. Take both of the kettlebells and pull them up towards your stomach using both your shoulders and back.\n3. As you reach your torso, squeeze your back tightly and hold for a few seconds.\n4. Return back to the starting position.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(21095L, "Dynamic Back Stretch", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start by standing up straight with your feet shoulder width apart and arms at your side.\n2. Swing your arms straight up in front of you towards the ceiling and repeat for about 5 to 10 times, feeling a stretch in your back.\n3. Repeat for as many reps as desired."),
        Exercise(21096L, "Machine Unilateral Row", listOf(MuscleGroup.BACK), Equipment.MACHINE, "1. Start by setting up the unilateral row machine with the amount of weight that you would like to perform for this exercise, placing the knee opposite of the handle on the padding and grabbing the handle with your opposite hand.\n2. Bend down slightly with your back and then once in position, elevate the handle up towards your side, squeezing your back and lat muscles, and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(21097L, "Rear Pull-Up (Wide Grip)", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start by grabbing a pull-up bar with an overhand grip.\n2. Position each hand about a foot away from your head.\n3. Lift yourself up until the back of neck is behind the pull-up bar.\n4. Exhale as you lift yourself up and inhale as you lower your body.\n5. Slowly let your self back down to the starting position.\n6. Repeat for the desired amount of reps."),
        Exercise(21098L, "Knees to Chest Hug", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start by laying with your back on a mat and knees pulled up towards your chest.\n2. Then place your arms underneath your knees and pull them towards your shoulders, feeling a stretch in your lower back and glutes.\n3. Hold this position for 15 to 30 seconds then return back to the starting position.\n4. Repeat for as many reps and duration as desired."),
        Exercise(21099L, "Dumbbell Incline Row (Reverse Grip)", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Start by setting up an incline bench to around 35 or 45 degrees and laying down on it with your chest flat on the bench.\n2. Hold a dumbbell in each hand, with a reverse grip, extended down towards the floor.\n3. Slowly pull the dumbbells up towards your chest, squeezing your back, and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(21100L, "Barbell Clean Deadlift", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Start off with a weighted barbell right in front of your shins with an overhand grip.\n2. Bend down at the knees with your back straight, chest up, head facing forward and pull up on the barbell with the driving force from your heels.\n3. As you lift the barbell up, keep your back straight and pull up.\n4. When the barbell crosses your knees, lift up with your torso until the bar has reached your hips and your knees are fully extended.\n5. Repeat this exercise for as many repetitions as needed."),
        Exercise(21101L, "Smith Machine Good Morning", listOf(MuscleGroup.BACK), Equipment.SMITH, "1. Start off by placing the bar of the smith machine across your shoulders and keeping your feet shoulder-width apart, as this will be your starting position.\n2. Slowly lower yourself down towards the floor making sure that you keep the lower half of your body still until you feel a stretch in your lower back.\n3. Hold this position for a count then slowly return back up to the start in a controlled manner.\n4. Repeat for as many reps and sets as desired."),
        Exercise(21102L, "Barbell Landmine One-Arm Row", listOf(MuscleGroup.BACK), Equipment.LANDMINE, "1. Place one end of the barbell into the landmine attachment or secure it in a corner.\n2. Load weight plates onto the other end of the barbell according to your strength and fitness level.\n3. Stand beside the landmine with your feet shoulder-width apart, knees slightly bent, and your torso leaning slightly forward.\n4. Reach across your body with one hand and grasp the end of the barbell that's loaded with weights.\n5. Initiate the rowing motion by pulling the barbell upward towards your ribcage, bending your elbow and keeping it close to your body.\n6. Squeeze your shoulder blade toward your spine as you pull, engaging the muscles of your back.\n7. Aim to bring the barbell up until it touches your ribcage or until your elbow is fully bent.\n8. Slowly lower the barbell back to the starting position, fully extending your arm and allowing the weight to hang straight down."),
        Exercise(21103L, "Scorpion", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start lying facedown on the floor in a T position.\n2. Take your hips and rotate them to the left and extend your right leg and knee slowly across your body towards your left hand.\n3. Hold this position and return back to the starting position."),
        Exercise(21104L, "Reverse Lunge Crossover", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start by standing up straight with your feet shoulder width apart and arms at your side.\n2. Slowly perform a rear lunge stepping back with one foot, flexing at your front knee and bending at the hips.\n3. While performing this motion, rotate your body and arms across the front leg that is bent.\n4. Hold this position for 5 to 10 seconds then return back to the starting position.\n5. Repeat this motion to the opposite side and the other leg for as many reps and time limit as you desire."),
        Exercise(21105L, "Dumbbell Rotational Row", listOf(MuscleGroup.BACK), Equipment.DUMBBELL, "1. Start by standing up straight with your feet shoulder width apart and a dumbbell in each hand holding with an overhand grip.\n2. Slowly and slightly lower your back towards the ground so you feel tension in your lower back and then slowly elevate the dumbbells up towards your chest.\n3. Squeeze your back in the process while turning your wrists so that they are in an upright position, hold for a count then return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(21106L, "Upward Facing Dog", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start off by laying face down with your forehead touching the floor and keeping your feet close together.\n2. Keep your fingertips at shoulder level, raise your elbows up in the air then slide your shoulder blades down towards your hips.\n3. Then straighten out your arms, lift up your head, shoulders and chest up towards the ceiling.\n4. Hold this position for 5 to 10 breaths and return back to the starting position."),
        Exercise(21107L, "Thoracic Spine Extension (Foam Roller)", listOf(MuscleGroup.BACK), Equipment.EXERCISEBALL, "1. Begin by sitting on the floor with your knees bent and feet flat on the ground.\n2. Place a foam roller horizontally on the ground behind you, perpendicular to your body.\n3. Slowly lie back onto the foam roller, positioning it underneath your upper back, just below your shoulder blades.\n4. Support your head with your hands, interlacing your fingers and placing them behind your head.\n5. Avoid putting too much weight on your neck.\n6. Engage your core muscles to stabilize your spine and maintain a neutral position throughout the exercise.\n7. Extend your arms straight out to the sides, palms facing up.\n8. This helps to open up the chest and shoulders.\n9. Using your legs, gently push against the ground to roll the foam roller up and down your upper back, focusing on the thoracic spine.\n10. Move slowly and deliberately, allowing the foam roller to apply pressure to different areas of your upper back.\n11. Pay attention to any areas of tightness or tension, and spend extra time rolling over those areas to help release muscle tension.\n12. Once you find a tender spot or area of restriction, pause and focus on extending your upper back over the foam roller.\n13. Slowly arch your back over the foam roller, allowing your chest to open up and your shoulder blades to move apart.\n14. Hold this extended position for a few seconds, focusing on breathing deeply into your chest to facilitate the stretch.\n15. Continue rolling and extending your upper back over the foam roller for 1-2 minutes, gradually working your way up and down the thoracic spine.\n16. Remember to maintain a slow and controlled pace, and listen to your body's feedback to determine how much pressure to apply.\n17. Breathe deeply and slowly throughout the exercise, inhaling as you extend your spine over the foam roller and exhaling as you release the stretch."),
        Exercise(21108L, "EZ Bar Bent-Over Row (Reverse Grip)", listOf(MuscleGroup.BACK), Equipment.EZCURLBAR, "1. Start by setting up an EZ bar with as much weight as you can handle and placing it in front of you, keeping your feet shoulder width apart and arms at your sides.\n2. Squat down and grab onto the bar with a reverse grip, then while keeping your back straight, stand up so that you are holding the bar against your waist.\n3. Slightly bend your knees, keep your back straight, then let the barbell slowly lower beneath your knees.\n4. Slowly pull the bar back up just below your chest, squeezing with your back and feeling a stretch, then hold for a count and return back to the starting position.\n5. Repeat for as many reps and set as desired."),
        Exercise(21109L, "Kneeling Thoracic Mobility", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Begin in kneeling or quadruped position.\n2. Position straight arms front of body with hands on floor.\n3. Bend right arm touching fingers to right side of head while left arm stays straight.\n4. Rotate and move right arm upwards, trying to point right elbow towards ceiling.\n5. Push extended left arm into floor to enable opening up and rotating more."),
        Exercise(21110L, "Upper Back Stretch", listOf(MuscleGroup.BACK), Equipment.BODYWEIGHT, "1. Start standing straight with feet shoulder width apart and arms to sides.\n2. Raise hands out front, clasp fingers together and stretch lower back.\n3. Hold 15 to 30 seconds then return to starting position.\n4. Repeat for desired reps."),
        Exercise(21111L, "Barbell Seated Good Morning", listOf(MuscleGroup.BACK), Equipment.BARBELL, "1. Sit on bench or box with butt resting on edge, barbell on shoulders behind neck.\n2. Lower torso toward knees, squeezing back tightly and pressing barbell down on shoulders.\n3. Tighten abdominals.\n4. Return to starting position.\n5. Repeat as needed."),

        // FOREARMS
        Exercise(22001L, "Dumbbell Hammer Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Stand feet apart with neutral grip.\n2. Curl arms to shoulders.\n3. Lower slowly.\n4. Keep wrists straight."),
        Exercise(22002L, "Dumbbell Wrist Curl (Palms Up)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Kneel over a bench.\n2. Flex wrists to lift.\n3. Exhale up, inhale down.\n4. Isolate wrists only."),
        Exercise(22003L, "Dumbbell Wrist Curl (Palms Down)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Kneel over a bench with palms down.\n2. Flex wrists to lift.\n3. Hold, then lower.\n4. Keep arms still."),
        Exercise(22004L, "Barbell Reverse Curl", listOf(MuscleGroup.FOREARMS), Equipment.BARBELL, "1. Stand apart.\n2. Hold barbell palms down.\n3. Lift to chest.\n4. Keep upper arms straight and wrists stable."),
        Exercise(22005L, "EZ Bar Curl (Reverse Grip)", listOf(MuscleGroup.FOREARMS), Equipment.EZCURLBAR, "1. Stand holding EZ Bar at waist.\n2. Lift towards shoulders.\n3. Squeeze forearms.\n4. Return to start position."),
        Exercise(22006L, "Barbell Wrist Curl (Posterior)", listOf(MuscleGroup.FOREARMS), Equipment.BARBELL, "1. Stand apart.\n2. Grasp barbell palms out.\n3. Lift bar using hands only.\n4. Keep arms straight and stable."),
        Exercise(22007L, "Cable Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.CABLE, "1. Sit on bench, arms on thighs.\n2. Grab cable bar.\n3. Pull to chest.\n4. Hold briefly before lowering."),
        Exercise(22008L, "Barbell Wrist Curl (Palms Up)", listOf(MuscleGroup.FOREARMS), Equipment.BARBELL, "1. Place barbell on floor.\n2. Sit on bench.\n3. Rest forearms on thighs.\n4. Curl wrist up.\n5. Lower slowly."),
        Exercise(22009L, "Dumbbell Seated Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit holding dumbbells.\n2. Rest forearms on knees.\n3. Curl wrists up.\n4. Hold.\n5. Return to starting position."),
        Exercise(22010L, "Dumbbell One-Arm Wrist Curl (Pronated)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on bench edge.\n2. Rest forearm on knee.\n3. Hold dumbbell palm down.\n4. Curl up.\n5. Feel stretch."),
        Exercise(22011L, "Dumbbell Bicep Curl (Reverse Grip)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Stand with arms at sides, palms down.\n2. Lift dumbbells to shoulders.\n3. Squeeze forearm.\n4. Return to start."),
        Exercise(22012L, "Barbell Wrist Curl (Palms Down)", listOf(MuscleGroup.FOREARMS), Equipment.BARBELL, "1. Place barbell on floor.\n2. Sit on bench.\n3. Rest forearms on thighs.\n4. Curl wrists up.\n5. Lower slowly."),
        Exercise(22013L, "Wrist Roller", listOf(MuscleGroup.FOREARMS), Equipment.OTHER, "1. Stand straight.\n2. Hold roller palms down.\n3. Lift arms parallel to floor.\n4. Rotate wrists up and down."),
        Exercise(22014L, "Cable Behind the Back Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.CABLE, "1. Set low pulley bar behind back.\n2. Keep elbows tucked.\n3. Raise bar squeezing forearms.\n4. Lower to start."),
        Exercise(22015L, "Cable Wrist Curl (Reverse Grip)", listOf(MuscleGroup.FOREARMS), Equipment.CABLE, "1. Set up bar on low pulley.\n2. Sit facing machine.\n3. Grab bar reverse grip.\n4. Raise bar with stretch."),
        Exercise(22016L, "Dumbbell Supinated One-Arm Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on bench edge.\n2. Rest arm on knee, palm up.\n3. Curl dumbbell.\n4. Hold and lower.\n5. Keep legs still."),
        Exercise(22017L, "Barbell Preacher Curl (Overhand)", listOf(MuscleGroup.FOREARMS), Equipment.BARBELL, "1. Sit on preacher bench.\n2. Back of arms on pad.\n3. Grasp bar overhand.\n4. Raise until forearms vertical."),
        Exercise(22018L, "Barbell Kneeling Wrist Curl (Palms Up)", listOf(MuscleGroup.FOREARMS), Equipment.BARBELL, "1. Kneel over bench.\n2. Hold barbell palms up.\n3. Flex wrists lifting and lowering.\n4. Exhale up, inhale down."),
        Exercise(22019L, "Dumbbell Reverse Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on flat bench with feet flat on floor, holding dumbbells in each hand using a reverse grip.\n2. Rest arms on legs so weights are extended off.\n3. Slowly lower weights down below your legs as starting position.\n4. Using only your wrist, curl the dumbbell up until you feel a stretch in your forearm muscles."),
        Exercise(22020L, "Dumbbell Seated Wrist Curl (Palms Down)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Place two dumbbells on floor in front of a flat bench.\n2. Sit down on bench with legs shoulder width apart.\n3. Grab dumbbells and bring it up so that your forearms are resting on your thighs with palms facing downward.\n4. Weights should be hanging over your knees as starting position.\n5. Slowly curl your wrist upwards while exhaling until you feel a stretch in your forearm muscles."),
        Exercise(22021L, "Cable One-Arm Reverse Curl", listOf(MuscleGroup.FOREARMS), Equipment.CABLE, "1. Set up a handle on a low pulley cable machine and grab the handle with one hand with your elbow rested at your side.\n2. Keeping your body straight, slowly elevate the handle up towards your shoulders, squeezing your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22022L, "Kneeling Forearm Stretch", listOf(MuscleGroup.FOREARMS), Equipment.BODYWEIGHT, "1. Start your body off in a kneeling position with your palms flat facing forward.\n2. Lean back keeping your palms on the floor until you feel a stretch in your forearms.\n3. Hold this position for up to 25-seconds and then return back.\n4. Repeat this exercise for as many repetitions as needed."),
        Exercise(22023L, "Barbell Kneeling Wrist Curl (Palms Down)", listOf(MuscleGroup.FOREARMS), Equipment.BARBELL, "1. Pick up a barbell while kneeling over a bench.\n2. With your palms facing downwards flex each forearm by lifting and lowering the barbell with only your wrist.\n3. Exhale while raising your wrist.\n4. Inhale while lowering your wrist.\n5. Repeat for the desired amount of reps."),
        Exercise(22024L, "Dumbbell Wrist Curl (Neutral Grip)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Kneel in front of a horizontal bench with your forearms rested upon the padding and holding a dumbbell in both hands with a neutral grip.\n2. Slowly lower the dumbbell down below the bench as far as possible squeezing your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22025L, "Wrist Circles", listOf(MuscleGroup.FOREARMS), Equipment.BODYWEIGHT, "1. Stand up straight with your feet shoulder width apart and your arms at your sides.\n2. Elevate your hands so that they are at about hip level and fully extended out in front of you.\n3. Begin to rotate your wrists in a forward circular motion, keeping the rest of your body still.\n4. Repeat for as many repetitions as desired."),
        Exercise(22026L, "Weight Plate Hand Squeeze", listOf(MuscleGroup.FOREARMS), Equipment.WEIGHTPLATE, "1. Stand up straight with your feet shoulder width apart, arms at your side and one arm holding a weight plate at hip level.\n2. Lower the weight down so that your fingers are nearly extended but you are still able to hold onto the weight and hold this position for a count.\n3. Raise the plate back up to the starting position and repeat for as many reps and sets as desired."),
        Exercise(22027L, "Dumbbell One-Arm Reverse Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Stand up straight, feet shoulder width apart and arms rested at your sides holding a dumbbell in one hand with a palms down reverse grip.\n2. Slowly elevate the dumbbell up to your shoulder, squeezing your forearm, and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22028L, "Dumbbell Alternating Reverse Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Stand up straight, feet shoulder width apart and arms rested at your sides holding a dumbbell in each hand with a palms down reverse grip.\n2. Slowly with one arm elevate the dumbbell up to your shoulder, squeezing your forearm, and hold for a count.\n3. Return back to the starting position and repeat with the opposite arm.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22029L, "EZ Bar Preacher Curl (Reverse Grip)", listOf(MuscleGroup.FOREARMS), Equipment.EZCURLBAR, "1. Sit on a preacher bench and holding a weighted EZ Bar in your hands with arms rested on the pad.\n2. Slowly elevate the bar up towards your shoulders, squeezing your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22030L, "Dumbbell One-Arm Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Kneel in front of a horizontal bench with your forearms rested upon the padding and one arm holding a dumbbell.\n2. Slowly lower the dumbbell down below the bench as far as possible squeezing your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22031L, "Weight Plate Pinch", listOf(MuscleGroup.FOREARMS), Equipment.WEIGHTPLATE, "1. Take two weight plates and place them together.\n2. Take your fingers and thumb and squeeze the plates together, holding the position for as long as possible.\n3. Repeat this exercise for as many repetitions as needed."),
        Exercise(22032L, "Dumbbell Seated Wrist Curl (Neutral Grip)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on the end of a flat bench with your feet flat on the floor and holding a dumbbell in both hands using a neutral (hammer) grip.\n2. Rest your arms on your legs so the weights are extended off of your knees.\n3. Lower the weights down below your knees as this will be your starting position.\n4. Slowly raise the dumbbells up, only using your wrists and squeeze until you feel a stretch in your forearm muscle."),
        Exercise(22033L, "Modified Push-Up to Forearms", listOf(MuscleGroup.FOREARMS), Equipment.BODYWEIGHT, "1. Start off on your hands and knees in a modified push up position.\n2. Squeeze your glutes and bring one elbow down to the floor followed by the other so that your upper body is rested upon your forearms.\n3. Return back to the starting position by straightening out one arm and then the other.\n4. Repeat for as many reps and sets desired."),
        Exercise(22034L, "Dumbbell Seated One-Arm Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on the end of a flat bench with your feet flat on the floor and holding a dumbbell in one hand using a neutral grip.\n2. Rest the arm holding the dumbbell on the same leg so the weight is extended off.\n3. Slowly lower the weight down below your leg, squeeze using your forearm and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(22035L, "Cable Reverse Preacher Curl", listOf(MuscleGroup.FOREARMS), Equipment.CABLE, "1. Set up a straight bar on a low pulley cable machine with a preacher bench attached or bringing a preacher bench close to the machine.\n2. Grab onto the bar with a reverse grip and rest your arms on the padding.\n3. Slowly curl the bar straight up towards your shoulders, squeezing your forearms and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(22036L, "Dumbbell Reverse Concentration Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on the end of a flat bench with your feet flat on the floor and holding a dumbbell in one hand using an underhand grip.\n2. Rest the arm holding the dumbbell on the inside of the same leg so the weight is extended off and turn it inward towards the opposite leg.\n3. Slowly lower the weight down below your leg, squeeze using your forearm and hold for a count.\n4. Return back to the starting position.\n5. Repeat for as many reps and sets as desired."),
        Exercise(22037L, "Dumbbell One-Arm Reverse Preacher Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on a preacher bench with your upper arms resting upon the padding and holding a dumbbell in one hand with a reverse grip.\n2. Slowly raise the dumbbell up towards your shoulders, squeezing in your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22038L, "Dumbbell One-Arm Reverse Bench Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Kneel in front of a horizontal bench with your forearms rested upon the padding and holding a dumbbell in one hand with a reverse grip.\n2. Slowly lower the dumbbell down below the bench as far as possible squeezing your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22039L, "Smith Machine Behind the Back Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.SMITH, "1. Set up a weighted smith machine and grab the bar behind your back using an underhand shoulder width grip.\n2. Keep your elbows tucked in at your sides and slowly raise the bar up, squeezing your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22040L, "Dumbbell Pronation (Side-Lying)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Lie sideways on a flat bench with one arm holding a dumbbell.\n2. Take the upper arm that is holding the dumbbell and rotate the forearm so that it is lifted forward and up.\n3. Repeat this exercise for as many repetitions as needed."),
        Exercise(22041L, "Dumbbell Supination (Side-Lying)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Lie sideways on a flat bench with one arm holding a dumbbell.\n2. Take the upper arm that is holding the dumbbell and rotate the forearm so that it is lifted forward and down.\n3. Repeat this exercise for as many repetitions as needed."),
        Exercise(22042L, "Dumbbell One-Arm Wrist Curl Over Bench (Neutral)", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Kneel in front of a horizontal bench with your forearms rested upon the padding and holding a dumbbell in one hand with a neutral grip.\n2. Slowly lower the dumbbell down below the bench as far as possible squeezing your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22043L, "Kettlebell Hang Clean", listOf(MuscleGroup.FOREARMS), Equipment.KETTLEBELL, "1. Take a kettlebell in one hand and stand upright with the kettlebell next to your side.\n2. Take the kettlebell and swing it back then raise it to shoulder level.\n3. Repeat this exercise for as many repetitions as needed."),
        Exercise(22044L, "Dumbbell Reverse Preacher Curl", listOf(MuscleGroup.FOREARMS), Equipment.DUMBBELL, "1. Sit on a preacher bench with your upper arms resting upon the padding and holding a dumbbell in each hand with a reverse grip.\n2. Slowly raise the dumbbells up towards your shoulders, squeezing in your forearms and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired."),
        Exercise(22045L, "Smith Machine Wrist Curl", listOf(MuscleGroup.FOREARMS), Equipment.SMITH, "1. Sit down at the end of a flat bench positioned behind a weighted smith machine, grabbing it with an underhand shoulder width grip.\n2. Keep your elbows at your side and slowly lower the weight below your legs, squeezing your forearms, and hold for a count.\n3. Return back to the starting position.\n4. Repeat for as many reps and sets as desired.")
    )

    suspend fun searchExercises(query: String): List<Exercise> {
        if (query.isBlank()) return emptyList()
        val lowerQuery = query.lowercase()
        return exerciseDatabase.filter {
            it.name.lowercase().contains(lowerQuery) ||
                    it.instructions?.lowercase()?.contains(lowerQuery) ?: false
        }
    }

    fun filterByMuscleGroup(muscleGroup: MuscleGroup): List<Exercise> {
        return exerciseDatabase.filter { it.muscleGroups.contains(muscleGroup) }
    }

    fun getExerciseById(id: Long): Exercise? {
        return exerciseDatabase.find { it.id == id }
    }
}
